@article{ahn_AlteredFunctionalConnectivitySalience_2021,
  title = {Altered {{Functional Connectivity}} of the {{Salience Network}} in {{Problematic Smartphone Users}}},
  author = {Ahn, Jaeun and Lee, Deokjong and Namkoong, Kee and Jung, Young-Chul},
  year = 2021,
  month = jul,
  journal = {Frontiers in Psychiatry},
  volume = {12},
