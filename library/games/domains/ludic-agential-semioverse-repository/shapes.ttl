@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ludd:  <https://emsenn.net/ns/domain/ludic#> .

# =============================================================================
# Ludic ASR — SHACL Validation Shapes
#
# Ludic validity is mechanical: content is valid when the structures,
# constraints, and boundaries it describes are concrete enough to recognize
# in practice. Terms must specify what elements do. Specifications must
# provide constitutive criteria. Lessons must include worked examples.
# =============================================================================

ludd:TermShape
    a sh:NodeShape ;
    sh:targetClass ludd:Term ;
    sh:property [
        sh:path ludd:defines ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A term MUST have defines: with the canonical term name."
    ] ;
    sh:property [
        sh:path ludd:cites ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A term SHOULD cite who introduced or developed it."
    ] .

ludd:LessonShape
    a sh:NodeShape ;
    sh:targetClass ludd:Lesson ;
    sh:property [
        sh:path ludd:teaches ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A lesson MUST specify teaches: listing what it develops."
    ] ;
    sh:property [
        sh:path ludd:requires ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A lesson SHOULD specify requires: listing prerequisites."
    ] ;
    sh:property [
        sh:path ludd:usesMechanic ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A lesson SHOULD specify uses-mechanic: listing mechanics it analyzes."
    ] .

ludd:SpecificationShape
    a sh:NodeShape ;
    sh:targetClass ludd:Specification ;
    sh:property [
        sh:path ludd:classifies ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A specification SHOULD specify classifies: listing what it categorizes."
    ] ;
    sh:property [
        sh:path ludd:usesMechanic ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A specification SHOULD specify uses-mechanic: listing central mechanics."
    ] ;
    sh:sparql [
        sh:severity sh:Warning ;
        sh:message "A specification SHOULD include a boundary cases section." ;
        sh:select """
            SELECT $this WHERE {
                $this a ludd:Specification .
                FILTER NOT EXISTS { $this ludd:hasBoundaryCasesSection true }
            }
        """
    ] .

ludd:TextShape
    a sh:NodeShape ;
    sh:targetClass ludd:Text ;
    sh:property [
        sh:path ludd:cites ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A text SHOULD cite its sources and influences."
    ] .

# --- Cross-type constraint ---

ludd:NoSelfReferenceShape
    a sh:NodeShape ;
    sh:targetClass ludd:Term, ludd:Lesson ;
    sh:sparql [
        sh:severity sh:Violation ;
        sh:message "A page must not list itself in its own requires: or teaches: fields." ;
        sh:select """
            SELECT $this WHERE {
                { $this ludd:requires $this }
                UNION
                { $this ludd:teaches $this }
            }
        """
    ] .
