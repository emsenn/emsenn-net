@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix emsenn: <https://emsenn.net/> .
@prefix agsv:   <https://emsenn.net/mathematics/objects/universes/agential-semioverse#> .
@prefix isv:    <https://emsenn.net/mathematics/objects/universes/interactive-semioverse#> .

# ===========================================================================
# Agential Semioverse Ontology
#
# Encodes the mathematical objects from agential-semioverse.md.
# Each class corresponds to a definition in the spec; each property
# corresponds to a component of a tuple or a constraint.
# ===========================================================================

agsv: a owl:Ontology ;
    rdfs:label "Agential Semioverse" ;
    rdfs:comment "Ontology for the agential semioverse: agents, skills, tools, and execution semantics over an interactive semioverse base." ;
    owl:imports isv: .

# ---------------------------------------------------------------------------
# Classes
# ---------------------------------------------------------------------------

agsv:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An agent handle. External index, not an element of H. See agential-semioverse.md, Agent Handles." ;
    rdfs:subClassOf isv:ThingHandle .

agsv:AgentProfile a owl:Class ;
    rdfs:label "Agent Profile" ;
    rdfs:comment "A tuple P(a) = (role, goals, policy, Skills, Tools, Mem). See agential-semioverse.md, Agent Profiles." .

agsv:InternalAgent a owl:Class ;
    rdfs:label "Internal Agent" ;
    rdfs:comment "A triple A = (Sigma, K, Pi) where Sigma is bounded state, K is a finite set of interaction operators, Pi is a policy. See agential-semioverse.md, Internal agents." ;
    rdfs:subClassOf agsv:Agent .

agsv:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:comment "A tuple t = (name, invocation, precondition, effect). Primitive typed partial operator on states. See agential-semioverse.md, Tool Signatures." .

agsv:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A tuple S = (id, T_in, T_out, Scopes, denotation). Composed from tools via the skill calculus. See agential-semioverse.md, Skill Specification." .

agsv:SkillTerm a owl:Class ;
    rdfs:label "Skill Term" ;
    rdfs:comment "An element of the smallest set generated by call, let, seq, if, lambda, app. See agential-semioverse.md, Skill Calculus." .

agsv:CallTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "Call Term" ;
    rdfs:comment "call(t, args) — primitive tool invocation." .

agsv:LetTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "Let Term" ;
    rdfs:comment "let x = s1 in s2 — sequential binding." .

agsv:SeqTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "Seq Term" ;
    rdfs:comment "seq(s1, s2) — sequential composition." .

agsv:IfTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "If Term" ;
    rdfs:comment "if p then s1 else s2 — conditional." .

agsv:LambdaTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "Lambda Term" ;
    rdfs:comment "lambda x. s — abstraction." .

agsv:AppTerm a owl:Class ;
    rdfs:subClassOf agsv:SkillTerm ;
    rdfs:label "App Term" ;
    rdfs:comment "s1(s2) — application." .

agsv:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A monotone predicate Pol on (skill, input, state). Restricts agent to its declared skills and tools. See agential-semioverse.md, Policy and Authorization." .

agsv:ExecutionStep a owl:Class ;
    rdfs:label "Execution Step" ;
    rdfs:comment "A tuple Exec(a, s, in, X) = (X', out, trace). See agential-semioverse.md, Execution Semantics." .

agsv:EffectReport a owl:Class ;
    rdfs:label "Effect Report" ;
    rdfs:comment "Required output of every skill execution: created paths, modified paths, content hashes. See agential-semioverse.md, Effect Reports and Artifacts." .

agsv:Module a owl:Class ;
    rdfs:label "Module" ;
    rdfs:comment "A colocated collection of artifacts interpreted as one Thing, anchored by /{id}/{id}.md. See agential-semioverse.md, Module Semantics." ;
    rdfs:subClassOf isv:Thing .

agsv:InputSchema a owl:Class ;
    rdfs:label "Input Schema" ;
    rdfs:comment "T_in: strict input schema requiring total decoding." .

agsv:OutputSchema a owl:Class ;
    rdfs:label "Output Schema" ;
    rdfs:comment "T_out: strict output schema including effect reports." .

agsv:AuthorizationScope a owl:Class ;
    rdfs:label "Authorization Scope" ;
    rdfs:comment "An element of the finite set of authorization predicates required by a skill." .

# ---------------------------------------------------------------------------
# Properties — Agent Profile components
# ---------------------------------------------------------------------------

agsv:hasProfile a owl:ObjectProperty ;
    rdfs:label "has profile" ;
    rdfs:comment "P : Agent -> Profile" ;
    rdfs:domain agsv:Agent ;
    rdfs:range agsv:AgentProfile .

agsv:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    rdfs:comment "role_a: a role label." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range xsd:string .

agsv:hasGoal a owl:DatatypeProperty ;
    rdfs:label "has goal" ;
    rdfs:comment "An element of goals_a." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range xsd:string .

agsv:hasPolicy a owl:ObjectProperty ;
    rdfs:label "has policy" ;
    rdfs:comment "policy_a: policy predicate on actions." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range agsv:Policy .

agsv:hasSkill a owl:ObjectProperty ;
    rdfs:label "has skill" ;
    rdfs:comment "An element of Skills_a." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range agsv:Skill .

agsv:hasTool a owl:ObjectProperty ;
    rdfs:label "has tool" ;
    rdfs:comment "An element of Tools_a." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range agsv:Tool .

agsv:hasMemory a owl:ObjectProperty ;
    rdfs:label "has memory" ;
    rdfs:comment "Mem_a: a fragment representing agent memory." ;
    rdfs:domain agsv:AgentProfile ;
    rdfs:range isv:Fragment .

# ---------------------------------------------------------------------------
# Properties — Tool components
# ---------------------------------------------------------------------------

agsv:toolName a owl:DatatypeProperty ;
    rdfs:label "tool name" ;
    rdfs:domain agsv:Tool ;
    rdfs:range xsd:string .

agsv:invocation a owl:DatatypeProperty ;
    rdfs:label "invocation" ;
    rdfs:comment "Identifies a runnable capability (command, script, or service)." ;
    rdfs:domain agsv:Tool ;
    rdfs:range xsd:string .

agsv:precondition a owl:DatatypeProperty ;
    rdfs:label "precondition" ;
    rdfs:comment "Predicate on state and inputs." ;
    rdfs:domain agsv:Tool ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Properties — Skill components
# ---------------------------------------------------------------------------

agsv:skillId a owl:DatatypeProperty ;
    rdfs:label "skill id" ;
    rdfs:comment "Globally stable identifier." ;
    rdfs:domain agsv:Skill ;
    rdfs:range xsd:string .

agsv:inputSchema a owl:ObjectProperty ;
    rdfs:label "input schema" ;
    rdfs:comment "T_in: strict input schema." ;
    rdfs:domain agsv:Skill ;
    rdfs:range agsv:InputSchema .

agsv:outputSchema a owl:ObjectProperty ;
    rdfs:label "output schema" ;
    rdfs:comment "T_out: strict output schema including effect reports." ;
    rdfs:domain agsv:Skill ;
    rdfs:range agsv:OutputSchema .

agsv:requiresScope a owl:ObjectProperty ;
    rdfs:label "requires scope" ;
    rdfs:comment "An element of Scopes." ;
    rdfs:domain agsv:Skill ;
    rdfs:range agsv:AuthorizationScope .

agsv:denotation a owl:ObjectProperty ;
    rdfs:label "denotation" ;
    rdfs:comment "S: T_in -> Int. The skill's interpretation as an interaction operator." ;
    rdfs:domain agsv:Skill ;
    rdfs:range isv:InteractionOperator .

agsv:hasBody a owl:ObjectProperty ;
    rdfs:label "has body" ;
    rdfs:comment "The skill term that defines this skill's computation." ;
    rdfs:domain agsv:Skill ;
    rdfs:range agsv:SkillTerm .

# ---------------------------------------------------------------------------
# Properties — Skill Term structure
# ---------------------------------------------------------------------------

agsv:callsTool a owl:ObjectProperty ;
    rdfs:label "calls tool" ;
    rdfs:comment "The tool invoked by a call term." ;
    rdfs:domain agsv:CallTerm ;
    rdfs:range agsv:Tool .

agsv:bindingTerm a owl:ObjectProperty ;
    rdfs:label "binding term" ;
    rdfs:comment "s1 in let x = s1 in s2." ;
    rdfs:domain agsv:LetTerm ;
    rdfs:range agsv:SkillTerm .

agsv:bodyTerm a owl:ObjectProperty ;
    rdfs:label "body term" ;
    rdfs:comment "s2 in let x = s1 in s2, or the body of a lambda." ;
    rdfs:domain agsv:SkillTerm ;
    rdfs:range agsv:SkillTerm .

agsv:firstTerm a owl:ObjectProperty ;
    rdfs:label "first term" ;
    rdfs:comment "s1 in seq(s1, s2)." ;
    rdfs:domain agsv:SeqTerm ;
    rdfs:range agsv:SkillTerm .

agsv:secondTerm a owl:ObjectProperty ;
    rdfs:label "second term" ;
    rdfs:comment "s2 in seq(s1, s2)." ;
    rdfs:domain agsv:SeqTerm ;
    rdfs:range agsv:SkillTerm .

agsv:thenBranch a owl:ObjectProperty ;
    rdfs:label "then branch" ;
    rdfs:domain agsv:IfTerm ;
    rdfs:range agsv:SkillTerm .

agsv:elseBranch a owl:ObjectProperty ;
    rdfs:label "else branch" ;
    rdfs:domain agsv:IfTerm ;
    rdfs:range agsv:SkillTerm .

# ---------------------------------------------------------------------------
# Properties — Execution
# ---------------------------------------------------------------------------

agsv:executedBy a owl:ObjectProperty ;
    rdfs:label "executed by" ;
    rdfs:domain agsv:ExecutionStep ;
    rdfs:range agsv:Agent .

agsv:executesSkill a owl:ObjectProperty ;
    rdfs:label "executes skill" ;
    rdfs:domain agsv:ExecutionStep ;
    rdfs:range agsv:Skill .

agsv:producesEffect a owl:ObjectProperty ;
    rdfs:label "produces effect" ;
    rdfs:domain agsv:ExecutionStep ;
    rdfs:range agsv:EffectReport .

# ---------------------------------------------------------------------------
# Properties — Effect Report
# ---------------------------------------------------------------------------

agsv:createdPath a owl:DatatypeProperty ;
    rdfs:label "created path" ;
    rdfs:domain agsv:EffectReport ;
    rdfs:range xsd:string .

agsv:modifiedPath a owl:DatatypeProperty ;
    rdfs:label "modified path" ;
    rdfs:domain agsv:EffectReport ;
    rdfs:range xsd:string .

agsv:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash" ;
    rdfs:domain agsv:EffectReport ;
    rdfs:range xsd:string .

# ---------------------------------------------------------------------------
# Admissibility constraints (as annotations)
# ---------------------------------------------------------------------------

agsv:isMonotone a owl:AnnotationProperty ;
    rdfs:label "is monotone" ;
    rdfs:comment "The operator is monotone in the state component." .

agsv:isFragmentPreserving a owl:AnnotationProperty ;
    rdfs:label "is fragment-preserving" ;
    rdfs:comment "Maps fragments to fragments." .

agsv:isClosureCompatible a owl:AnnotationProperty ;
    rdfs:label "is closure-compatible" ;
    rdfs:comment "S(t(X)) >= t(S(X)) for all X." .

agsv:Tool agsv:isMonotone true ;
    agsv:isFragmentPreserving true ;
    agsv:isClosureCompatible true .

agsv:Skill agsv:isMonotone true ;
    agsv:isFragmentPreserving true ;
    agsv:isClosureCompatible true .
