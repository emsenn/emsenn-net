@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix mathd: <https://emsenn.net/ns/domain/mathematical#> .
@prefix asr:   <https://emsenn.net/ns/agential-semioverse-repository#> .

mathd: a owl:Ontology ;
    rdfs:label "Mathematical ASR Ontology" ;
    rdfs:comment """
        Content types and typed relations for mathematical knowledge within
        an Agential Semioverse Repository. Extends the general ASR ontology
        with types whose validity is constitutive: the presence or absence
        of relations determines what the content IS.
    """ .

# --- Classes ---

mathd:Definition a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Definition" ;
    rdfs:comment "Establishes the meaning of a mathematical term or structure." .

mathd:Axiom a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Axiom" ;
    rdfs:comment "A proposition taken as given within a theory." .

mathd:Theorem a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Theorem" ;
    rdfs:comment "A proposition proven true within a formal system." .

mathd:Proof a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Proof" ;
    rdfs:comment "A demonstration that a proposition is true." .

mathd:Lemma a owl:Class ;
    rdfs:subClassOf mathd:Theorem ;
    rdfs:label "Lemma" ;
    rdfs:comment "Auxiliary result supporting a theorem." .

mathd:Proposition a owl:Class ;
    rdfs:subClassOf mathd:Theorem ;
    rdfs:label "Proposition" ;
    rdfs:comment "Proven result of intermediate significance." .

mathd:Corollary a owl:Class ;
    rdfs:subClassOf mathd:Theorem ;
    rdfs:label "Corollary" ;
    rdfs:comment "Result following readily from a theorem." .

mathd:Conjecture a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Conjecture" ;
    rdfs:comment "Proposition believed true but not yet proven." ;
    owl:disjointWith mathd:Theorem .

mathd:Example a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Example" ;
    rdfs:comment "Concrete instance illustrating a definition, theorem, or concept." .

mathd:Counterexample a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Counterexample" ;
    rdfs:comment "Concrete instance showing a statement is false." .

# --- Properties ---

mathd:provenBy a owl:ObjectProperty ;
    rdfs:label "proven by" ;
    rdfs:domain mathd:Theorem ;
    rdfs:range mathd:Proof ;
    owl:inverseOf mathd:proves .

mathd:proves a owl:ObjectProperty ;
    rdfs:label "proves" ;
    rdfs:domain mathd:Proof ;
    rdfs:range mathd:Theorem ;
    owl:inverseOf mathd:provenBy .

mathd:followsFrom a owl:ObjectProperty ;
    rdfs:label "follows from" ;
    rdfs:domain mathd:Corollary ;
    rdfs:range mathd:Theorem .

mathd:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:domain mathd:Lemma ;
    rdfs:range mathd:Theorem .

mathd:enables a owl:ObjectProperty ;
    rdfs:label "enables" ;
    rdfs:domain mathd:Axiom .

mathd:uses a owl:ObjectProperty ;
    rdfs:label "uses" ;
    rdfs:domain mathd:Proof .

mathd:illustrates a owl:ObjectProperty ;
    rdfs:label "illustrates" ;
    rdfs:domain mathd:Example .

mathd:hasExample a owl:ObjectProperty ;
    rdfs:label "has example" ;
    rdfs:range mathd:Example ;
    owl:inverseOf mathd:illustrates .

mathd:refutes a owl:ObjectProperty ;
    rdfs:label "refutes" ;
    rdfs:domain mathd:Counterexample .

mathd:evidence a owl:ObjectProperty ;
    rdfs:label "evidence" ;
    rdfs:domain mathd:Conjecture .

mathd:technique a owl:DatatypeProperty ;
    rdfs:label "technique" ;
    rdfs:domain mathd:Proof ;
    rdfs:range xsd:string .

mathd:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:domain mathd:Definition .

mathd:requires a owl:ObjectProperty ;
    rdfs:label "requires" .

mathd:partOf a owl:ObjectProperty ;
    rdfs:label "part of" .
