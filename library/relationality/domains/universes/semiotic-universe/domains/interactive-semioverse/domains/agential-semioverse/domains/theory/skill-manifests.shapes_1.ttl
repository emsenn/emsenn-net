@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix asr:   <https://emsenn.net/asr/ontology#> .
@prefix rel:   <https://emsenn.net/relationality/ontology#> .

# =============================================================================
# SHACL Shapes for Skill Manifest Validation
#
# Encodes the validation rules from skill-manifests.md Section 11:
#   1. Required fields present (id, description, region)
#   2. id matches directory name
#   3. dependencies reference existing skill ids
#   4. region.reads and region.writes reference valid paths
#   5. inputs and outputs are well-typed
#   6. triggers present for invocable skills (runtime: inference | script)
#
# Also encodes:
#   - Invariant 2.2 (required fields, defaults)
#   - Invariant 2.3 (triggers requirement for dispatchable skills)
#   - Definition 2.1 of skill-manifests.md (manifest tuple structure)
# =============================================================================

# -----------------------------------------------------------------------------
# Core Manifest Shape
# Validates the required structure of a skill manifest.
# Every SKILL.md must satisfy this shape.
# -----------------------------------------------------------------------------

asr:SkillManifestShape a sh:NodeShape ;
    sh:targetClass asr:SkillManifest ;
    rdfs:label "Skill Manifest Shape" ;
    rdfs:comment """Validates a skill manifest against the operational frontmatter
    schema defined in skill-manifests.md Section 2.""" ;

    # Required: id (SkillId, immutable)
    sh:property [
        sh:path asr:id ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-z][a-z0-9-]*$" ;
        sh:name "id" ;
        sh:description "Skill identifier. Must be kebab-case, must match directory name." ;
        sh:severity sh:Violation ;
    ] ;

    # Required: description (human-readable label)
    sh:property [
        sh:path asr:description ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "description" ;
        sh:description "Human-readable description of what the skill does." ;
        sh:severity sh:Violation ;
    ] ;

    # Required: region (reads/writes declaration)
    sh:property [
        sh:path asr:region ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:node asr:RegionShape ;
        sh:name "region" ;
        sh:description "File-system region the skill reads from and writes to." ;
        sh:severity sh:Violation ;
    ] ;

    # Optional with default [0, 1]: version
    sh:property [
        sh:path asr:version ;
        sh:maxCount 1 ;
        sh:node asr:VersionShape ;
        sh:name "version" ;
        sh:description "Semantic version as [major, minor]. Defaults to [0, 1]." ;
        sh:severity sh:Info ;
    ] ;

    # Optional with default "operational": kind
    sh:property [
        sh:path asr:kind ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "operational" "learn" "meta" ) ;
        sh:name "kind" ;
        sh:description "Skill kind: operational (acts on content), learn (curriculum), meta (acts on infrastructure)." ;
        sh:severity sh:Warning ;
    ] ;

    # Optional with default "inference": runtime
    sh:property [
        sh:path asr:runtime ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "inference" "script" "manual" "documentation" ) ;
        sh:name "runtime" ;
        sh:description "Execution runtime: inference (LLM), script (colocated code), manual (human), documentation (reference only)." ;
        sh:severity sh:Warning ;
    ] ;

    # Optional with default []: triggers
    sh:property [
        sh:path asr:triggers ;
        sh:datatype xsd:string ;
        sh:name "triggers" ;
        sh:description "Natural language phrases that dispatch to this skill." ;
        sh:severity sh:Info ;
    ] ;

    # Optional with default []: dependencies
    sh:property [
        sh:path asr:dependencies ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-z][a-z0-9-]*$" ;
        sh:name "dependencies" ;
        sh:description "Skill ids this skill depends on. Must reference existing skills." ;
        sh:severity sh:Warning ;
    ] ;

    # Optional with default []: scopes
    sh:property [
        sh:path asr:scopes ;
        sh:datatype xsd:string ;
        sh:name "scopes" ;
        sh:description "Authorization scopes required to execute this skill." ;
        sh:severity sh:Info ;
    ] .

# -----------------------------------------------------------------------------
# Region Shape
# Validates the region declaration (reads/writes paths).
# -----------------------------------------------------------------------------

asr:RegionShape a sh:NodeShape ;
    rdfs:label "Region Shape" ;
    rdfs:comment "Validates region declarations with reads and writes path lists." ;

    sh:property [
        sh:path asr:reads ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-zA-Z._{}*/]+/?$" ;
        sh:name "reads" ;
        sh:description "Paths the skill reads from. Must be valid directory path patterns." ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path asr:writes ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-zA-Z._{}*/]+/?$" ;
        sh:name "writes" ;
        sh:description "Paths the skill writes to. Must be valid directory path patterns." ;
        sh:severity sh:Violation ;
    ] .

# -----------------------------------------------------------------------------
# Version Shape
# Validates version as a two-element list [major, minor].
# -----------------------------------------------------------------------------

asr:VersionShape a sh:NodeShape ;
    rdfs:label "Version Shape" ;
    rdfs:comment "Version tuple [major, minor] where both are non-negative integers." ;

    sh:property [
        sh:path asr:major ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:name "major version" ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path asr:minor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:name "minor version" ;
        sh:severity sh:Violation ;
    ] .

# -----------------------------------------------------------------------------
# Dispatchable Skill Shape (Invariant 5.2)
# Skills with runtime inference or script SHOULD have triggers.
# This is a sh:Warning, not a sh:Violation — skills without triggers
# can still be invoked by direct naming or as dependencies.
# -----------------------------------------------------------------------------

asr:DispatchableSkillShape a sh:NodeShape ;
    sh:targetClass asr:SkillManifest ;
    rdfs:label "Dispatchable Skill Shape" ;
    rdfs:comment """Invariant 5.2: A skill with runtime inference or script should
    include at least one trigger phrase.""" ;

    sh:sparql [
        sh:message "Dispatchable skill (runtime: {?runtime}) has no trigger phrases. It can only be invoked by direct naming (/skill-id) or as a dependency." ;
        sh:severity sh:Warning ;
        sh:select """
            SELECT $this ?runtime
            WHERE {
                $this asr:runtime ?runtime .
                FILTER (?runtime IN ("inference", "script"))
                FILTER NOT EXISTS { $this asr:triggers ?trigger }
            }
        """ ;
    ] .

# -----------------------------------------------------------------------------
# Dependency Acyclicity Shape
# From skill-manifests.md Invariant 5.3: the dependency graph must be a DAG.
# SHACL cannot express graph-level acyclicity directly; this shape checks
# that no skill lists itself as a dependency (the simplest cycle).
# Full DAG validation requires a script (validate-manifest.py).
# -----------------------------------------------------------------------------

asr:NoCyclicDependencyShape a sh:NodeShape ;
    sh:targetClass asr:SkillManifest ;
    rdfs:label "No Self-Dependency Shape" ;
    rdfs:comment "A skill must not list itself as a dependency." ;

    sh:sparql [
        sh:message "Skill {?id} lists itself as a dependency." ;
        sh:severity sh:Violation ;
        sh:select """
            SELECT $this ?id
            WHERE {
                $this asr:id ?id .
                $this asr:dependencies ?dep .
                FILTER (?dep = ?id)
            }
        """ ;
    ] .

# -----------------------------------------------------------------------------
# Input/Output Type Shape
# Validates that input and output type declarations use the recognized
# type vocabulary: string, number, boolean, object, string[], object[].
# The ? suffix marks optional parameters.
# -----------------------------------------------------------------------------

asr:TypedParameterShape a sh:NodeShape ;
    rdfs:label "Typed Parameter Shape" ;
    rdfs:comment "Validates that parameter types use the recognized vocabulary." ;

    sh:property [
        sh:path asr:parameterType ;
        sh:datatype xsd:string ;
        sh:pattern "^(string|number|boolean|object|string\\[\\]|object\\[\\])\\??$" ;
        sh:name "parameter type" ;
        sh:description "Must be one of: string, number, boolean, object, string[], object[]. Append ? for optional." ;
        sh:severity sh:Warning ;
    ] .
