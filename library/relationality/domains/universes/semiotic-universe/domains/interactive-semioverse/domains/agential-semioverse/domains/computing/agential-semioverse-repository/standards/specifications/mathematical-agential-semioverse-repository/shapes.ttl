@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mathd: <https://emsenn.net/ns/domain/mathematical#> .

# =============================================================================
# Mathematical ASR — SHACL Validation Shapes
#
# These shapes validate mathematical relations. They fire when the
# relevant relation is present on a page, regardless of what other
# relations the page uses.
# =============================================================================

mathd:DefinitionShape
    a sh:NodeShape ;
    sh:targetClass mathd:Definition ;
    sh:property [
        sh:path mathd:defines ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A definition MUST define at least one term."
    ] ;
    sh:property [
        sh:path mathd:hasExample ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A definition SHOULD link to at least one example."
    ] .

mathd:AxiomShape
    a sh:NodeShape ;
    sh:targetClass mathd:Axiom ;
    sh:property [
        sh:path mathd:partOf ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "An axiom MUST specify its axiomatic system (part-of:)."
    ] ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:maxCount 0 ;
        sh:severity sh:Violation ;
        sh:message "An axiom MUST NOT have a proven-by relation."
    ] .

mathd:TheoremShape
    a sh:NodeShape ;
    sh:targetClass mathd:Theorem ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A theorem MUST have at least one proven-by relation. Without proof, use type: conjecture."
    ] ;
    sh:property [
        sh:path mathd:requires ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A theorem SHOULD specify its dependencies (requires:)."
    ] .

mathd:ProofShape
    a sh:NodeShape ;
    sh:targetClass mathd:Proof ;
    sh:property [
        sh:path mathd:proves ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A proof MUST prove exactly one theorem, lemma, or proposition."
    ] ;
    sh:property [
        sh:path mathd:uses ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A proof SHOULD list what it uses."
    ] .

mathd:LemmaShape
    a sh:NodeShape ;
    sh:targetClass mathd:Lemma ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A lemma MUST be proven."
    ] ;
    sh:property [
        sh:path mathd:supports ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A lemma SHOULD specify which theorem(s) it supports."
    ] .

mathd:PropositionShape
    a sh:NodeShape ;
    sh:targetClass mathd:Proposition ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A proposition MUST be proven."
    ] .

mathd:CorollaryShape
    a sh:NodeShape ;
    sh:targetClass mathd:Corollary ;
    sh:property [
        sh:path mathd:followsFrom ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A corollary MUST specify what theorem it follows from."
    ] ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A corollary MUST have a proof."
    ] .

mathd:ConjectureShape
    a sh:NodeShape ;
    sh:targetClass mathd:Conjecture ;
    sh:property [
        sh:path mathd:provenBy ;
        sh:maxCount 0 ;
        sh:severity sh:Violation ;
        sh:message "A conjecture MUST NOT be proven. If proven, reclassify as theorem."
    ] ;
    sh:property [
        sh:path mathd:evidence ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A conjecture SHOULD provide supporting evidence."
    ] .

mathd:ExampleShape
    a sh:NodeShape ;
    sh:targetClass mathd:Example ;
    sh:property [
        sh:path mathd:illustrates ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "An example MUST specify what it illustrates."
    ] .

mathd:CounterexampleShape
    a sh:NodeShape ;
    sh:targetClass mathd:Counterexample ;
    sh:property [
        sh:path mathd:refutes ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A counterexample MUST specify what it refutes."
    ] .

mathd:NoSelfReferenceShape
    a sh:NodeShape ;
    sh:targetSubjectsOf mathd:requires ;
    sh:sparql [
        sh:severity sh:Violation ;
        sh:message "A page MUST NOT require itself." ;
        sh:select """
            SELECT $this
            WHERE { $this mathd:requires $this }
        """
    ] .
