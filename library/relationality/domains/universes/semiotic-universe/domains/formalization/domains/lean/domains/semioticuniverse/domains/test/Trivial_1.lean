/-
# Test.Trivial — Golden tests with concrete instances

Exercises the SemioticAmbient typeclasses against the simplest
possible instances to verify the axioms are consistent and the
derived lemmas typecheck.

Instance 1: Prop with identity operators.
  H = Prop,  j = id,  G = id.
  This is the degenerate semiotic universe where everything is
  already habitual and provenance is trivial.
-/

import SemioticUniverse.Fusion

namespace SemioticUniverse.Test

/-!
## Instance 1: Prop with identity operators

Prop is a complete Heyting algebra (classical, in fact).
With j = id and G = id, all axioms are trivially satisfied.
-/

instance : HeytingDomain Prop where

instance : ModalClosure Prop where
  j := id
  extensive := fun _ h => h
  monotone := fun _ _ hab ha => hab ha
  idempotent := fun _ => rfl
  join_preserving := fun _ _ => rfl
  j_bot := rfl
  meet_preserving := fun _ _ => rfl

instance : TraceComonad Prop where
  G := id
  counit := fun _ h => h
  comult := fun _ h => h
  pres_inf := fun _ _ => rfl
  pres_sup := fun _ _ => rfl
  pres_himp := fun _ _ => rfl
  pres_top := rfl
  pres_bot := rfl

instance : SemioticAmbient Prop where
  j_G_le_G_j := fun _ h => h
  habitual_iff_trace_habitual := fun _ => Iff.rfl

/-!
### §1 Tests: Ambient structure lemmas
-/

-- ⊤ and ⊥ are habitual.
example : IsHabitual (True : Prop) := isHabitual_top
example : IsHabitual (False : Prop) := isHabitual_bot

-- In this instance, everything is habitual (j = id).
example (a : Prop) : IsHabitual a :=
  show ModalClosure.j a = a from rfl

-- G is idempotent.
example (a : Prop) : TraceComonad.G (TraceComonad.G a) = TraceComonad.G a :=
  TraceComonad.idempotent a

-- Habituality is preserved by G.
example (a : Prop) (ha : IsHabitual a) :
    IsHabitual (TraceComonad.G a) :=
  isHabitual_G_of_isHabitual ha

-- Meet of habitual elements is habitual.
example (a b : Prop) (ha : IsHabitual a) (hb : IsHabitual b) :
    IsHabitual (a ∧ b) :=
  IsHabitual.inf ha hb

-- Heyting implication of habitual elements is habitual.
example (a b : Prop) (ha : IsHabitual a) (hb : IsHabitual b) :
    IsHabitual (a → b) :=
  IsHabitual.himp ha hb

/-!
### §2 Tests: Syntax examples typecheck
-/

-- The identity term has the right type.
#check (idP : Term [] (Ty.P ⇒ Ty.P))

-- The constant function has the right type.
#check (constP : Term [] (Ty.P ⇒ Ty.P ⇒ Ty.P))

-- Projection terms have the right types.
#check (fstP : Term [] (Ty.P ⊗ Ty.P ⇒ Ty.P))
#check (sndP : Term [] (Ty.P ⊗ Ty.P ⇒ Ty.P))

/-!
### §3 Tests: Fragment examples
-/

-- The minimal fragment: generated by the empty set.
-- For Prop with j = id and G = id, the closure of {} under
-- Heyting+j+G operations is just {True, False} = {⊤, ⊥}.
-- We define mem as: a ∈ F iff a = True ∨ a = False.
-- This is provably minimal: any subalgebra contains ⊤ and ⊥.
private def minimalMem (a : Prop) : Prop := a = True ∨ a = False

private theorem minimalMem_top : minimalMem (⊤ : Prop) := Or.inl rfl
private theorem minimalMem_bot : minimalMem (⊥ : Prop) := Or.inr rfl

def trivialFragment : Fragment (H := Prop) where
  mem := minimalMem
  isSubalgebra := {
    inf_mem := fun {a b} ha hb => by
      cases ha with
      | inl h => cases hb with
        | inl h' => exact Or.inl (by simp [h, h'])
        | inr h' => exact Or.inr (by simp [h, h'])
      | inr h => exact Or.inr (by simp [h])
    sup_mem := fun {a b} ha hb => by
      cases ha with
      | inl h => exact Or.inl (by simp [h])
      | inr h => cases hb with
        | inl h' => exact Or.inl (by simp [h, h'])
        | inr h' => exact Or.inr (by simp [h, h'])
    himp_mem := fun {a b} ha hb => by
      cases ha with
      | inl h => cases hb with
        | inl h' => exact Or.inl (by simp [h, h'])
        | inr h' => exact Or.inr (by simp [h, h'])
      | inr h => exact Or.inl (by simp [h])
    top_mem := minimalMem_top
    bot_mem := minimalMem_bot
    j_mem := fun ha => ha  -- j = id
    G_mem := fun ha => ha  -- G = id
  }
  generators := []
  generators_mem := fun _ h => by simp at h
  minimal := fun F' hSub _hGen _a _ha =>
    -- Any subalgebra contains ⊤ and ⊥. For the minimal fragment
    -- on Prop (j=id, G=id), mem a means a = True ∨ a = False.
    match _ha with
    | Or.inl h => h ▸ hSub.top_mem
    | Or.inr h => h ▸ hSub.bot_mem

-- j preserves the trivial fragment.
example : PreservesFragment (ModalClosure.j : Prop → Prop)
    trivialFragment :=
  j_fragmentPreserving trivialFragment

-- G preserves the trivial fragment.
example : PreservesFragment (TraceComonad.G : Prop → Prop)
    trivialFragment :=
  G_fragmentPreserving trivialFragment

/-!
### §4 Tests: Interpretation instance
-/

-- A concrete interpretation: every operator is interpreted as id.
-- This is the trivial interpretation where syntax contributes
-- nothing beyond what the semantics already has.
instance : Interpretation₁ Prop where
  interp₁ := fun _ => id
  monotone₁ := fun _ _ _ hab => hab
  modal_hom₁ := fun _ _ => rfl
  trace_compat₁ := fun _ _ => rfl
  fragment_pres₁ := fun _ _ _ ha => ha

-- Proposition 4.1 holds on the trivial instance.
example (f : DefOp) (a : Prop) (ha : IsHabitual a) :
    IsHabitual (Interpretation₁.interp₁ f a) :=
  interp_preserves_habitual₁ f a ha

-- The trace of an interpreted habitual value is habitual.
example (f : DefOp) (a : Prop) (ha : IsHabitual a) :
    IsHabitual (TraceComonad.G (Interpretation₁.interp₁ f a)) :=
  interp_trace_habitual₁ f a ha

-- Interpreted operators are fragment-preserving.
example (f : DefOp) :
    IsFragmentPreserving (Interpretation₁.interp₁ f : Prop → Prop) :=
  interp_fragmentPreserving₁ f

/-!
### §5–6 Tests: Fusion
-/

-- A partial structure with everything.
def fullStructure : PartialStructure (H := Prop) where
  sem := fun _ => True
  syn := fun _ => True

-- Fusion closure is inflationary.
example : fullStructure ≤ fusionClosure (H := Prop) fullStructure :=
  fusionClosure_inflationary fullStructure

-- The fusion closure is fusion-saturated.
example : IsFusionSaturated (fusionClosure (H := Prop) fullStructure) :=
  fusionClosure_saturated fullStructure

-- The fusion reflection: S_fus(X) ≤ Y ↔ X ≤ Y for saturated Y.
example (Y : PartialStructure (H := Prop))
    (hY : IsFusionSaturated Y) :
    fusionClosure fullStructure ≤ Y ↔ fullStructure ≤ Y :=
  fusion_reflection hY

-- Congruence on the trivial interpretation is trivially reflexive.
example (f : DefOp) (hf : fullStructure.syn f) :
    Congruent (H := Prop) fullStructure f f :=
  Congruent.refl hf

-- Admissible behavior: id is admissible on Prop.
def idBehavior : AdmissibleBehavior (H := Prop) where
  fn := id
  monotone := fun _ _ h => h
  modal_compat := fun _ => rfl
  trace_compat := fun _ => rfl
  fragment_pres := fun _ _ h => h

-- Admissible behaviors preserve habituality.
example (a : Prop) (ha : IsHabitual a) :
    IsHabitual (idBehavior.fn a) :=
  idBehavior.preserves_habitual ha

end SemioticUniverse.Test
