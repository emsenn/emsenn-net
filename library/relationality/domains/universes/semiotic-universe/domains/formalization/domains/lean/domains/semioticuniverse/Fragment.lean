/-
# Fragment — Finitely Generated Modal-Temporal Subalgebras

Corresponds to §3 of semiotic-universe.md.

Interpretation is always local: a sign is interpreted in a
bounded context, not against the totality of the sign system
at once. Fragments formalize these bounded interpretive contexts.

A modal-temporal subalgebra F ⊆ H is closed under:
  - Heyting operations (∧, ∨, ⇨, ⊤, ⊥)
  - modal closure j
  - trace G

A fragment is a *finitely generated* modal-temporal subalgebra:
one generated by a finite set of meanings.

§3.1 defines subalgebras and fragments.
§3.2 defines restriction of operators to fragments.
§3.3 defines fragmentwise equality and hereditary extensionality.
-/

import SemioticUniverse.Ambient

namespace SemioticUniverse

variable {H : Type*} [SemioticAmbient H]

/-!
## §3.1 Modal-Temporal Subalgebras
-/

/-- A modal-temporal subalgebra: a predicate on H closed under
all Heyting, modal, and trace operations. (Definition 3.1) -/
structure IsSubalgebra (F : H → Prop) : Prop where
  /-- Closed under meet. -/
  inf_mem : ∀ {a b}, F a → F b → F (a ⊓ b)
  /-- Closed under join. -/
  sup_mem : ∀ {a b}, F a → F b → F (a ⊔ b)
  /-- Closed under Heyting implication. -/
  himp_mem : ∀ {a b}, F a → F b → F (a ⇨ b)
  /-- Contains top. -/
  top_mem : F ⊤
  /-- Contains bottom. -/
  bot_mem : F ⊥
  /-- Closed under j. -/
  j_mem : ∀ {a}, F a → F (ModalClosure.j a)
  /-- Closed under G. -/
  G_mem : ∀ {a}, F a → F (TraceComonad.G a)

/-- A fragment is a finitely generated modal-temporal subalgebra.
(Definition 3.2)

We represent finite generation by requiring a finite list of
generators such that F is the smallest subalgebra containing them.

For the formalization, we represent a fragment as:
  - a predicate F : H → Prop identifying members
  - a proof that F is a subalgebra
  - a finite generating set
  - a proof that F is the smallest subalgebra containing
    the generators -/
structure Fragment where
  /-- The membership predicate. -/
  mem : H → Prop
  /-- Proof that mem defines a subalgebra. -/
  isSubalgebra : IsSubalgebra mem
  /-- The finite generating set. -/
  generators : List H
  /-- Every generator is in the fragment. -/
  generators_mem : ∀ a, a ∈ generators → mem a
  /-- Minimality: F is contained in any subalgebra containing
  the generators. -/
  minimal : ∀ (F' : H → Prop), IsSubalgebra F' →
    (∀ a, a ∈ generators → F' a) → ∀ a, mem a → F' a

/-!
## §3.2 Restriction of Operators

An operator f : Hⁿ → H is fragment-preserving on F if
f(F^n) ⊆ F. When this holds, the restriction f|_F is
well-defined.

An operator is fragment-preserving (globally) if it preserves
every fragment. (Definition 3.3)
-/

/-- An operator (arity 1) is fragment-preserving on a specific
fragment if it maps members to members. -/
def PreservesFragment (f : H → H) (F : Fragment (H := H)) : Prop :=
  ∀ a, F.mem a → F.mem (f a)

/-- An operator is fragment-preserving if it preserves every
fragment. (Definition 3.3) -/
def IsFragmentPreserving (f : H → H) : Prop :=
  ∀ (F : Fragment (H := H)), PreservesFragment f F

/-- j is fragment-preserving. -/
theorem j_fragmentPreserving :
    IsFragmentPreserving (ModalClosure.j : H → H) :=
  fun F _a ha => F.isSubalgebra.j_mem ha

/-- G is fragment-preserving. -/
theorem G_fragmentPreserving :
    IsFragmentPreserving (TraceComonad.G : H → H) :=
  fun F _a ha => F.isSubalgebra.G_mem ha

/-!
## §3.3 Fragmentwise Equality

Two operators agree on a fragment F if they produce the same
output for all inputs from F. (Definition 3.4)
-/

/-- Fragmentwise equality for unary operators. -/
def FragmentwiseEq (f g : H → H) (F : Fragment (H := H)) : Prop :=
  ∀ a, F.mem a → f a = g a

/-- Fragmentwise equality for n-ary operators (represented as
functions on lists). -/
def FragmentwiseEqN (f g : List H → H) (F : Fragment (H := H))
    (n : Nat) : Prop :=
  ∀ args : List H, args.length = n →
    (∀ a, a ∈ args → F.mem a) → f args = g args

/-!
## §3.3 Hereditary Extensionality

A family of operators is hereditarily extensional if fragmentwise
equality on one fragment propagates to all fragments reachable by
Heyting operations, j, G, and the operators themselves.
(Definition 3.5)

This captures the semiotic insight that if two interpretive
procedures agree in one bounded context, they agree in every
context reachable from it by the sign system's own operations.
-/

/-- A family of unary operators is hereditarily extensional if
fragmentwise equality propagates under all closure operations.
(Definition 3.5, simplified to unary case) -/
def IsHereditarilyExtensional (ops : List (H → H)) : Prop :=
  ∀ f g, f ∈ ops → g ∈ ops →
    ∀ (F : Fragment (H := H)), FragmentwiseEq f g F →
      -- For any fragment F' reachable from F by applying
      -- Heyting operations, j, G, or operators in the family:
      ∀ (F' : Fragment (H := H)),
        -- (We require F ⊆ F' as a simplification of "reachable";
        -- the full definition would track the closure under the
        -- generating operations.)
        (∀ a, F.mem a → F'.mem a) →
        FragmentwiseEq f g F'

end SemioticUniverse
