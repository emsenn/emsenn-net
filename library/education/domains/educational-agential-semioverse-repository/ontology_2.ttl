@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix edud:  <https://emsenn.net/ns/domain/educational#> .
@prefix asr:   <https://emsenn.net/ns/agential-semioverse-repository#> .

edud: a owl:Ontology ;
    rdfs:label "Educational ASR Ontology" ;
    rdfs:comment """
        Content types and typed relations for educational knowledge within
        an Agential Semioverse Repository. Extends the general ASR ontology
        with types whose validity is governed by pedagogical soundness:
        content is valid when it teaches rather than deposits.
    """ .

# --- Classes ---

edud:Lesson a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Lesson" ;
    rdfs:comment "A teaching document that builds understanding of a single core idea through concrete grounding and active engagement." .

edud:Curriculum a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Curriculum" ;
    rdfs:comment "A structured sequence of lessons organized as a dependency graph." .

edud:Skill a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Skill" ;
    rdfs:comment "A node in the curriculum dependency graph defining what a learner can do." .

edud:LearnSkill a owl:Class ;
    rdfs:subClassOf edud:Skill ;
    rdfs:label "Learn Skill" ;
    rdfs:comment "A skill that defines a learning outcome with testable completion criteria." .

edud:OperationalSkill a owl:Class ;
    rdfs:subClassOf edud:Skill ;
    rdfs:label "Operational Skill" ;
    rdfs:comment "A skill that defines a repeatable procedure for creating or evaluating content." .

edud:Term a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Term" ;
    rdfs:comment "A definition page for a concept within the education domain." .

edud:School a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "School" ;
    rdfs:comment "A page describing a pedagogical tradition or intellectual school." .

edud:TransmissionMode a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Transmission Mode" ;
    rdfs:comment "A page describing a mode through which knowledge moves between people, generations, or communities." .

# --- Object Properties ---

edud:teaches a owl:ObjectProperty ;
    rdfs:label "teaches" ;
    rdfs:domain edud:Lesson ;
    rdfs:comment "Source develops understanding of target." ;
    owl:inverseOf edud:practicedThrough .

edud:practicedThrough a owl:ObjectProperty ;
    rdfs:label "practiced through" ;
    rdfs:range edud:Lesson ;
    rdfs:comment "Target teaches source (inverse of teaches)." ;
    owl:inverseOf edud:teaches .

edud:scaffolds a owl:ObjectProperty ;
    rdfs:label "scaffolds" ;
    rdfs:domain edud:Lesson ;
    rdfs:comment "Source provides temporary support for learning target." .

edud:prerequisiteOf a owl:ObjectProperty ;
    rdfs:label "prerequisite of" ;
    rdfs:comment "Target requires source." .

edud:buildsOn a owl:ObjectProperty ;
    rdfs:label "builds on" ;
    rdfs:domain edud:Curriculum ;
    rdfs:comment "Source extends target's learning." .

edud:contestedBy a owl:ObjectProperty ;
    rdfs:label "contested by" ;
    rdfs:comment "Target challenges source." .

edud:transmissionMode a owl:ObjectProperty ;
    rdfs:label "transmission mode" ;
    rdfs:range edud:TransmissionMode ;
    rdfs:comment "How knowledge associated with source is transmitted." .

# --- Datatype Properties ---

edud:completionCriterion a owl:DatatypeProperty ;
    rdfs:label "completion criterion" ;
    rdfs:domain edud:Skill ;
    rdfs:range xsd:string ;
    rdfs:comment "Testable statement of what the skill enables." .

edud:tradition a owl:DatatypeProperty ;
    rdfs:label "tradition" ;
    rdfs:range xsd:string ;
    rdfs:comment "Intellectual tradition context." .

edud:centers a owl:DatatypeProperty ;
    rdfs:label "centers" ;
    rdfs:range xsd:string ;
    rdfs:comment "Whose knowledge the source privileges." .

edud:excludes a owl:DatatypeProperty ;
    rdfs:label "excludes" ;
    rdfs:range xsd:string ;
    rdfs:comment "What the source does not cover and why." .

edud:reproduces a owl:DatatypeProperty ;
    rdfs:label "reproduces" ;
    rdfs:range xsd:string ;
    rdfs:comment "Structural pattern the content replicates (e.g., banking model)." .

edud:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:domain edud:Term .

edud:requires a owl:ObjectProperty ;
    rdfs:label "requires" .

edud:cites a owl:ObjectProperty ;
    rdfs:label "cites" .
