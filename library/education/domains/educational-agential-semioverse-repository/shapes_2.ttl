@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix edud:  <https://emsenn.net/ns/domain/educational#> .

# =============================================================================
# Educational ASR — SHACL Validation Shapes
#
# These shapes validate educational relations. They fire when the relevant
# relation is present on a page, regardless of what other relations the page
# uses. Severity levels:
#   sh:Violation — constitutive requirement (content is ill-formed without it)
#   sh:Warning   — recommended (content is valid but weaker without it)
# =============================================================================

edud:LessonShape
    a sh:NodeShape ;
    sh:targetClass edud:Lesson ;
    sh:property [
        sh:path edud:teaches ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A lesson SHOULD specify what it teaches (teaches:)."
    ] ;
    sh:property [
        sh:path edud:requires ;
        sh:minCount 0 ;
        sh:severity sh:Info ;
        sh:message "A lesson with no prerequisites should state this explicitly."
    ] .

edud:LessonWorkedExampleShape
    a sh:NodeShape ;
    sh:targetClass edud:Lesson ;
    rdfs:comment "Structural check: lessons MUST contain a worked example section." ;
    sh:sparql [
        sh:severity sh:Violation ;
        sh:message "A lesson MUST include a worked example." ;
        sh:select """
            SELECT $this
            WHERE {
                $this a edud:Lesson .
                FILTER NOT EXISTS { $this edud:hasWorkedExample true }
            }
        """
    ] .

edud:LessonExerciseShape
    a sh:NodeShape ;
    sh:targetClass edud:Lesson ;
    rdfs:comment "Structural check: lessons MUST contain exercises or self-check questions." ;
    sh:sparql [
        sh:severity sh:Violation ;
        sh:message "A lesson MUST include exercises or self-check questions." ;
        sh:select """
            SELECT $this
            WHERE {
                $this a edud:Lesson .
                FILTER NOT EXISTS { $this edud:hasExercises true }
            }
        """
    ] .

edud:CurriculumShape
    a sh:NodeShape ;
    sh:targetClass edud:Curriculum ;
    sh:property [
        sh:path edud:teaches ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A curriculum SHOULD specify what skills or competencies it develops."
    ] .

edud:LearnSkillShape
    a sh:NodeShape ;
    sh:targetClass edud:LearnSkill ;
    sh:property [
        sh:path edud:completionCriterion ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A learn skill MUST have at least one testable completion criterion."
    ] .

edud:TermShape
    a sh:NodeShape ;
    sh:targetClass edud:Term ;
    sh:property [
        sh:path edud:defines ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A term page MUST define at least one term."
    ] ;
    sh:property [
        sh:path edud:cites ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A term page SHOULD cite its intellectual sources."
    ] .

edud:SchoolShape
    a sh:NodeShape ;
    sh:targetClass edud:School ;
    sh:property [
        sh:path edud:tradition ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "A school page SHOULD specify its broader intellectual tradition."
    ] .

edud:TransmissionModeShape
    a sh:NodeShape ;
    sh:targetClass edud:TransmissionMode ;
    sh:property [
        sh:path edud:defines ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A transmission mode page MUST define the mode."
    ] .

edud:NoSelfReferenceShape
    a sh:NodeShape ;
    sh:targetSubjectsOf edud:requires ;
    sh:sparql [
        sh:severity sh:Violation ;
        sh:message "A page MUST NOT require itself." ;
        sh:select """
            SELECT $this
            WHERE { $this edud:requires $this }
        """
    ] .
