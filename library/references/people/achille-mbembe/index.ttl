  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/references/people/achille-mbembe/> ;
  schema:name "Achille Mbembe" ;
  schema:description "Achille Mbembe (1957–) is a Cameroonian post-colonial theorist whose work extends Foucauldian biopolitics into necropolitics — the analysis of contemporary regimes of power as the production and management of death-worlds — and develops a comprehensive critique of the colonial constitution of modern subjectivity." ;
  schema:datePublished "2026-04-27" ;
