  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/references/people/frantz-fanon/> ;
  schema:name "Frantz Fanon" ;
  schema:description "Frantz Fanon (1925-1961) was a Martinican psychiatrist, philosopher, and revolutionary whose analysis of the colonial subject's psychic formation and of the violence of decolonization is foundational to post-colonial thought, the black radical tradition, and the contemporary decolonial-critical apparatus." ;
