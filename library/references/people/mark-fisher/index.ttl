  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/references/people/mark-fisher/> ;
  schema:name "Mark Fisher" ;
  schema:description "Mark Fisher (1968-2017) was a British cultural theorist whose work — capitalist realism, the slow cancellation of the future, hauntology, the weird and the eerie — developed a sustained diagnosis of the late-capitalist condition's affective-temporal pathology and its consequences for subjects' capacity to imagine alternatives." ;
