  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/texts/append-only-log-as-history-monoid/> ;
  schema:name "Append-Only Logs Are History Monoids" ;
  schema:description "Append-only event logs are trace monoids (history monoids) — formal algebraic objects where independent events commute and dependent events do not. This structure is not a metaphor; it is the mathematical identity of event-sourced systems." ;
  schema:datePublished "2026-04-04" ;
