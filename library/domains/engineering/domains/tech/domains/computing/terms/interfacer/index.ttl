  rdf:type "component" ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/metaphysics/domains/ontology/terms/boundary/> , "adapter-pattern" , "serialization" , "format" ;
