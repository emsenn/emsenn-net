&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/terms/operator/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/terms/operator/> ;
  schema:name "Operator" ;
  schema:description "A computing operator is a mathematical operator realised in a computational system: a typed, effectively-computable transformation whose source and target are representable in finite resources and whose action is given by a procedure rather than by an existence claim." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
