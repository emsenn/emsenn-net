  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/software/domains/programming/terms/pure-function/> ;
  schema:name "pure function" ;
  schema:description "A **pure function** is a [function](/technology/disciplines/computing/software/programming/terms/function.md) that satisfies two conditions: it always produces the same output when given the same inputs, and it causes no observable changes outside itself (no side effects)." ;
