&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/internet/domains/activitypub/terms/activity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/internet/domains/activitypub/terms/activity/> ;
  schema:name "Activity" ;
  schema:description "An Activity is the basic unit of interaction in [ActivityPub](../index.md). It's a verb-object pair — an action performed by an [Actor](./actor.md) on some target — expressed in the [ActivityStreams 2.0](./activitystreams-2-0.md) vocabulary and distributed across the [federation](./federation.md) via server-to-server delivery." ;
