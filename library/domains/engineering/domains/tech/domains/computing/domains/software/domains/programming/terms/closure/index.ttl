&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/software/domains/programming/terms/closure/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/software/domains/programming/terms/closure/> ;
  schema:name "closure" ;
  schema:description "A **closure** is a [first-class function](./first-class-function.md) bundled together with a reference to the environment in which it was defined. When the function is later called — possibly far from where it was created — it can still access the [variables](/technology/disciplines/computing/software/programming/terms/variable.md) that were in scope at the time of its creation." ;
  schema:datePublished "2026-03-05" ;
