&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/internet/domains/activitypub/terms/actor/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/internet/domains/activitypub/terms/actor/> ;
  schema:name "Actor" ;
  schema:description "An Actor is an addressable entity in [ActivityPub](../index.md) — a user account, a bot, a service, or any other thing that can send and receive [activities](./activity.md). Each actor has an inbox (where it receives activities from the [federation](./federation.md)) and an outbox (where it publishes activities)." ;
  schema:datePublished "2025-12-31" ;
