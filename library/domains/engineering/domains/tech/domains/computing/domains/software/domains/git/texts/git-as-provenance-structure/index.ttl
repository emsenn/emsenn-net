  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/software/domains/git/texts/git-as-provenance-structure/> ;
  schema:name "Git as Provenance Structure" ;
  schema:description "Git is a version control system. It is also, read differently, a provenance structure: an immutable record of what was done, when, by whom, and building on what prior work. This lesson reads git's data model through that lens, connecting its design to the formal concept of provenance in the [Interactive Semioverse](../../../../../../mathematics/objects/universes/interactive-semioverse/index.md)." ;
  schema:datePublished "2026-03-01" ;
