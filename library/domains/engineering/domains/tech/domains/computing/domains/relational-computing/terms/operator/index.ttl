&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/relational-computing/terms/operator/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/relational-computing/terms/operator/> ;
  schema:name "Operator" ;
  schema:description "A relational-computing operator is a computing operator whose source and target are graphs of relations rather than stored values — a transformation that takes a relation graph (or a region of one) to another relation graph by the addition, retraction, or traversal of relations." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "value-mutation" ;
  schema:about &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/domains/relational-computing/terms/operator/> ;
