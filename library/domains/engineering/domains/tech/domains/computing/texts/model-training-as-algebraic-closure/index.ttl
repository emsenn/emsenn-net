&lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/texts/model-training-as-algebraic-closure/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/texts/model-training-as-algebraic-closure/> ;
  schema:name "Model Training as Algebraic Closure" ;
  schema:description "The mathematical structure of LLM training maps onto algebraic closure operators: pre-training closes over a corpus, fine-tuning applies an additional nucleus, in-context learning temporarily extends the generator set, and the trained model is the fixed point." ;
  schema:datePublished "2026-04-04" ;
  schema:dateModified "2026-04-04" ;
  emsenn:Sources "Vaswani et al., 'Attention Is All You Need,' NeurIPS 2017" , "Hu et al., 'LoRA: Low-Rank Adaptation of Large Language Models,' ICLR 2022 (arXiv 2021)" , "Ouyang et al., 'Training Language Models to Follow Instructions with Human Feedback,' NeurIPS 2022" , "Rafailov et al., 'Direct Preference Optimization,' NeurIPS 2023" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/tech/domains/computing/texts/model-training-as-algebraic-closure/> .

