&lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/extends/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/extends/> ;
  schema:name "Extends" ;
  schema:description "Extension is a relation A extends B — written B ≤ A or B ↪ A — asserting that B embeds in A as a sub-structure: there exists a monomorphism (structure-preserving injection) ι: B → A that commutes with all operations. The defining structure: A contains all of B (via ι) and may contain more. Extension is not mere inclusion of sets — it requires structure preservation: the embedding ι must respect the algebraic, logical, or categorical structure at stake. Extension is a preorder: reflexive (B ≤ B via the identity), transitive (B ≤ A and A ≤ C implies B ≤ C via composition), and generates a partial order on the equivalence classes of mutual extensions." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/tech/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/terms/extension/> ;
  rdfs:seeAlso "Refines, Satisfies, FieldExtension, TheoryExtension, KanExtension, LiskovSubstitution" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/extends/> .

