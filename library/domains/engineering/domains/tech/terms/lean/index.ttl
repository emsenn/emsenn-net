&lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/lean/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/lean/> ;
  schema:name "Lean" ;
  schema:description "Lean is a formal proof assistant based on the Calculus of Inductive Constructions. Three proof modalities (term-mode, tactic-mode, inductive-mode) all produce kernel-verifiable proof terms via structurally distinct paths. The kernel is small and is the only trusted component; all other components produce candidate terms for the kernel to check." ;
  schema:datePublished "2026-03-22" ;
  schema:dateModified "2026-03-22" ;
  schema:about &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/lean/> ;
  rdfs:seeAlso "Assertion, Machine, System" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/lean/> .

