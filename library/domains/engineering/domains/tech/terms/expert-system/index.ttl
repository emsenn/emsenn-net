  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/tech/terms/expert-system/> ;
  schema:name "Expert System" ;
  schema:description "An ExpertSystem is any live system whose architecture combines a DataStore (knowledge base) with an Engine (inference engine): the DataStore holds structured content; the Engine applies operations to that content to produce output." ;
  schema:datePublished "2026-03-18" ;
  schema:dateModified "2026-03-18" ;
