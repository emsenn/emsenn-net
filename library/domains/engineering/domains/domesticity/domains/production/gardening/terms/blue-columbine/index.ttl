  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/blue-columbine/> ;
  schema:name "Blue Columbine" ;
  schema:description "Perennial cultivar of Aquilegia caerulea, hardy zones 3-9. Distinctive spurred flowers with blue sepals, white petals (color range: solid blue, purple, bicolored variants exist). Blooms year two from seed; self-seeds prolifically. Early-season nectar plant for bumblebees and hummingbirds (May-June). Prefers cool climates, well-drained soil, part shade in hot climates. Sensitive to heat and humidity." ;
  schema:datePublished "2026-04-02" ;
