&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/annual/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/annual/> ;
  schema:name "annual" ;
  schema:description "A plant that completes its entire life cycle — germination, growth, flowering, seed production, and death — in a single growing season. Most common garden vegetables (tomatoes, basil, lettuce, beans) are annuals." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
