  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/molokhia/> ;
  schema:name "Molokhia cultivation" ;
  schema:description "Growing protocol for *Corchorus olitorius*, tropical heat-loving annual producing mucilaginous leaves central to Palestinian, Egyptian, Lebanese, and Indian cuisines. Seeds carry cultural lineage through generations and diaspora. Requires warm temperatures (25–35°C); unsuitable for temperate climates except as warm-season annual or greenhouse crop. 50–80 days to harvestable leaf production." ;
  schema:datePublished "2026-04-02" ;
