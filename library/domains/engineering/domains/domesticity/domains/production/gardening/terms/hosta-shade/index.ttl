  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/hosta-shade/> ;
  schema:name "Hosta Shade" ;
  schema:description "Perennial cultivar genus of Hosta, hardy zones 3-9. The premier shade plant. Broad variegated or solid-colored leaves in basal mounds (0.3-1.5 m wide depending on cultivar). Part to full shade (2-4+ hours dappled sun). Hardy, long-lived (30-50+ years), extremely low-maintenance. Major threats: slugs, deer. Variegated margins ('Gold Standard,' 'Patriot') or centers ('Moonlight,' 'October Light'). Large types ('Sum and Substance,' 'Big Daddy'); miniatures ('Little Treasure'); slow-growing, space-efficient perennials." ;
  schema:datePublished "2026-04-02" ;
