  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/french-marigold/> ;
  schema:name "French Marigold" ;
  schema:description "Annual cultivar of Tagetes patula, 45-70 days to first flower. Compact 0.3-0.8 m plants. Roots produce terthienyls that suppress root-knot nematodes; volatile limonene deters whitefly. Interplant throughout vegetable gardens 4-5 feet from susceptible crops. Full sun, well-drained soil. Low fertility preference." ;
  schema:datePublished "2026-04-02" ;
