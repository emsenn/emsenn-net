  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/eggplant/> ;
  schema:name "Eggplant" ;
  schema:description "Warm-season annual fruiting crop (Solanum melongena, 70–90 days to first fruit). Large-fruited Occidental types produce purple, white, or striped berries (200–500 g). Heat-demanding; slow to establish from seed (requires 12–14 week indoor growing period). Prefers warm soil (25–30°C optimal). Self-compatible but benefits from insect pollination. Requires consistent moisture and fertile soil. White Garden variety (white-fruited, 3-inch heirloom) demonstrates diversity." ;
  schema:datePublished "2026-04-02" ;
