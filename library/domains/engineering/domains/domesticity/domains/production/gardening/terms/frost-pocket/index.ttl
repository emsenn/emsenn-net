&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/frost-pocket/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/frost-pocket/> ;
  schema:name "frost pocket" ;
  schema:description "A low-lying area where cold air collects on still nights. Because cold air is denser than warm air, it flows downhill and pools in depressions, valley floors, and areas blocked by walls or dense hedges. Frost pockets experience frost earlier in autumn and later in spring than surrounding higher ground, shortening the effective growing season for that spot." ;
  schema:datePublished "2026-03-07" ;
  schema:dateModified "2026-03-07" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/frost-pocket/> .

