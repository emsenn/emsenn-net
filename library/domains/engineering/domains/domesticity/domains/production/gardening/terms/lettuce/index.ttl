&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/lettuce/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/lettuce/> ;
  schema:name "Lettuce cultivation" ;
  schema:description "Growing protocol for *Lactuca sativa*, optimized for cool-season production and succession sowing. Seed germinates at 10–20°C but exhibits thermoinhibition above 25°C. Succession-sow every 2–3 weeks for continuous harvest; cut-and-come-again harvesting extends production. 25–55 days to maturity depending on type and temperature." ;
  schema:datePublished "2026-04-02" ;
