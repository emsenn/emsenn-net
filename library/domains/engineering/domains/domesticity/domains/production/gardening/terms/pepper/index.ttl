  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/pepper/> ;
  schema:name "Pepper" ;
  schema:description "Warm-season annual fruiting crop (Capsicum annuum, 60–90 days to first fruit). Includes sweet bell peppers and chili peppers (wide Scoville range 0–200,000+ SHU). Requires warm soil and air (germination \u003e70°F optimal). Slow to establish; start indoors 8–10 weeks before last frost. Heat-demanding; production slows below 20°C. Self-compatible but benefits from insect pollination. Moderate water and fertilizer needs." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/capsicum-annuum/> , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/capsicum-annuum/> ;
