  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/morning-glory/> ;
  schema:name "Morning Glory" ;
  schema:description "Annual vine cultivar of Ipomoea purpurea, 60-75 days to first flower. Vigorous twining vine 2-3.5 m. Blue, purple, pink, or bicolored ephemeral flowers open at dawn, close by mid-morning. Full sun, moderate soil. Poor soil yields more flowers (nitrogen limitation). Prolific seeder; allow plants to complete seed maturation for self-sowing next season or deadhead to extend flowering." ;
  schema:datePublished "2026-04-02" ;
