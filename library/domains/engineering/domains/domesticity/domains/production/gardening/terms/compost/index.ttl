&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/compost/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/compost/> ;
  schema:name "compost" ;
  schema:description "Decomposed organic material (plant scraps, leaves, food waste) used as a soil amendment. Compost improves soil structure, adds nutrients, increases water-holding capacity, and supports beneficial soil organisms. It is produced by piling organic material and allowing microorganisms to break it down over weeks to months. Finished compost is dark, crumbly, and earthy-smelling." ;
  schema:datePublished "2026-03-07" ;
