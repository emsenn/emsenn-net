&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> ;
  schema:name "Potato" ;
  schema:description "Cool-season perennial (cultivated as annual, 70–120 days to harvest). Produces underground stem tubers (swollen stolons) via vegetative propagation from seed-tubers. Purple and blue-fleshed cultivars (Purple Majesty, Purple Viking) accumulate high anthocyanins. Prefers cool soils (15–20°C); poor performance in heat. Direct-plant seed-tubers in spring; hill soil around emerging plants to prevent sunlight-exposed tubers. Moderate water and fertility needs. Cool-season crop distinct from warm-season Solanaceae." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:about &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> , &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> , &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> ;
