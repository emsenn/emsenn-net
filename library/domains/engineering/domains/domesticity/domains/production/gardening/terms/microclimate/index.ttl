&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/microclimate/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/microclimate/> ;
  schema:name "microclimate" ;
  schema:description "The climate conditions of a small, specific area that differ from the surrounding region. In gardening, microclimates are created by factors such as proximity to buildings, pavement, bodies of water, elevation changes, and wind exposure. A south-facing wall, for example, creates a warmer microclimate than an open north-facing slope at the same location." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/microclimate/> .

