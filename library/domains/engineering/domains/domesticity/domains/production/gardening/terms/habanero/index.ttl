&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/habanero/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/habanero/> ;
  schema:name "Habanero" ;
  schema:description "Perennial shrubby pepper (Capsicum chinense, 90–150+ days to first fruit) producing small lantern-shaped intensely pungent fruit (100,000–350,000 SHU). Requires warm climate (zones 9–11 for reliable fruiting); slow to establish; benefits from starting very early (12 weeks before last frost). Self-incompatible flowering in some cultivars; grow multiple plants for best yields. Prune to shrub form for multi-season production in warm climates." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/capsicum-chinense/> ;
