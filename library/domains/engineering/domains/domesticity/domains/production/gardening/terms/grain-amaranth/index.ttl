  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/grain-amaranth/> ;
  schema:name "Grain Amaranth" ;
  schema:description "Annual cultivar of Amaranthus cruentus, 75-150 days to grain maturity depending on cultivar. Pendant or erect tassels of dense flowers. Gluten-free pseudocereal grain with 16-17% protein and superior amino acid balance (high lysine). Also produces edible leaves. Deep-red flower bracts yield natural dye. Golden Giant (most productive, 90-110 days); Aurelia's Verde (rapid, 75-90 days); traditional Hopi Red (120-150 days, deep dye color)." ;
  schema:datePublished "2026-04-02" ;
