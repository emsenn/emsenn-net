&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/tuber/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/tuber/> ;
  schema:name "tuber" ;
  schema:description "A thickened portion of an underground stem that stores energy for the plant. Each \"eye\" (growth bud) on a tuber can produce a new shoot. In gardening, tubers are planted directly in the ground at the appropriate depth and spacing. The most common garden tuber is the potato." ;
  schema:datePublished "2026-03-07" ;
