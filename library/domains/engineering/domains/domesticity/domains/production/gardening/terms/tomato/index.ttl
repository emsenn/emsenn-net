  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/tomato/> ;
  schema:name "Tomato" ;
  schema:description "Annual warm-season fruiting crop (Solanum lycopersicum, 60–90 days to first fruit). Indeterminate varieties produce continuously; determinate varieties produce in concentrated burst. Requires staking (indeterminate) or support. Deep transplant burial for adventitious root development. Buzz-pollinated by bumblebees (greenhouse production needs mechanical vibration). Wide cultivar diversity including cherry, paste, beefsteak, and heirloom types." ;
  schema:datePublished "2026-04-02" ;
