  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/purple-orach/> ;
  schema:name "Purple orach cultivation" ;
  schema:description "Growing protocol for *Atriplex hortensis*, heat- and drought-tolerant annual producing dramatic deep-purple foliage. Tall plant (4–6 feet); grown for ornamental-edible dual-use. Rapid development (40–50 days to mature), early bolting but short-season crop allows succession plantings. Excellent summer alternative to heat-sensitive spinach and lettuce." ;
  schema:datePublished "2026-04-02" ;
