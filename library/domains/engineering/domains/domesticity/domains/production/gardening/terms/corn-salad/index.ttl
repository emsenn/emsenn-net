  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/corn-salad/> ;
  schema:name "Corn salad cultivation" ;
  schema:description "Growing protocol for *Valerianella locusta* (mâche, lamb's lettuce), exceptionally frost-hardy winter salad green. Seed exhibits thermodormancy above 68°F; sow only in fall (late August through September). Hardy to 5–10°F; matures in 60–90 days under cool conditions. Winter through early spring harvest in temperate climates." ;
  schema:datePublished "2026-04-02" ;
