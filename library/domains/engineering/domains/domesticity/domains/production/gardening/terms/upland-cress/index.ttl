  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/upland-cress/> ;
  schema:name "Upland cress cultivation" ;
  schema:description "Growing protocol for *Barbarea verna* (land cress), cool-season biennial producing watercress-like peppery leaves without requiring flowing water. Seed exhibits thermodormancy below 70°F only; sow in fall or early spring. Hardy to -20°F; matures in 50–60 days under cool conditions. Perennial in zones 5–9." ;
  schema:datePublished "2026-04-02" ;
