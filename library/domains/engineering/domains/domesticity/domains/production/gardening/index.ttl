&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/> ;
  schema:name "Gardening" ;
  schema:description "Gardening is the practice of cultivating plants within a managed space for food, medicine, beauty, or ecological function. Unlike industrial agriculture, gardening operates at a scale where the cultivator maintains direct relationship with individual plants and soil conditions. It is simultaneously a technical discipline (requiring knowledge of botany, soil science, and local climate), a domestic practice (embedded in household labor and seasonal rhythm), and a cultural practice (carrying seed-saving traditions, indigenous polycultures, and community knowledge across generations)." ;
  schema:datePublished "2026-04-02" ;
