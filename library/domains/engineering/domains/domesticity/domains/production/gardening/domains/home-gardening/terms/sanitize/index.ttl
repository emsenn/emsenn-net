&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/terms/sanitize/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/terms/sanitize/> ;
  schema:name "sanitize" ;
  schema:description "To sanitize is to reduce microbes on tools, jars, trays, or other equipment to a level considered safe for [food-safe](./food-safe.md) use. In [home gardening](../_index.md) for [sprouts](./sprout.md) and [microgreens](../topics/microgreens/index.md), sanitizing is a routine step before each growing cycle because the warm, moist conditions that support germination also support bacterial growth." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/terms/sanitize/> .

