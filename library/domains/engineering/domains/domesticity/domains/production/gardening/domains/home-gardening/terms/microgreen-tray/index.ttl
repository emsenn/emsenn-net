  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/terms/microgreen-tray/> ;
  schema:name "microgreen tray" ;
  schema:description "A microgreen tray is a shallow container used to grow [microgreens](../topics/microgreens/index.md) in a thin layer of growing medium. The tray provides the structure that holds the medium, retains moisture, and supports the plants during their short growth cycle from seed to harvest." ;
