  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/fernleaf-yarrow/> ;
  schema:name "Fernleaf Yarrow" ;
  schema:description "Perennial cultivar of Achillea filipendulina, hardy zones 3-9. Finely feathery foliage, golden-yellow flat-topped flower clusters (0.8-1.5 m tall). Cut flowers last 2-3 weeks fresh; dry beautifully for winter arrangements. Dye plant: quercetin produces bright yellow-gold. Attracts parasitoid wasps and tachinid flies—beneficial insect reservoir. Drought-tolerant, long-lived, low-maintenance. 'Gold Plate' (largest flowers, 1.2-1.5 m); 'Cloth of Gold' (reliable golden-yellow, 1 m)." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:about &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/fernleaf-yarrow/> ;
