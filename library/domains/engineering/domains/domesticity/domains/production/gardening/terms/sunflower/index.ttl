  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/sunflower/> ;
  schema:name "Sunflower" ;
  schema:description "Annual cultivar of Helianthus annuus, 60-110 days to maturity. Tall cultivars (2-3.5 m) require staking; dwarf ornamental cultivars (0.6-1 m) do not. Full sun, well-drained soil, consistent moisture. Prolific pollinator attractor. Large-headed giants mature in 90-110 days; rapid confection types in 65-90 days." ;
  schema:datePublished "2026-04-02" ;
