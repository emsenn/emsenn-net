&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/domains/microgreens/terms/tray/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/domains/microgreens/terms/tray/> ;
  schema:name "tray" ;
  schema:description "A tray is a shallow container used for growing [microgreens](./microgreen.md). In the context of microgreen cultivation, the tray holds the growing medium (typically a thin layer of soil, coconut coir, or hemp mat), retains moisture, and provides the surface area across which seeds are spread for even germination." ;
  schema:datePublished "2025-12-31" ;
