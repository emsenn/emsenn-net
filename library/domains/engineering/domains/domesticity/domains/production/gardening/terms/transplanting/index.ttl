&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/transplanting/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/transplanting/> ;
  schema:name "transplanting" ;
  schema:description "The act of moving a plant from one growing location to another, typically from an indoor container to an outdoor garden bed. Transplanting is stressful for plants because roots are disturbed and environmental conditions change abruptly. Hardening off (gradually exposing seedlings to outdoor conditions over a week) reduces transplant shock." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/transplanting/> .

