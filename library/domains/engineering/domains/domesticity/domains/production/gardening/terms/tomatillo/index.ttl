&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/tomatillo/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/tomatillo/> ;
  schema:name "Tomatillo" ;
  schema:description "Warm-season annual fruiting crop (Physalis philadelphica, 60–75 days to first fruit). Produces small (2–4 cm) berries enclosed in papery calyx husk. Essential characteristic: self-incompatible (requires 2+ plants for cross-pollination). Single isolated plants produce empty husks. Rio Grande Verde (green) and purple cultivars common. Moderate water and fertility. Prolific and disease-resistant relative to tomatoes and peppers. Ideal for salsa verde and fresh salsas." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
