&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/photosynthesis/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/photosynthesis/> ;
  schema:name "photosynthesis" ;
  schema:description "The process by which plants convert light energy, water, and carbon dioxide into sugars and oxygen. It occurs primarily in the leaves and is the foundation of all plant growth. Without adequate light for photosynthesis, a plant cannot produce enough energy to grow, flower, or fruit." ;
  schema:datePublished "2026-03-06" ;
