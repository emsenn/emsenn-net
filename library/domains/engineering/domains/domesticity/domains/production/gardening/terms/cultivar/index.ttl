&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/cultivar/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/cultivar/> ;
  schema:name "cultivar" ;
  schema:description "A specific version of a plant species that has been selected or bred for particular traits, such as fruit size, color, disease resistance, or climate tolerance. Short for \"cultivated variety.\" Two cultivars of the same species may have different temperature tolerances, days to maturity, or disease resistance." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
