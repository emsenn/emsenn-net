&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/direct-sowing/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/direct-sowing/> ;
  schema:name "direct sowing" ;
  schema:description "Planting seeds directly into the soil where the plant will grow to maturity, without starting them indoors or in a separate container first. Direct sowing is the simplest propagation method and works well when the plant tolerates local conditions at planting time and the growing season is long enough for it to reach maturity from an outdoor start." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/direct-sowing/> .

