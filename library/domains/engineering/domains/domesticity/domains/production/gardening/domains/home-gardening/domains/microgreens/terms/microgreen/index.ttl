&lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/domains/microgreens/terms/microgreen/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/domains/home-gardening/domains/microgreens/terms/microgreen/> ;
  schema:name "microgreen" ;
  schema:description "A microgreen is a young edible plant harvested after the [cotyledons](../../../terms/cotyledon.md) have expanded and just as the first true leaves begin to appear, typically seven to twenty-one days after planting. Microgreens are grown in shallow [trays](./tray.md) with a thin layer of growing medium and are cut at the stem just above the soil line." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
