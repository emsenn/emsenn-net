  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/sweet-grass/> ;
  schema:name "Sweet Grass" ;
  schema:description "Perennial grass cultivar of Hierochloe odorata, hardy zones 3-8. Rhizomatous, spreading mat-forming habit. Produces sweet vanilla fragrance (coumarin). Thrives in consistently moist, mineral-rich soil. Propagate by rhizome division (spring or fall). Indigenous sacred medicine of Anishinaabe peoples (Ojibwe, Odawa, Potawatomi); one of Four Sacred Medicines. Dried bundles used for smudging. Three-strand braids represent mind, body, spirit." ;
  schema:datePublished "2026-04-02" ;
