  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/piri-piri/> ;
  schema:name "Piri piri" ;
  schema:description "Perennial shrubby pepper (Capsicum frutescens, 90–120+ days to first fruit) producing small upright intensely pungent fruit (50,000–175,000 SHU). Native to tropical Americas, dispersed to Africa via Portuguese colonial networks; name from Bantu meaning \"pepper-pepper.\" Requires warm climate (zones 9–11); grows as ornamental in cooler zones. Self-compatible; single plant produces fruit. Compact, heavily-branched growth; suitable for containers and small spaces. Prolific and decorative." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
