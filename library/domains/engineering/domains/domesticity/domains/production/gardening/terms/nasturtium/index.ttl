  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/nasturtium/> ;
  schema:name "Nasturtium" ;
  schema:description "Annual cultivar of Tropaeolum majus, 55-70 days to first flower. Trailing vines 1.5-3 m or compact bush types 0.3-0.5 m. Entirely edible—peppery flowers, leaves, unripe seed pods (\"poor man's capers\"). Premier aphid trap crop; plant 4-5 feet from vulnerable crops (tomato, squash, beans). Full sun, moderate soil, consistent moisture. Cold-sensitive annual." ;
  schema:datePublished "2026-04-02" ;
