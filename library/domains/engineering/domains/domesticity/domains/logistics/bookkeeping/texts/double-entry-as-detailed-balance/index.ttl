  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/logistics/bookkeeping/texts/double-entry-as-detailed-balance/> ;
  schema:name "Double-Entry Bookkeeping as Detailed Balance" ;
  schema:description "The trial balance in double-entry bookkeeping instantiates the detailed balance condition from Markov chain theory. Conservation of quantity across accounts is the same conservation law that governs equilibrium in stochastic systems." ;
  schema:datePublished "2026-04-04" ;
  schema:dateModified "2026-04-04" ;
