  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/design/domains/typography/terms/body/> ;
  schema:name "body text" ;
  schema:description "Body text is the primary reading text of a document, the continuous prose that carries its main content. It stands in contrast to [headings](./heading.md), [captions](./caption.md), display type, and other typographic elements that serve structural or supplementary roles." ;
