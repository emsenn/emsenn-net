&lt;https://emsenn.net/library/domains/engineering/domains/design/domains/typography/terms/caption/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/design/domains/typography/terms/caption/> ;
  schema:name "caption" ;
  schema:description "A caption is text that accompanies an image, figure, table, or other visual element to provide context, explanation, or attribution. Captions sit at the boundary between the visual content they describe and the [body text](./body.md) that surrounds it." ;
  schema:datePublished "2026-03-03" ;
