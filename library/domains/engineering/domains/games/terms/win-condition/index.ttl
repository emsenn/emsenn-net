&lt;https://emsenn.net/library/domains/engineering/domains/games/terms/win-condition/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/win-condition/> ;
  schema:name "win condition" ;
  schema:description "A win condition is the criterion that decides when a game ends and who (if anyone) has won. Checkmate in chess. The most points when the deck runs out. Survival when all other players are eliminated. The win condition gives direction to every decision a [player](./player.md) makes — it is what makes choices *strategic* rather than arbitrary." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/games/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/win-condition/> .

