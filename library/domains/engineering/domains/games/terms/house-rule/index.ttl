&lt;https://emsenn.net/library/domains/engineering/domains/games/terms/house-rule/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/house-rule/> ;
  schema:name "house rule" ;
  schema:description "A house rule is a change to a game's published or traditional [rules](./rules.md) adopted by a particular group of [players](./player.md). House rules are local: they apply at this table, in this group, for these sessions. They don't change the game in general; they change the game *as played here*." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/house-rule/> .

