&lt;https://emsenn.net/library/domains/engineering/domains/games/terms/play/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/play/> ;
  schema:name "play" ;
  schema:description "Play is voluntary, intrinsically motivated activity pursued for its own sake. It is broader than games: a child stacking blocks is playing without rules, objectives, or competition. Play becomes a game when it acquires structure — [rules](./rules.md), objectives, constraints — but the underlying quality of voluntary engagement persists." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/games/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/play/> .

