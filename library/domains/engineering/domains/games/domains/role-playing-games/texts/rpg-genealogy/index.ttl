  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/texts/rpg-genealogy/> ;
  schema:name "Genealogy of Role-Playing Games" ;
  schema:description "Role-playing games are not descended from a single ancestor. They combine elements from at least four distinct traditions, none of which alone produces what we recognize as an RPG." ;
