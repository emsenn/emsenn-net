  schema:name "initiative" ;
  schema:description "Initiative is a rule for sequencing actions during conflict in a [tabletop role-playing game](../_index.md). When multiple [characters](../../../terms/character.md) act simultaneously — typically in combat — initiative determines who goes first." ;
  schema:datePublished "2026-01-01" ;
