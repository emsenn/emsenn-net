&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/faction/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/faction/> ;
  schema:name "faction" ;
  schema:description "A faction is an organized group in a [tabletop role-playing game](../index.md) world with its own goals, resources, loyalties, and pressures. Factions may be formal institutions, criminal networks, cults, mercenary companies, families, religious orders, or loose coalitions." ;
