&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/scenario/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/scenario/> ;
  schema:name "scenario" ;
  schema:description "A scenario is the prepared package of situations, locations, non-player characters, pressures, and clues that a [tabletop role-playing game](../_index.md) group will engage during play. It is not a script for what the players must do. It is the authored starting state and the actionable parts of the world that the [game master](../../../terms/game-master.md) can bring to the table." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:keywords &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/> , &lt;https://emsenn.net/tags/scenario-design/> , &lt;https://emsenn.net/tags/preparation/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/scenario/> .

