&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/debrief/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/debrief/> ;
  schema:name "debrief" ;
  schema:description "A debrief is the structured conversation that happens after a [tabletop role-playing game](../_index.md) session ends. Its purpose is to help players step out of the fiction, reflect on what happened, share feedback, and identify anything that needs follow-up before the next session." ;
  schema:datePublished "2026-03-09" ;
