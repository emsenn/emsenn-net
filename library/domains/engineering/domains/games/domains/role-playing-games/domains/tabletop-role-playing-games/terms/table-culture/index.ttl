&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/table-culture/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/table-culture/> ;
  schema:name "table culture" ;
  schema:description "Table culture is the set of shared norms, habits, and expectations that govern how players interact during a [tabletop role-playing game](../_index.md). Every group develops its own table culture, whether consciously or not: how much crosstalk is acceptable, whether players use character voices, how phones are handled, who brings snacks, and how disagreements about rules are resolved." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/table-culture/> .

