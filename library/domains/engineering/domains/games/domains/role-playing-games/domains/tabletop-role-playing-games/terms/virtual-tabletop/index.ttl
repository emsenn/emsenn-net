&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/virtual-tabletop/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/virtual-tabletop/> ;
  schema:name "virtual tabletop" ;
  schema:description "A virtual tabletop is a digital platform that reproduces key tabletop play aids online: maps, tokens, dice rollers, character sheets, handouts, and shared visual space. It does not replace the [tabletop role-playing game](../index.md) with a full video game. Instead, it provides virtual analogs of the tools a group would otherwise place on a physical table." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:keywords &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/> , &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/virtual-tabletop/> , &lt;https://emsenn.net/tags/remote-play/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/virtual-tabletop/> .

