  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/campaign-frame/> ;
  schema:name "campaign frame" ;
  schema:description "A campaign frame is the compact premise that gives a [tabletop role-playing game](../index.md) campaign its initial direction. It names what is happening in the world, why the player characters are involved, and what kinds of choices the campaign is built to support." ;
  schema:datePublished "2026-03-09" ;
