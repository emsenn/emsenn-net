&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/modifier/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/domains/tabletop-role-playing-games/terms/modifier/> ;
  schema:name "modifier" ;
  schema:description "A modifier is a numerical bonus or penalty applied to a dice roll in a [tabletop role-playing game](../_index.md). Modifiers represent the influence of a [character's](../../../terms/character.md) abilities, circumstances, equipment, or other factors on the probability of success." ;
