&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/setting/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/setting/> ;
  schema:name "setting" ;
  schema:description "A setting is the fictional world where a [role-playing game](../_index.md) takes place. It encompasses the geography, history, cultures, metaphysics, and tone that define the space in which [characters](./character.md) act. The setting provides the raw material from which the [game master](./game-master.md) constructs situations and the players derive motivation for their characters' choices." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/setting/> .

