&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/system/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/system/> ;
  schema:name "system" ;
  schema:description "A system is the set of rules and mechanics used to resolve actions in a [role-playing game](../index.md). It provides the procedures that determine what happens when a [character](./character.md) attempts something with an uncertain outcome — how to decide whether an attack hits, whether a negotiation succeeds, or whether a character notices a hidden clue." ;
  schema:datePublished "2026-01-01" ;
