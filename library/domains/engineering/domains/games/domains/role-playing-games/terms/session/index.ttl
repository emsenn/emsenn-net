&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/session/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/session/> ;
  schema:name "session" ;
  schema:description "A session is a single continuous period of play in a [role-playing game](../index.md), typically lasting two to five hours. Sessions are the basic unit of scheduling and pacing: groups agree to meet for a session, and the [game master](./game-master.md) structures content to fit within that window." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/session/> .

