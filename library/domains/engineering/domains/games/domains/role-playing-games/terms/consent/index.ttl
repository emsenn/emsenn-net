&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/consent/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/consent/> ;
  schema:name "consent" ;
  schema:description "Consent in [role-playing games](../index.md) is agreement among players about what content is acceptable in play. Unlike many other forms of entertainment, role-playing games are co-created in real time — any participant can introduce themes, scenarios, or situations that others find uncomfortable or harmful. Consent practices address this by making boundaries explicit and revisable." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/consent/> .

