  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/role-playing-games/terms/campaign/> ;
  schema:name "campaign" ;
  schema:description "A campaign is a connected series of [sessions](./session.md) in a [role-playing game](../index.md), linked by continuity of [characters](./character.md), setting, and narrative threads. Campaigns range from a handful of sessions to years of regular play." ;
