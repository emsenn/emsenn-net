&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/hard-hand/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/hard-hand/> ;
  schema:name "hard hand" ;
  schema:description "A hard hand in [blackjack](../index.md) is a hand whose total does not include an ace counted as 11 [@thorp1966]. Either the hand has no ace at all, or any ace it contains must count as 1 to avoid a [bust](./bust.md). A 10-6 is a hard 16. Ace-6-10 is also a hard 17, because the ace can no longer remain 11." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/hard-hand/> .

