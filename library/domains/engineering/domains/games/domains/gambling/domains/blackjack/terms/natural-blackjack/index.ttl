  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/natural-blackjack/> ;
  schema:name "natural blackjack" ;
  schema:description "A natural blackjack in [blackjack](../index.md) is a two-card total of 21 made from an ace and any ten-value card [@shackleford2025blackjackcalculator]. It is structurally distinct from reaching 21 with three or more cards because casino rules usually pay it at a premium rather than at even money." ;
