&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/bust/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/bust/> ;
  schema:name "bust" ;
  schema:description "A bust in [blackjack](../index.md) is a hand total above 21, which causes that hand to lose immediately under the standard rules [@thorp1966]. If the player busts, the dealer does not need to finish drawing. If the dealer busts after the player has stood, all remaining player hands that have not already busted win." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/bust/> .

