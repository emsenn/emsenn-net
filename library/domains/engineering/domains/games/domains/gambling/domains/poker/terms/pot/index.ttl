&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/pot/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/pot/> ;
  schema:name "pot" ;
  schema:description "The pot in [poker](../index.md) is the total amount [wagered](../../../terms/wager.md) by all players during a [hand](./hand.md) [@sklansky1999]. It accumulates through antes, blinds, and bets made across the round's betting streets. The player who wins the hand - either by holding the strongest cards at [showdown](./showdown.md) or by making all other players [fold](./fold.md) - collects the pot." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/pot/> .

