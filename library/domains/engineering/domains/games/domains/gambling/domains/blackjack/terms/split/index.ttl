&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/split/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/split/> ;
  schema:name "split" ;
  schema:description "To split in [blackjack](../index.md) is to divide a starting pair into two separate hands, each matched by an additional wager equal to the original bet [@thorp1966]. If the player is dealt two 8s, for example, they may split them and play each 8 as the base of a new hand." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/split/> .

