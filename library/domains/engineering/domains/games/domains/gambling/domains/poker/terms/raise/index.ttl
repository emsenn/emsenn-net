  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/raise/> ;
  schema:name "raise" ;
  schema:description "To raise in [poker](../index.md) is to increase the current wager [@britannica2026poker]. A raise keeps the player in the [hand](./hand.md) while forcing later players to pay more if they want to continue." ;
  schema:datePublished "2026-03-09" ;
