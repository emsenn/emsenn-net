&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/double-down/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/double-down/> ;
  schema:name "double down" ;
  schema:description "To double down in [blackjack](../index.md) is to double the original [wager](../../../terms/wager.md) in exchange for committing to receive exactly one additional card [@thorp1966]. The action increases both risk and reward: the player invests more precisely when the expected value of one more card is favorable enough to justify the larger stake." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/double-down/> .

