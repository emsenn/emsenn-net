&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/upcard/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/upcard/> ;
  schema:name "upcard" ;
  schema:description "An upcard in [blackjack](../_index.md) is the dealer's face-up card, revealed before the player makes decisions [@thorp1966]. It does not show the dealer's full hand, but it provides the key public information the player uses to estimate the dealer's likely finishing range." ;
  schema:datePublished "2026-03-09" ;
