&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/soft-hand/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/soft-hand/> ;
  schema:name "soft hand" ;
  schema:description "A soft hand in [blackjack](../_index.md) is a hand that contains an ace counted as 11 without causing a [bust](./bust.md) [@thorp1966]. For example, ace-six is a soft 17. If the player takes another card and would otherwise go over 21, the ace can convert from 11 to 1 and the hand becomes hard instead of busting." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/soft-hand/> .

