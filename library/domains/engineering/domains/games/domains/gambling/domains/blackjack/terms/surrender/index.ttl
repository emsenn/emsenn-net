&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/surrender/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/surrender/> ;
  schema:name "surrender" ;
  schema:description "To surrender in [blackjack](../_index.md) is to concede the hand before play is completed and lose only part of the original wager, usually one half [@thorp1966]. Surrender exists because some starting positions are weak enough that cutting the loss is better than continuing." ;
  schema:datePublished "2026-03-09" ;
  schema:dateModified "2026-03-09" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/blackjack/terms/surrender/> .

