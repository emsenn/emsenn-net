&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/fold/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/domains/poker/terms/fold/> ;
  schema:name "fold" ;
  schema:description "To fold in [poker](../index.md) is to abandon the current [hand](./hand.md) and give up any claim to the [pot](./pot.md) [@britannica2026poker]. Folding ends the player's participation in that hand immediately." ;
  schema:datePublished "2026-03-09" ;
