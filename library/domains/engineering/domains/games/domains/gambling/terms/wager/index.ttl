&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/terms/wager/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/terms/wager/> ;
  schema:name "wager" ;
  schema:description "A wager is a stake placed on an uncertain outcome in [gambling](../_index.md). The bettor risks something of value — typically money — against the possibility of receiving a larger return if their prediction proves correct. The terms of the wager specify what is staked, what outcomes qualify as a win, and what the payout will be, usually expressed as [odds](./odds.md)." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/terms/wager/> .

