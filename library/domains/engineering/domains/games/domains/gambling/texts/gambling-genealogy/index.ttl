  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/gambling/texts/gambling-genealogy/> ;
  schema:name "Genealogy of Gambling" ;
  schema:description "Gambling does not descend from a single ancestor practice. It emerged independently across multiple traditions wherever three conditions converged: a mechanism for generating uncertain outcomes, a social practice of wagering, and a context in which the wager carried real consequences." ;
