&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/discard-pile/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/discard-pile/> ;
  schema:name "discard pile" ;
  schema:description "The discard pile is the stack of cards removed from active [hand](./hand.md) use during a [card game](../index.md), usually placed face up but sometimes face down depending on the game's rules. Cards reach the discard pile through player choices (playing or voluntarily discarding) or through game events (cards that have resolved their effect)." ;
  schema:datePublished "2026-03-01" ;
  schema:dateModified "2026-03-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/discard-pile/> .

