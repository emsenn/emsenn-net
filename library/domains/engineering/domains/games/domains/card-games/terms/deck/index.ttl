&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/deck/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/deck/> ;
  schema:name "deck" ;
  schema:description "A deck is the bounded set of cards used as the core material of play in a [card game](../_index.md). A deck can be standardized — the 52-card French-suited deck (four [suits](./suit.md), thirteen [ranks](./rank.md) each) is the most widely used — or custom to a specific game, as in trading card games and many modern board-adjacent card games." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/deck/> .

