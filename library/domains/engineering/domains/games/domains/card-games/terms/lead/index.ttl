&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/lead/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/lead/> ;
  schema:name "lead" ;
  schema:description "The lead is the first card played that opens a comparative unit, commonly a [trick](./trick.md), in a [card game](../index.md). The player who leads sets the [suit](./suit.md) or category that subsequent players must [follow](./follow-suit.md), establishing the frame within which the trick is contested." ;
  schema:datePublished "2026-03-01" ;
  schema:dateModified "2026-03-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/lead/> .

