&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/wild-card/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/wild-card/> ;
  schema:name "wild card" ;
  schema:description "In [card games](../_index.md), a wild card is a card that can substitute for other identities under specified conditions. The holder of a wild card declares what [rank](./rank.md) and [suit](./suit.md) it represents, allowing it to complete combinations that would otherwise be impossible given the cards actually dealt." ;
  schema:datePublished "2026-03-01" ;
  schema:dateModified "2026-03-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/wild-card/> .

