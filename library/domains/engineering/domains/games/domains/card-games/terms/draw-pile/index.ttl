&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/draw-pile/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/draw-pile/> ;
  schema:name "draw pile" ;
  schema:description "The draw pile is the face-down stack from which [players](../../../../terms/player.md) take new cards during setup or play in a [card game](../index.md). After the [deck](./deck.md) is [shuffled](./shuffle.md) and [hands](./hand.md) are dealt, the remaining cards typically form the draw pile — a reservoir of hidden information that feeds new cards into the game." ;
  schema:datePublished "2026-03-01" ;
  schema:dateModified "2026-03-01" ;
  schema:identifier &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/terms/draw-pile/> .

