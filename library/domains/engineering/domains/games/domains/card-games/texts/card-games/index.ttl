  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/card-games/texts/card-games/> ;
  schema:name "Card Games Specification" ;
  schema:description "This specification defines the structural features that distinguish card games from other game types. It provides constitutive criteria — the features whose presence or absence decides whether a game *is* a card game — and descriptive criteria — features that are common but not definitional." ;
