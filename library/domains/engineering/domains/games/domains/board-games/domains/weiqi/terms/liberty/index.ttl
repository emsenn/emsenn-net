&lt;https://emsenn.net/library/domains/engineering/domains/games/domains/board-games/domains/weiqi/terms/liberty/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/engineering/domains/games/domains/board-games/domains/weiqi/terms/liberty/> ;
  schema:name "liberty" ;
  schema:description "A liberty in [weiqi](../_index.md) is an empty intersection directly adjacent to a stone or connected group of stones [@nagofed2026thisisgo]. Liberties determine whether a group remains on the board. When the last liberty is removed, the group is subject to [capture](./capture.md)." ;
  schema:datePublished "2026-03-09" ;
