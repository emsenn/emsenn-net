@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ludd:  <https://emsenn.net/ns/domain/ludic#> .
@prefix asr:   <https://emsenn.net/ns/agential-semioverse-repository#> .

ludd: a owl:Ontology ;
    rdfs:label "Ludic ASR Ontology" ;
    rdfs:comment """
        Content types and typed relations for ludic knowledge (games and play)
        within an Agential Semioverse Repository. Validity is mechanical:
        content is valid when its structures, constraints, and boundaries
        are concrete enough to recognize in practice.
    """ .

# --- Classes ---

ludd:Term a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Term" ;
    rdfs:comment "A vocabulary entry naming a game element: mechanic, role, state, structure, or analytical concept." .

ludd:Lesson a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Lesson" ;
    rdfs:comment "A curriculum module teaching game analysis through structured sequence." .

ludd:Specification a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Specification" ;
    rdfs:comment "A formal structural analysis defining a game type by constitutive and descriptive features." .

ludd:Text a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Text" ;
    rdfs:comment "An original game text, design document, or analytical essay." .

ludd:Topic a owl:Class ;
    rdfs:subClassOf asr:Content ;
    rdfs:label "Topic" ;
    rdfs:comment "An organizing node for a game family, tradition, or area of inquiry." .

# --- Object Properties ---

ludd:usesMechanic a owl:ObjectProperty ;
    rdfs:label "uses mechanic" ;
    rdfs:comment "Source analyzes or employs target mechanic." ;
    rdfs:range ludd:Term .

ludd:classifies a owl:ObjectProperty ;
    rdfs:label "classifies" ;
    rdfs:comment "Source defines target as a category." ;
    rdfs:domain ludd:Specification .

ludd:boundaryWith a owl:ObjectProperty ;
    rdfs:label "boundary with" ;
    rdfs:comment "Source shares structural overlap with target." .

ludd:models a owl:ObjectProperty ;
    rdfs:label "models" ;
    rdfs:comment "Source instantiates the game type target defines." ;
    rdfs:domain ludd:Text .

ludd:cites a owl:ObjectProperty ;
    rdfs:label "cites" ;
    rdfs:comment "Source credits or references target." .

ludd:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:comment "Source is the authoritative definition of target." .

ludd:requires a owl:ObjectProperty ;
    rdfs:label "requires" ;
    rdfs:comment "Source requires understanding of target." .

ludd:teaches a owl:ObjectProperty ;
    rdfs:label "teaches" ;
    rdfs:comment "Source develops understanding of target." .
