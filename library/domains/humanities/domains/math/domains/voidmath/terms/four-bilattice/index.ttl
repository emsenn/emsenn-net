  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/four-bilattice/> ;
  schema:name "Four-bilattice" ;
  schema:description "The canonical four-element bilattice FOUR — the smallest non-trivial bilattice, with carrier {t, f, ⊥, ⊤} corresponding to true, false, no evidence, and contradictory. Originally Belnap's four-valued logic; the canonical example of voidmath's bilattice structure." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/four-bilattice/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/four-bilattice/> ;
