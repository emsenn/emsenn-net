  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-valuation/> ;
  schema:name "Predication valuation" ;
  schema:description "A function assigning to each predicate a fiber-algebra element — the structure that records what value is held at every predication cell. The dynamic data of a predication system: what is registered at each (subject, predicate, object) triple." ;
  schema:datePublished "2026-04-28" ;
  schema:dateModified "2026-04-28" ;
