&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity-set/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity-set/> ;
  schema:name "Entity set" ;
  schema:description "The set whose elements are entities — the source of the cell index E × E over which predication fiber algebras are built. Carries no required structure beyond set-hood; specific applications may add finiteness, sortedness, or other refinements." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity-set/> ;
