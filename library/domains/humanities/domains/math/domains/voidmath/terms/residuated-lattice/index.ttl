&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/> ;
  schema:name "Residuated lattice" ;
  schema:description "The underlying value algebra of the framework: a lattice equipped with a commutative monoid product (fusion) and its residual implication, related by the residuation adjunction. The chosen residuated lattice is what gets pair-doubled into the twist product to produce the voidmath bilattice." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/twist-product/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/bilattice/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-fiber-algebra/> ;
  emsenn:Symbol "\\mathbf{L}" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/residuated-lattice/> .

