&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-bound/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-bound/> ;
  schema:name "Settling bound" ;
  schema:description "An ordinal λ that bounds the settling index of a family of predication valuations: settling steps τ range over τ \u003c λ. Typically ω (countable settlings) but may be any fixed ordinal, supporting transfinite settlings while avoiding the size-theoretic issues of indexing by the class of all ordinals." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-bound/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-valuation/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-monotonicity/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/spatiotemporal-knowledge-presheaf/> ;
  emsenn:Symbol "\\lambda" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-bound/> .

