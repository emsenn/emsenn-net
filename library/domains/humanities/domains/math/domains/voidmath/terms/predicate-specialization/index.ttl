&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-specialization/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-specialization/> ;
  schema:name "Predicate specialization" ;
  schema:description "A morphism class in the predicate category, given by a sub-support inclusion dom(q) ↪ dom(p) between predicates. Encodes the relation 'q is a sub-predicate of p': q's cells are a structurally designated subset of p's cells, with q's values inherited from p's on that subset and extended by ⊥ outside. One of the four canonical generators of the predicate category." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-specialization/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-category/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-converse/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-subject-projection/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-object-projection/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-fiber-algebra/> ;
  emsenn:Symbol "f_{\\mathrm{sp}}" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-specialization/> .

