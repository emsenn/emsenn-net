&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-subject-projection/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-subject-projection/> ;
  schema:name "Predicate subject-projection" ;
  schema:description "A morphism class in the predicate category, induced by the diagonal collapse (s, o) ↦ (s, s) on the entity-pair index. Builds a binary predicate q whose value at (s, o) depends only on p's value at (s, s), broadcasting the subject-diagonal content across all object coordinates. One of the four canonical generators of the predicate category." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-subject-projection/> ;
