&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-converse/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-converse/> ;
  schema:name "Predicate converse" ;
  schema:description "A morphism class in the predicate category, induced by the swap (s, o) ↦ (o, s) on the entity-pair index. Encodes the relational converse: the predicate p^c holds at the pair (s, o) exactly where p holds at (o, s). One of the four canonical generators of the predicate category." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-converse/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-category/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-specialization/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-subject-projection/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-object-projection/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-fiber-algebra/> ;
  emsenn:Symbol "f_{\\mathrm{conv}}" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-converse/> .

