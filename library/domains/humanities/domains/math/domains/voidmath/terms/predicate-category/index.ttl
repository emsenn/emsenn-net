&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-category/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate-category/> ;
  schema:name "Predicate category" ;
  schema:description "The small category whose objects are predicates and whose morphisms are generated by exactly four canonical classes — specialization, converse, subject-projection, object-projection — that exhaust the natural maps between predication fiber algebras under entity-set equivariance." ;
  schema:datePublished "2026-04-28" ;
  schema:dateModified "2026-04-28" ;
