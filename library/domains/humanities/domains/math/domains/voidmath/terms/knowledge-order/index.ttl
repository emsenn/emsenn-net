&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/knowledge-order/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/knowledge-order/> ;
  schema:name "Knowledge order" ;
  schema:description "The knowledge axis of a bilattice — the partial order measuring how much evidence has accumulated, regardless of direction. Ranges from $\\bot$ (no information) to $\\top$ (full evidence in both directions). One of the two parallel orders that constitute the bilattice four-corner structure." ;
  schema:datePublished "2026-04-28" ;
  schema:dateModified "2026-04-28" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/knowledge-order/> ;
