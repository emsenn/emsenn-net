  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-cell/> ;
  schema:name "Predication cell" ;
  schema:description "The minimum writable unit of predication: an ordered triple (subject, predicate, object) at which a value can be assigned. The directed triadic structure that relationality's primitive paradox spells out into when fully articulated." ;
  schema:datePublished "2026-04-28" ;
  schema:dateModified "2026-04-28" ;
