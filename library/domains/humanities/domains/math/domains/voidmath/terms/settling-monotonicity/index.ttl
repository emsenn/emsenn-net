&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-monotonicity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-monotonicity/> ;
  schema:name "Settling monotonicity" ;
  schema:description "The condition that a settle-indexed family of predication valuations grows monotonically in the knowledge order. Values may shift in truth direction but never lose evidence: knowledge accumulates, conflicts surface as both-affirmed-and-denied rather than overwriting each other. The formal structure of irreversible evidence-gathering." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/settling-monotonicity/> ;
