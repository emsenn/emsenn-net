  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/pre-bilattice/> ;
  schema:name "Pre-bilattice" ;
  schema:description "An algebra carrying two parallel lattice structures on a common carrier — one for the truth order, one for the knowledge order — without yet the negation that makes a bilattice. The structural skeleton on which the voidmath bilattice is built." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
