  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predication-fiber-algebra/> ;
  schema:name "Predication fiber algebra" ;
  schema:description "The algebra of values held at the cells of a single predicate — the pointwise twist product of a residuated lattice over the entity-pair index. Bilattice-residuated, with two parallel orders (knowledge and truth) and the operations that lift from the underlying lattice." ;
  schema:datePublished "2026-04-28" ;
