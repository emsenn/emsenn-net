&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/predicate/> ;
  schema:name "Predicate" ;
  schema:description "An element of the predicate set — what occupies the second coordinate of a predication cell. A predicate is the directional element of a relating: it holds of a subject in relation to an object, and asserting different predicates of the same entity pair is asserting different relations." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
