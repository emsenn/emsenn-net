&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/closure-operator/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/closure-operator/> ;
  schema:name "Closure operator" ;
  schema:description "A family of monotone, inflationary, idempotent, and naturally-coherent maps on the predication fiber algebras — one per predicate — implementing consequence-closure under inference rules. The operator-theoretic engine of settling: each settling step takes a valuation to its closure." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/closure-operator/> ;
