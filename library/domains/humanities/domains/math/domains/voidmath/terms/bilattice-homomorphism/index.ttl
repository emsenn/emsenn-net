  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/bilattice-homomorphism/> ;
  schema:name "Bilattice homomorphism" ;
  schema:description "A function between bilattices preserving all four lattice operations and negation (and conflation, when present). The structure-preserving morphism class for bilattices; the natural bottom-preserving such homomorphisms between predication fiber algebras are exactly the maps induced by the four predicate-category generators." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
