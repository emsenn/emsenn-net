&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/evidence/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/evidence/> ;
  schema:name "Evidence" ;
  schema:description "The role borne by the two components of a twist-product value: positive evidence (first coordinate) tracks information for an assertion; negative evidence (second coordinate) tracks information against. The two evidence kinds behave dually under the bilattice's two parallel orders." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/evidence/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/evidence/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/evidence/> ;
