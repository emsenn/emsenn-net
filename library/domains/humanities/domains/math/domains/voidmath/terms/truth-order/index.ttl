&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/truth-order/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/truth-order/> ;
  schema:name "Truth order" ;
  schema:description "The truth axis of a bilattice — the partial order measuring direction of evidence (affirming vs denying). Ranges from $\\mathbf{f}$ (false) to $\\mathbf{t}$ (true). One of the two parallel orders that constitute the bilattice four-corner structure, independent of the knowledge order." ;
  schema:datePublished "2026-04-28" ;
  schema:dateModified "2026-04-28" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/truth-order/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/knowledge-order/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/bilattice/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/twist-product/> ;
  emsenn:Symbol "\\leq_t" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/truth-order/> .

