&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity/> ;
  schema:name "Entity" ;
  schema:description "An element of an entity set — the kind of thing predicates discuss. An entity occupies the subject or object position of a predication cell; it is the relatum-side of relating, the underlying individual that predication makes claims about." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity/> ;
