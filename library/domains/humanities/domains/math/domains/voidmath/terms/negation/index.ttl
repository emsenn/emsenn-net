&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/negation/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/negation/> ;
  schema:name "Negation" ;
  schema:description "The unary involution on a bilattice that reverses the truth axis while preserving the knowledge axis. Antitone in truth, monotone in knowledge, and self-inverse. On twist products, negation is the swap of evidence components — it exchanges positive and negative evidence." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/negation/> ;
