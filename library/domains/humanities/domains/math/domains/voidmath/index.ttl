&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/> ;
  schema:name "Voidmath" ;
  schema:description "The math of relationality — the formal articulation, in standard categorical and bilattice-theoretic vocabulary, of what the relationality framework commits to philosophically. Where relationality cribs its language from philosophy, voidmath cribs from math: predication, fiber algebra, fibration, hyperdoctrine, Priestley duality, sheaf cohomology." ;
  schema:datePublished "2026-04-29" ;
  schema:dateModified "2026-04-29" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/> .

