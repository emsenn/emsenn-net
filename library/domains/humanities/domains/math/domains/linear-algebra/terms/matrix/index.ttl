&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/linear-algebra/terms/matrix/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/linear-algebra/terms/matrix/> ;
  schema:name "Matrix" ;
  schema:description "A matrix is a rectangular grid of numbers (or more generally, elements of a [field](../../algebra/terms/field.md)), arranged in rows and columns. An $m \times n$ matrix has $m$ rows and $n$ columns. You write the entry in the $i$th row and $j$th column as $a_{ij}$. A $2 \times 3$ matrix looks like $\begin{pmatrix} 1 \u0026 2 \u0026 3  4 \u0026 5 \u0026 6 \u001bnd{pmatrix}$ — two rows, three columns, six entries." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/linear-algebra/terms/matrix/> .

