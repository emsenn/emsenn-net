&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/topological-space/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/topological-space/> ;
  schema:name "Topological Space" ;
  schema:description "A topological space is a set equipped with a notion of \"nearness\" — a way of saying which points are close to which, without necessarily measuring exact distances. The idea is to keep the parts of geometry that matter for continuity (can you deform one shape into another without tearing?) while throwing away the parts that don't (how far apart are these two points, exactly?)." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
