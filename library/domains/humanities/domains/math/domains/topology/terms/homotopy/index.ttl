&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/homotopy/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/homotopy/> ;
  schema:name "Homotopy" ;
  schema:description "A homotopy is a continuous deformation of one map into another. Imagine two paths drawn on a surface, both starting at the same point and ending at the same point. If you can slide one path into the other without lifting your pen from the surface — smoothly, continuously, never tearing or jumping — then the two paths are homotopic, and the sliding process itself is a homotopy." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/homotopy/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/texts/homotopies/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/homotopy/> ;
  emsenn:Mathematicalobject &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/topological-space/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/topology/terms/homotopy/> .

