&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/intersection/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/intersection/> ;
  schema:name "Intersection" ;
  schema:description "The intersection of two [sets](./set.md) is the set of everything that belongs to both. If $A = {1, 2, 3, 4}$ and $B = {3, 4, 5, 6}$, then $A cap B = {3, 4}$ — only the [elements](./element.md) that appear in $A$ *and* in $B$. Intersection is the \"and\" operation on sets: $x in A cap B$ means $x in A$ and $x in B$." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/intersection/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/intersection/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/intersection/> .

