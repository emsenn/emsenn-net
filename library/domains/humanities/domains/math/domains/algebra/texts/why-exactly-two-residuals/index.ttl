  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/texts/why-exactly-two-residuals/> ;
  schema:name "Why Exactly Two Residuals?" ;
  schema:description "A product has two argument positions. Each position generates one residual. This is why predicates decompose into extending and restricting — and why there is no third mode." ;
  schema:datePublished "2026-03-31" ;
