&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/complement/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/complement/> ;
  schema:description "An element ¬a such that a ∧ ¬a = ⊥ and a ∨ ¬a = ⊤. Every element of a Boolean algebra has a complement; in a Heyting algebra, not every element does." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
