&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/quotient-group/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/quotient-group/> ;
  schema:name "Quotient Group" ;
  schema:description "A quotient group is what you get when you take a [group](./group.md) and \"collapse\" part of it — treating certain elements as identical. The elements you collapse form a [normal subgroup](./normal-subgroup.md), and the quotient group consists of the [cosets](./coset.md) of that subgroup, with a natural group operation inherited from the original group." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/quotient-group/> .

