  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/abelian-group/> ;
  schema:name "Abelian Group" ;
  schema:description "An abelian group is a [group](./group.md) $(G, cdot, e)$ in which the operation is commutative: $a cdot b = b cdot a$ for all $a, b in G$. The name honors Niels Henrik Abel." ;
  schema:datePublished "2026-03-05" ;
