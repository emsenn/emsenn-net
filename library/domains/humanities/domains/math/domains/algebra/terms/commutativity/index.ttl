&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/commutativity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/commutativity/> ;
  schema:description "The property that order does not matter: a · b = b · a. Distinguishes commutative algebra from non-commutative, and linear logic from the Lambek calculus." ;
