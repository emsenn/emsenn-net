&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/group-homomorphism/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/group-homomorphism/> ;
  schema:name "Group Homomorphism" ;
  schema:description "A group homomorphism is a [function](../../../concepts/function/index.md) $phi : G \to H$ between [groups](./group.md) that preserves the group operation: $phi(a cdot b) = phi(a) cdot phi(b)$ for all $a, b in G$. This extends the notion of [homomorphism](./homomorphism.md) from [monoids](./monoid.md) to groups." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/algebra/terms/group-homomorphism/> .

