&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/mode/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/mode/> ;
  schema:name "Mode" ;
  schema:description "The mode of a dataset is the value that appears most often. In the dataset {3, 5, 5, 7, 8, 5, 9}, the mode is 5 — it occurs three times, more than any other value. A dataset can have one mode (unimodal), two modes (bimodal), several modes (multimodal), or no mode at all (when every value occurs equally often)." ;
  schema:datePublished "2026-01-01" ;
  schema:dateModified "2026-01-01" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/mode/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/mode/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/mode/> .

