&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/probability/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/probability/terms/probability/> ;
  schema:name "Probability" ;
  schema:description "Probability is a way of assigning numbers to uncertain outcomes so that the numbers behave consistently. You flip a coin: you do not know whether it will land heads, but you can say the chance is $1/2$. You roll a die: the chance of any particular face is $1/6$. Probability gives these intuitions a precise mathematical form." ;
  schema:datePublished "2026-01-01" ;
