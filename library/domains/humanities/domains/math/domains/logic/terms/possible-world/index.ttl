&lt;https://emsenn.net/library/domains/humanities/domains/math/domains/logic/terms/possible-world/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/logic/terms/possible-world/> ;
  schema:name "Possible World" ;
  schema:description "A possible world is a complete way things could be — a total state of affairs, specifying the truth value of every relevant proposition. The actual world is one possible world. A world where it rained yesterday in London but not in Paris is another. A world where the laws of physics are the same but Napoleon won at Waterloo is yet another." ;
  schema:datePublished "2025-12-26" ;
