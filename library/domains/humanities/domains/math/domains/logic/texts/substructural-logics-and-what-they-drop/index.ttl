  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/logic/texts/substructural-logics-and-what-they-drop/> ;
  schema:name "Substructural Logics and What They Drop" ;
  schema:description "Classical logic assumes hypotheses can be duplicated, discarded, and reordered. Dropping these assumptions yields linear logic, relevance logic, and the Lambek calculus — each with distinct algebraic semantics." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
