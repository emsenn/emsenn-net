&lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/> ;
  schema:name "Measure" ;
  schema:description "A measure assigns a quantity to a thing. Length measures a line. Temperature measures a gas. Bounce rate measures a session. The thing being measured and the quantity it produces live in different worlds, and the measure is what connects them." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/> , &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/measure/> ;
