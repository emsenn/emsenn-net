  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/math/terms/element-of/> ;
  schema:name "element-of" ;
  schema:description "A positional frontmatter relation declaring that the subject is a named element of the object, identified by an explicit evaluation term [τ](τ) under the evaluation map for the object. The evaluation map MUST be nameable. Coarsest valid answer: entity." ;
