  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/texts/describing-genring-as-nationalist-identity-production/> ;
  schema:name "Genring: The Noble Indian and the Hearty Bavarian as Twin Products of Romantic Nationalist Identity Production" ;
  schema:description "How 19th-century German Romantic nationalism produced identical genre figures from Lakota peoples and Bavarian peasants, and how this dual operation stabilized the Volksgemeinschaft and fed fascism." ;
