  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/texts/municipal-decisions-follow-capital-not-ideology/> ;
  schema:name "Municipal Decisions Follow Capital, Not Ideology" ;
  schema:description "Cities do not decide based on what they believe. They decide based on what they can afford — where 'afford' means fiscal, political, administrative, and discursive capital. Jackson, Flint, and Duluth demonstrate the theorem." ;
