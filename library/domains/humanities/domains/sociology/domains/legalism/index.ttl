&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/> ;
  schema:name "Legalism" ;
  schema:description "The sociological study of law — how legal systems produce, maintain, and contest social order through rules, institutions, and the classification of persons and acts." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Centralthesis "The sociology of law treats law not as doctrine to be applied but as a social institution that produces and maintains order through the classification of persons, acts, and relations — what counts as a crime, what makes a contract enforceable, who has standing — are sociological questions about how power operates through legal form." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/domains/american-law/> , "critical-legal-studies" , "feminist-legal-theory" , "law-and-economics" , "legal-positivism" , "legal-realism" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/terms/natural-law/> , "sociological-jurisprudence" ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/science/domains/information/terms/discipline/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/> .

