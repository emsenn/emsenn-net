  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/californication-and-affect/> ;
  schema:name "Californication: How Affect Closes the Loop" ;
  schema:description "A person loses their job during a recession. They post about it online. The post frames the loss as a \"pivot.\" People share their own pivot stories. A minor economy of shared affect emerges: vulnerability performed as resilience, loss reframed as growth, systemic failure processed as personal transformation." ;
  schema:datePublished "2026-03-06" ;
