&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/settlerism-and-the-cybernetic-subject/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/settlerism-and-the-cybernetic-subject/> ;
  schema:name "Settlerism and the Cybernetic Subject" ;
  schema:description "Settlerism — settler colonialism understood as a continuing structure rather than a finished event — supplies the historical-material substrate the contemporary apparatus runs on. The genres in which subjects are formatted presuppose a settler-cultural imaginary, and the temporal middle is structurally eliminated by the binary the structure offers. The cybernetic subject is a settler subject in a specific structural sense, regardless of biographical specification." ;
  schema:datePublished "2026-04-27" ;
