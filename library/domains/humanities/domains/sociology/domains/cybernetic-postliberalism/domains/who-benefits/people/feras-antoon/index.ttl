  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/domains/who-benefits/people/feras-antoon/> ;
  schema:name "Feras Antoon" ;
  schema:description "Lebanese-Canadian executive (Montreal-based) who served as CEO of MindGeek through the company's peak years (2013-2022), holding (with David Tassillo) 99.7% of the parent company MindGeek S.à.r.l. according to Luxembourg's beneficial-ownership registry — though the *Fleites v. MindGeek* federal racketeering complaint alleges this share was given to Antoon and Tassillo by Bergmair as compensation for running day-to-day operations while Bergmair remained the controlling beneficial owner." ;
