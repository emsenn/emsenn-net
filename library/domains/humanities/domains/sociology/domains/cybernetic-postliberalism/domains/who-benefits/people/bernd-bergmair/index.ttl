  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/domains/who-benefits/people/bernd-bergmair/> ;
  schema:name "Bernd Bergmair" ;
  schema:description "Austrian-born Goldman Sachs partner (b. 1968) who controlled MindGeek/Pornhub as majority beneficial owner from approximately 2013 to 2023, operating largely invisibly through a chain of Hong Kong, Luxembourg, and BVI shell companies (Bright Imperial Ltd., RT Holding, Acaju Investments). The Brown Rudnick federal racketeering complaint alleges he 'took extreme steps to conceal not just his identity, but his very existence.' The expanded profile and the Bruinen-ECP and Colbeck Capital cases trace his role across the company's life cycle." ;
  schema:datePublished "2026-04-28" ;
