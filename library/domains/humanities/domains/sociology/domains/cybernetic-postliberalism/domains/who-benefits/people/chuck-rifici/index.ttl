  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/domains/who-benefits/people/chuck-rifici/> ;
  schema:name "Chuck Rifici" ;
  schema:description "Canadian cannabis-industry entrepreneur (co-founder of Tweed/Canopy Growth) who in 2021 attempted to acquire MindGeek through Bruinen Investments — a vehicle assembled with former-RCMP advisors and Crime Stoppers International personnel — under the rubric of an audit-led 'ethical turnaround.' The bid (Project Narsil) failed; Ethical Capital Partners completed an acquisition in March 2023 along structurally similar lines." ;
