&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/> ;
  schema:name "Cybernetic Postliberalism" ;
  schema:description "An analytical framework examining how liberal subjectivity is reproduced through cybernetic feedback loops between affect, platforms, economy, and the body." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Centralthesis "Cybernetic postliberalism's central thesis is that liberal subjectivity is reproduced not through ideology or coercion but through cybernetic feedback loops between bodies, affect, technology, and economy — a process named californication, in which structural contradictions are formatted as personally manageable affect, and self-regulation becomes the governance mechanism that preserves system stability." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  prov:wasDerivedFrom &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> ;
  emsenn:Featuredtexts &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/overview/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/californication-and-affect/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/subjects-under-californication/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/the-ecclesial-structure-of-leftist-critique/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/locating-the-origin-of-social-media-platforms-in-the-anglican-church/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/texts/describing-the-american-genocide-against-the-temporal-middle/> ;
