&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/> ;
  schema:name "Cybernetic Postliberalism" ;
  schema:description "Late-liberal governance reproduces itself by formatting structural contradictions as personally manageable affect, on a contracting energetic substrate." ;
  schema:datePublished "2026-04-30" ;
  schema:dateModified "2026-04-30" ;
  emsenn:Centralthesis "Cybernetic postliberalism's central thesis is that liberal subjectivity is reproduced not through ideology or coercion but through cybernetic feedback loops between bodies, affect, technology, and economy — a process named californication, in which structural contradictions are formatted as personally manageable affect, and self-regulation becomes the governance mechanism that preserves system stability." ;
  prov:wasDerivedFrom &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> ;
