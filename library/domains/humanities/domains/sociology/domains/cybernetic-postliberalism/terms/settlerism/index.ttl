&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/settlerism/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/settlerism/> ;
  schema:name "Settlerism" ;
  schema:description "The structural formation of governance organized around continuous displacement-and-replacement of indigenous relations, the production of stable settler subject-positions on a continuously-renewed colonial frontier, and the legal-cultural infrastructures that legitimate the displacement by erasing indigenous prior presence." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
