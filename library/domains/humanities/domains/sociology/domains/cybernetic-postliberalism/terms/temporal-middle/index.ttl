&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/temporal-middle/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/temporal-middle/> ;
  schema:name "Temporal middle" ;
  schema:description "The position of inheriting, continuing, and transforming a tradition without either renewing it wholesale or abandoning it — occupied by every living person but systematically eliminated by settler colonialism, genring, and binary nationalist frameworks that offer only the 'traditional' or the 'assimilated' position." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Contrastswith "assimilation-binary" , "tradition-modernity-binary" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/temporal-middle/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/genring/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/settlerism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/refusal/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/temporal-middle/> .

