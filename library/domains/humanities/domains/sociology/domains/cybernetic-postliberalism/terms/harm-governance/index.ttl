&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/harm-governance/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/harm-governance/> ;
  schema:name "Harm governance" ;
  schema:description "The institutional-affective regime in which care has been collapsed into risk management — political action must be administered through proper procedural channels in order to count as legitimate, and people who have lost faith in the state reproduce its administrative logic with each other. The signature asymmetry is that individual direct action registers as inherently risky because it lacks institutional validation, while mass action registers as safe because institutional form makes it feel legitimate; the framework cannot recognize that institutional form itself introduces risks (co-optation, slowness, dependence on the structures being challenged). Care that does not wait for consensus is what harm governance captures and reformats." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith &lt;https://emsenn.net/tags/direct-action/> , &lt;https://emsenn.net/tags/mutual-aid/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/refusal/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/harm-governance/> ;
