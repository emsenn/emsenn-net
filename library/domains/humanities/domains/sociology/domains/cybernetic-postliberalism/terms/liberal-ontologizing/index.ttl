  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/liberal-ontologizing/> ;
  schema:name "Liberal ontologizing" ;
  schema:description "The foundational operation of liberal thought that treats things as discrete substances with inherent properties — pre-relational, pre-political, sovereign over themselves — and so makes the world into a collection of independently-existing entities that can subsequently 'enter into' relations." ;
