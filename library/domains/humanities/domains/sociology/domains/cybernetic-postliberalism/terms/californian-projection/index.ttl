&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californian-projection/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californian-projection/> ;
  schema:name "Californian projection" ;
  schema:description "The formation in which California — the actual coastal territory and the imaginative screen — has served as the historical laboratory in which the apparatus iterates: a continuous test-and-export of subject-formatting infrastructures, from the Misiones Californianas through the Gold Rush, Hollywood, Esalen, Silicon Valley, and the wellness industry, each phase a stage of one apparatus rather than separate phenomena." ;
  schema:datePublished "2026-04-27" ;
