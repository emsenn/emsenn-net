&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/industrial-intellectualism/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/industrial-intellectualism/> ;
  schema:name "Industrial intellectualism" ;
  schema:description "The structural condition in which intellectual labor is organized as a production process — thought converted into narrative products (threads, essays, papers, podcasts, newsletters) packaged for recognizability within a genre and evaluated by whether the analysis *feels right*, not by whether it corresponds to material outcomes. Citation operates as containment rather than as analytical claim: the citation signals genre membership, confirms the narrative arc has the right shape, and produces the affective satisfaction the market of circulation demands. Embedded knowledge — knowledge held in place by relations, geographies, and obligations — is extracted, formatted, and circulated as insight, with the formatting itself being what the industry selects for." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "embedded-scholarship" , "organic-intellectualism" , "slow-scholarship" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/industrial-intellectualism/> ;
