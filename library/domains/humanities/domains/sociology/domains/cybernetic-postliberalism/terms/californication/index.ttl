&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californication/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californication/> ;
  schema:name "Californication" ;
  schema:description "The operation by which liberal governance reproduces itself by formatting structural contradictions as personally manageable affect. The system does not persuade subjects of its legitimacy and does not, principally, coerce them; it formats them. Crises that liberalism cannot resolve are routed through subjects as mood, trauma, growth opportunity, or lifestyle, and the self-regulation that follows is itself the governance mechanism. The operation is recurrent across the modern pastoral apparatus, with the medieval Christian church as its most thoroughly developed prior institutional form; what is distinctive about the present is its operation under contracted energetic surplus and platformal feedback architecture." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "ideological-persuasion" , "repressive-coercion" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/gramscian/terms/hegemony/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californication/> ;
