&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/zen-fascism/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/zen-fascism/> ;
  schema:name "Zen fascism" ;
  schema:description "The affective regime within californication in which detachment from crisis functions as ethical credential and distress registers as pathology. Where californication names the general operation by which structural contradiction is formatted as personally manageable affect, zen fascism names the specific calibration of feeling rules under which the calm subject is authorized to speak and the distressed subject is offered therapy. The 'zen' names the affective register (detachment, nonreactivity, presence, acceptance) drawn from contemplative traditions but stripped of their relational and ethical context; the 'fascism' names the enforcement — a normative hierarchy of legitimate and illegitimate affect, with credentials attached to the right feelings and penalties attached to the wrong ones." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "open-grief" , "political-rage" , "killjoy-discourse" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/zen-fascism/> ;
