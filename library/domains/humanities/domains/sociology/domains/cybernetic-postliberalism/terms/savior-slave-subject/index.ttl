&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/savior-slave-subject/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/savior-slave-subject/> ;
  schema:name "Savior-slave subject" ;
  schema:description "The dual subject-position californication produces: the subject is constituted as personally responsible for managing structural crises (savior) and structurally incapable of transforming the conditions producing them (slave), such that the feedback loop of self-regulation is itself what governance consists of. The impossibility of occupying both positions is not a defect in the system — it is the system's operating principle, the form in which late-liberal governance reproduces itself through subjects who exhaust themselves managing what they cannot affect." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "autonomous-subject" , "sovereign-subject" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/savior-slave-subject/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/californication/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/terms/cruel-optimism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/zen-fascism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/harm-governance/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/ontogenring/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/savior-slave-subject/> .

