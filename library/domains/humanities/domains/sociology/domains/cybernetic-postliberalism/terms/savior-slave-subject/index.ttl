  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/savior-slave-subject/> ;
  schema:name "Savior-slave subject" ;
  schema:description "The subject position produced by californication: constituted as personally responsible for managing structural crises (savior) and structurally incapable of transforming the conditions producing them (slave), such that the feedback loop of self-regulation is itself what governance consists of." ;
