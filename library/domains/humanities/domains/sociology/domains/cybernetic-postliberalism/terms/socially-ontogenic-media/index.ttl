&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/socially-ontogenic-media/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/socially-ontogenic-media/> ;
  schema:name "Socially ontogenic media" ;
  schema:description "Media artifacts that model survivable identity postures within contradictory or collapsing systems, distributing templates for how to be a coherent actor when inherited identity models no longer function. Unlike media that entertains, explains, or persuades, socially ontogenic media provides its audience with a usable template for how to *be* inside a system that does not offer clear guidance on who to be. The mechanism is the modulation loop: a rhythmic, repeatable pattern of affective response that the audience can emulate and internalize. The category recurs across wildly different genres (Kipling's 'If—,' M*A*S*H, Phineas and Ferb) because the function — modeling survivable being under contradiction — is independent of tone." ;
  schema:datePublished "2025-04-13" ;
  schema:dateModified "2025-04-13" ;
  emsenn:Contrastswith "didactic-media" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarchist-communication/terms/propaganda/> , "entertainment" ;
