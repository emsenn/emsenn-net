  schema:name "Work" ;
  schema:description "The domain of work, labor, organization, and social practices around production and collaboration." ;
  schema:datePublished "2026-04-11" ;
  schema:dateModified "2026-04-11" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
