&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-excess/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-excess/> ;
  schema:name "JurisdictionalExcess" ;
  schema:description "JurisdictionalExcess is a triple (B, J, φ) — an officer B, a full jurisdiction J = (A, T_J, H_J, V), and an act φ — where Q_vires(φ, A, t) = 1 (φ is intra vires within J) but Q_vires(φ, B, t) = 0 (φ falls outside B's personal sub-jurisdiction Z = J|_B). The defining structure: excess is the gap between the full jurisdiction's nuclear domain and the officer's delegated sub-domain. The act is valid — it creates duties — but B has exceeded the scope of their authority, acquiring a duty to the principal for the transgression." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-excess/> ;
  rdfs:seeAlso "Jurisdiction, JurisdictionalVires, Delegation, Instruction, HohfeldianPosition, Accountability, Breach" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-excess/> .

