&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/authority/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/authority/> ;
  schema:name "Authority" ;
  schema:description "Authority is the capacity to create, alter, or extinguish normative relations — to make things count as obligatory, permitted, or prohibited within a scope." ;
  schema:datePublished "2026-04-03" ;
  schema:dateModified "2026-04-03" ;
  emsenn:Contrastswith "influence" , "competence" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/power/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/coercion/> ;
