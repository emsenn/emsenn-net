&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/contract/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/contract/> ;
  schema:name "Contract" ;
  schema:description "A Contract is a five-tuple (P₁, P₂, Φ₁₂, Φ₂₁, V) — two parties P₁ and P₂, a bilateral exchange of promise-sets (Φ₁₂: what P₁ commits to deliver to P₂; Φ₂₁: what P₂ commits to deliver to P₁), and formation conditions V (offer, acceptance, consideration, intention, capacity, legality) — that generates a Hohfeldian web of duties and claims persisting independently of performance. The invariant: authority transfers through delegation; obligation persists through contract. A contract is not a transfer but a mutual binding: both parties remain bound until discharge." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/contract/> ;
  rdfs:seeAlso "Duty, Person, Institution, Delegation, Principal, Office, Promise, Trust, HohfeldianPosition, NormativeSystem, Record, Norm, Authority" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/contract/> .

