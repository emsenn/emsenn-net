&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/duty-of-progressive-encoding/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/duty-of-progressive-encoding/> ;
  schema:name "Duty of Progressive Encoding" ;
  schema:description "The obligation on every office-holder to encode completed work so that future holders — or less capable agents — can perform it at lower cost. A general governance duty grounded in the settlement path: every discharge of a work duty should produce an artifact that moves the work one step toward process." ;
  schema:datePublished "2026-04-07" ;
  schema:dateModified "2026-04-07" ;
