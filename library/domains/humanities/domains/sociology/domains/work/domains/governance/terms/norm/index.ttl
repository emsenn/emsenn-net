&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/norm/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/norm/> ;
  schema:name "Norm" ;
  schema:description "A Norm is a triple (φ, O, N) — a proposition φ expressing what agents in situation S should do or refrain from doing, a deontic modality O selecting among obligation, permission, and prohibition, and a normative system N within which the norm is operative and from which it derives its force. The defining structure: a norm is not a regularity (a pattern of behavior that happens to occur) but a prescription (a standard whose authority is independent of whether it is followed). Violated norms remain norms; violated regularities simply turn out not to be regularities." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/norm/> ;
  rdfs:seeAlso "Duty, Institution, NormativeSystem, Authority, Rule" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/norm/> .

