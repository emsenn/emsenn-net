&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/duty-of-plan-stewardship/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/duty-of-plan-stewardship/> ;
  schema:name "Duty of Plan Stewardship" ;
  schema:description "The obligation on the owner of a plan to ensure it converges toward its goal — maintaining tasks, tracking dependencies, surfacing blockers, and reporting progress. Distinct from the duty of execution: the steward ensures the work gets done, not that any specific task is performed." ;
  schema:datePublished "2026-04-07" ;
  schema:dateModified "2026-04-07" ;
