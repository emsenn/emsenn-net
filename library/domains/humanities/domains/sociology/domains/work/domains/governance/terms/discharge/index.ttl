&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/discharge/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/discharge/> ;
  schema:name "Discharge" ;
  schema:description "A Discharge is a triple (d, a, t) — a duty d, a performance act a by the duty-bearer, and a history t at which the act has reached settled determination as both performed and recognized. Discharge is not merely performance — it is recognized performance; both performance and recognition predicates must reach affirming settlement for the discharge to count." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/discharge/> ;
  rdfs:seeAlso "Duty, Office, Officium, Clerk, DutyOfficer" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/discharge/> .

