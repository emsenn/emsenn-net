  schema:name "Officer" ;
  schema:description "The natural person currently holding an office — the body natural wearing the body politic. Distinguished from the office (which persists through succession) and from the role (which requires only capability-matching, not formal investiture)." ;
  schema:datePublished "2026-04-03" ;
  schema:dateModified "2026-04-03" ;
