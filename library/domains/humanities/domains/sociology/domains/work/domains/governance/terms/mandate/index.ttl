&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/mandate/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/mandate/> ;
  schema:name "Mandate" ;
  schema:description "A Mandate is a triple (A, φ, C) — an authorizing source A, a prescribed act or procedure φ that is required without substantive discretion, and a compulsion condition C under which the mandated party must perform φ when triggered. The defining structure: mandated action is not chosen — it is required by the source authority; refusal when triggered is itself a violation. Mandamus will lie against a mandate-holder who refuses a properly triggered mandated act." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/mandate/> ;
  rdfs:seeAlso "Duty, Clerk, DutyOfficer, Discharge, Delegation, Judgment, Intent" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/mandate/> .

