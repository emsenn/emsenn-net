&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/status-function-declaration/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/status-function-declaration/> ;
  schema:name "Status Function Declaration" ;
  schema:description "A StatusFunctionDeclaration is a four-tuple (X, Y, C, A) — a target X, a status Y, a context C in which the status applies, and an authorizing act A by which the status is constituted — that creates an institutional fact by the act of its utterance or performance. The defining invariant: the declaration does not describe a pre-existing fact; it constitutes one. X acquires the status Y in context C precisely because the declaration A is performed by a party with the standing to make it operative. Without A, X may have all the properties it will have after A, yet still lack status Y." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/status-function-declaration/> ;
  rdfs:seeAlso "Institution, Charter, Area, Authority, Person, Office, NormativeSystem, Norm, Group, Tribe, Investiture, Record, Trust, HohfeldianPosition" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/status-function-declaration/> .

