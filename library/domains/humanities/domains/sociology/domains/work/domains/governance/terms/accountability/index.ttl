&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accountability/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accountability/> ;
  schema:name "Accountability" ;
  schema:description "Accountability is a triple (B, S, A) — a bearer B, a scope S, and an accountability function A: Outcomes(S) → {B} — a total map assigning every outcome within S to B as the answerable party. The defining structure: accountability is backward-looking, total, and non-transferable by delegation. B is answerable for everything that happens in S regardless of who caused it, who was delegated to handle it, or whether B was present. Delegation distributes authority; it never lifts accountability." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accountability/> ;
  rdfs:seeAlso "Duty, Captain, DutyOfficer, Delegation, Discharge, Officer, Principal, Sanction, Breach, Trust, Responsibility" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accountability/> .

