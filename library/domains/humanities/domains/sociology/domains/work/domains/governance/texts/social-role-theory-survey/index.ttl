  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/social-role-theory-survey/> ;
  schema:name "Social Role Theory: A Survey of Competing Accounts" ;
  schema:description "Survey of sociological, logical, and computational traditions that define what a role is — from Linton's status/role distinction through Goffman's dramaturgical analysis to Boella and van der Torre's multi-agent normative formalization." ;
  schema:datePublished "2026-04-03" ;
  schema:dateModified "2026-04-03" ;
  emsenn:Introduces &lt;https://emsenn.net/tags/survey/> ;
  emsenn:Sources "Linton, Ralph. *The Study of Man*. Appleton-Century, 1936." , "Parsons, Talcott. *The Social System*. Free Press, 1951." , "Goffman, Erving. *The Presentation of Self in Everyday Life*. Doubleday, 1959." , "Goffman, Erving. *Encounters: Two Studies in the Sociology of Interaction*. Bobbs-Merrill, 1961." , "Turner, Ralph H. 'The Role and the Person.' *American Journal of Sociology* 84, no. 1 (1978): 1-23." , "Biddle, Bruce J. 'Recent Developments in Role Theory.' *Annual Review of Sociology* 12 (1986): 67-92." , "Searle, John R. *The Construction of Social Reality*. Free Press, 1995." , "Sandhu, Ravi S., et al. 'Role-Based Access Control Models.' *IEEE Computer* 29, no. 2 (1996): 38-47." , "Masolo, Claudio, et al. 'Social Roles and their Descriptions.' *KR 2004*, 267-277." , "Boella, Guido, and Leendert van der Torre. 'Organizations in Multi-Agent Systems.' *AAMAS 2006*." , "Boella, Guido, and Leendert van der Torre. 'The Ontological Properties of Social Roles in Multi-Agent Systems.' *Artificial Intelligence and Law* 15 (2007): 155-185." , "Grossi, Davide, John-Jules Ch. Meyer, and Frank Dignum. 'Counts-as: Classification or Constitution? An Answer Using Modal Logic.' *Journal of Logic and Computation* 18, no. 4 (2008): 631-669." , "Searle, John R. *Making the Social World: The Structure of Human Civilization*. Oxford University Press, 2010." , "Guala, Francesco, and Frank Hindriks. 'A Unified Social Ontology.' *The Philosophical Quarterly* 65, no. 259 (2015): 177-201." , "ANSI/INCITS 359-2004. *Role Based Access Control*." ;
