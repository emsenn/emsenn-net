&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/indigenous-governance-traditions-survey/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/indigenous-governance-traditions-survey/> ;
  schema:name "Indigenous Governance Traditions Beyond State Sovereignty" ;
  schema:description "A survey of non-Western governance frameworks that offer foundational alternatives to the Hohfeldian legal model and state-centric authority structures, including Haudenosaunee confederacy, Anishinaabe clan governance, Ubuntu philosophy, Andean ayllu systems, and Aboriginal Australian kinship governance." ;
