&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/black-radical-governance-survey/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/black-radical-governance-survey/> ;
  schema:name "Black Radical Governance" ;
  schema:description "A survey of the Black radical tradition's theory of governance: that governance systems carry racial inheritance, that formal equality within inherited structures reproduces domination, that abolition is a positive governance theory (replacing life-denying institutions with life-affirming ones), and that fugitivity and collective refusal are normative practices outside state capture." ;
  schema:datePublished "2026-04-03" ;
