&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-declination/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-declination/> ;
  schema:name "JurisdictionalDeclination" ;
  schema:description "A JurisdictionalDeclination is a triple (A, φ, G) — a forum A, a matter φ for which A holds valid jurisdiction J with JV(A, φ, t) ∈ H*_t, and a declination ground G — such that A's act introduces ¬Exercise(A, φ, t) ∈ H*_t: A will not apply σ^J_t to φ despite having the jurisdictional authority to do so. The defining structure: declination is the retraction of a nucleus's operation on a specific matter, distinct from dismissal (which finds JV ∉ H*_t) and from Δ_t-failure (where jurisdiction expires). A declines what it validly could do." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-declination/> ;
  rdfs:seeAlso "Jurisdiction, JurisdictionalVires, JurisdictionalInvocation, Dismissal, Duty, Act, HohfeldianPosition" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-declination/> .

