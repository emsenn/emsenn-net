&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accord/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/accord/> ;
  schema:name "Accord" ;
  schema:description "An Accord is a sheaf F: T^op → Set over the history site — the type of observations. A section F(t) at history t is an Observation. The sheaf condition says local observations at different histories cohere into global ones." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  emsenn:Base "relational-history-site" ;
