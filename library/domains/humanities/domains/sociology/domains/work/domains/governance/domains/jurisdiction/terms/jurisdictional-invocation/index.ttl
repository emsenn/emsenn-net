&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-invocation/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-invocation/> ;
  schema:name "JurisdictionalInvocation" ;
  schema:description "A JurisdictionalInvocation is a triple (G, F, φ) — an invoker G with standing in F, a forum F with jurisdiction J = (A, T_J, H_J, V), and a matter φ — such that G's act introduces φ into F's nucleus domain H^J_t, enabling σ^J_t to evaluate JV(A, φ, t). Before invocation, φ exists as a fiber element in H_t but is not within F's active matter queue. After invocation, the forum must either fix JV(A, φ, t) ∈ H*_t (proceed) or return it to ⊥ (dismiss for want of jurisdiction)." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-invocation/> ;
  rdfs:seeAlso "Jurisdiction, Standing, Act, JurisdictionalVires, Dismissal, JurisdictionalDeclination, JurisdictionalSubmission, Forum" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-invocation/> .

