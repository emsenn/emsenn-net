&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/normative-system/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/normative-system/> ;
  schema:name "Normative System" ;
  schema:description "A Normative System is a structured collection of norms with authority, scope, and coherence conditions, within which norms operate and from which duties derive their force. It is the ambient order giving every obligation, permission, and prohibition its meaning and binding power." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  emsenn:Contrastswith "Regularity" , "Convention" , "Mere-Custom" , "Social-Habit" ;
