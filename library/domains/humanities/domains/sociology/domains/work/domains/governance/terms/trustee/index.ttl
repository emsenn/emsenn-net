&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/trustee/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/trustee/> ;
  schema:name "Trustee" ;
  schema:description "A Trustee is a five-tuple (T_prop, Ben, D_trust, V, A_acc) — trust property T_prop legally vested in the trustee, beneficiaries Ben holding equitable title, fiduciary duties D_trust (loyalty, care, prudence), the vesting condition V, and an accounting obligation A_acc. The defining structure: legal title without beneficial interest — the trustee owns the property as a matter of law but holds it entirely for others." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/trustee/> ;
  rdfs:seeAlso "Fiduciary, Steward, Principal, Duty, Officer" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/trustee/> .

