&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/amendment/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/amendment/> ;
  schema:name "Amendment" ;
  schema:description "An Amendment is a morphism (C, J) → (C', J') between charters — a pair (μ, ν) of a scope adjustment μ and a policy revision ν — that transforms one constituted community's governing policies into another while preserving the community's identity. The defining structure: an amendment changes what the charter says without dissolving and reconstituting the community; the community persists through the amendment. Formally a site morphism — a functor on the underlying blueprint category that is continuous with respect to both Grothendieck topologies." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/amendment/> ;
  rdfs:seeAlso "Charter, Institution, NormativeSystem, Authority, Contract, Delegation" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/amendment/> .

