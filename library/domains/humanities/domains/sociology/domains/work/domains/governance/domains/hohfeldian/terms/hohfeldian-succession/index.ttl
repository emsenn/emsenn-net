&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-succession/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-succession/> ;
  schema:name "Succession" ;
  schema:description "A Succession is a pair (O, L) — an office O and a priority-ordered succession list L = (h₀, h₁, ..., hₙ) of candidate holders — together with an activation predicate P that fires when the primary holder h₀ is unavailable. When P fires, the relief of h₀ and the emergency investiture of the first available candidate hᵢ occur simultaneously. The defining structure: succession is a latent ordered family of sections over the same office position; the active section is the minimum-index element for which the candidate is present and the activation condition holds. Formally: the succession list is a total ordering on the set of candidate sections of the role fibration; succession selects the minimum with respect to that ordering among the candidates currently in a settable state." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-succession/> ;
  rdfs:seeAlso "Investiture, Relief, Captain, DutyOfficer, Office, Enrollment, Duty" ;
