  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/duty-of-execution/> ;
  schema:name "Duty of Execution" ;
  schema:description "The universal obligation on any agent assigned work to advance it toward completion — or to escalate if unable. The duty that makes assignment meaningful: without it, dispatch is notification without obligation." ;
