&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-position/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-position/> ;
  schema:name "Hohfeldian Position" ;
  schema:description "A HohfeldianPosition is one of eight fundamental legal concepts organized in two quartets — (claim, duty, privilege, no-claim) and (power, liability, immunity, disability) — that together constitute the primitive vocabulary for any normative system. Every normative relation between two parties can be decomposed into one or more Hohfeldian positions. The fundamental distinction: first-quartet positions govern what parties must, may, and cannot do (act-level); second-quartet positions govern who can alter act-level normative relations (meta-level)." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/hohfeldian/terms/hohfeldian-position/> ;
