&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdiction/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdiction/> ;
  schema:name "Jurisdiction" ;
  schema:description "Jurisdiction is a four-tuple (A, T_J, H_J, V) — an authority A, a sub-site T_J ⊆ T of the history monoid, a sub-fiber H_J ⊆ H|_{T_J} of the fiber bundle restricted to T_J, and a validity condition V — such that A's instructions create valid duties within T_J × H_J and have no normative force outside it. The defining structure: jurisdiction is a sub-topos of the full relational universe within which an authority's second-quartet powers are operative. Acts within jurisdiction propagate toward H*_t; acts outside it do not." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/> ;
  rdfs:seeAlso "Authority, HohfeldianPosition, Judgment, Instruction, Norm, NormativeSystem, Standing, Area, Delegation, Captain" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdiction/> .

