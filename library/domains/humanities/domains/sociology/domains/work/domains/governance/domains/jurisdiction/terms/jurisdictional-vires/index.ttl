&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-vires/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-vires/> ;
  schema:name "JurisdictionalVires" ;
  schema:description "JurisdictionalVires is a quality Q_vires(φ, A, t) ∈ {0,1} — the quality of an act φ relative to authority A at history t — where Q_vires = 1 (intra vires) iff JV(A, φ, t) ∈ H*_t: all four jurisdiction conditions hold simultaneously. Q_vires = 0 (ultra vires) whenever any condition fails. The defining structure: vires is the natural transformation that evaluates whether φ has a settled path through A's jurisdictional nucleus. It is a quality of the act, not of the authority — the same authority A may be intra vires on one act and ultra vires on another at the same history." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-vires/> ;
  rdfs:seeAlso "Jurisdiction, Act, JurisdictionalInvocation, JurisdictionalExcess, JurisdictionalDeclination, HohfeldianPosition, Standing" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/domains/jurisdiction/terms/jurisdictional-vires/> .

