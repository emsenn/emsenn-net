&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/investiture/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/investiture/> ;
  schema:name "Investiture" ;
  schema:description "An Investiture is a four-tuple (R, I⁺, I⁻, μ) — a role R with defined authority and accountability, a formal assumption act I⁺ that creates the role-binding, a corresponding relief act I⁻ that dissolves it, and a mutual acknowledgement condition μ required for either act to be valid. The defining structure: authority does not transfer by presence, proximity, or rank — only by the completion of I⁺ with μ satisfied." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/investiture/> ;
  rdfs:seeAlso "Captain, DutyOfficer, Incumbent, Delegation, Discharge, Office, StatusFunctionDeclaration, Authority, Trust, Norm, HohfeldianPosition, Record" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/investiture/> .

