&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/institution/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/institution/> ;
  schema:name "Institution" ;
  schema:description "An Institution is a quintuple (Pos, D, CR, Rec, BG) — a position set, a deontic profile assignment, a constitutive rule set of the form 'X counts as Y in context C', a collective recognition predicate, and background conditions. The defining structure: a rule-system that creates and maintains institutional facts by collective acceptance, persisting independently of any particular set of participants. Three traditions: Searle (constitutive rules and status-functions), North (rules of the game vs. organizations as players), Hodgson (institutions reshape agent dispositions over time)." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/institution/> ;
  rdfs:seeAlso "Enterprise, Substrate, Foundation, Company, Charter, NormativeSystem, Vessel, Person" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/institution/> .

