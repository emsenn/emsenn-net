&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/custody/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/custody/> ;
  schema:name "Custody" ;
  schema:description "A Custody is a triple (H, O, [t₀,t₁)) — a holder H who possesses an object O during a bounded interval [t₀,t₁) with a duty of care for O but without ownership of O. The defining structure: possession without title; the holder may use O only as necessary to fulfill the custodial purpose; accountability for O's condition runs from t₀ to t₁. The duty of care is preservation of O's settlement: the holder maintains O's condition through the interval and returns it at t₁ with the same settlement profile it had at t₀." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/custody/> ;
  rdfs:seeAlso "Cargo, Trustee, Duty, Bailment, Vessel" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/custody/> .

