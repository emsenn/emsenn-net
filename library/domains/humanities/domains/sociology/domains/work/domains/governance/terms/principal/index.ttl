&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> ;
  schema:name "Principal" ;
  schema:description "A Principal is a quadruple (P, Q, ρ, α) — an original authority structure P whose accountability proposition is not derived from any superior authority within the sub-system, an action domain Q, a delegation profile ρ assigning to each agent a restriction of the principal's authority into the agent's scope, and an accountability proposition α in the principal's settled determination. Delegation does not deplete the principal's authority (restriction is not depletion); accountability does not flow down delegation morphisms; revocation withdraws ρ_a without disturbing the principal." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> ;
  prov:wasDerivedFrom &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/voidmath/terms/entity/> ;
  rdfs:seeAlso "Office, Incumbent, Duty, Officer, StaffOfficer, DutyOfficer, Captain, Authority, Delegation, Trust, HohfeldianPosition, Contract, Fiduciary, Norm" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> .

