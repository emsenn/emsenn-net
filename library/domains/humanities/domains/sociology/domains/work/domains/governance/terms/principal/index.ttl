&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> ;
  schema:name "Principal" ;
  schema:description "A Principal is a quadruple (H^P, Q, ρ, α) — an original authority fiber doctrine H^P whose fixed propositions are not derived from any superior fiber within the sub-system, an action domain Q, a delegation profile ρ assigning to each agent a restriction map from H^P into the agent's fiber doctrine, and an accountability proposition α ∈ H^{P*}_t asserting original authority over Q at t. The defining nuclear condition: α is in the fixed fiber of the principal's own nuclei, not in the image of any restriction map from above within the sub-system. Delegation does not reduce H^{P*}_t (restriction is not depletion); accountability propositions do not flow down delegation morphisms; revocation withdraws ρ_a without disturbing H^P." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  emsenn:Base "t" ;
  schema:isPartOf "relational-universe" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> ;
  emsenn:Elementof "entity" ;
  prov:wasDerivedFrom "Entity" ;
  emsenn:Fiberof "relational-universe" ;
  emsenn:Minimummath "relational-history-fiber-saturating-nucleus" ;
  rdfs:seeAlso "Office, Incumbent, Duty, Officer, StaffOfficer, DutyOfficer, Captain, Authority, Delegation, Trust, HohfeldianPosition, Contract, Fiduciary, Norm" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/terms/principal/> .

