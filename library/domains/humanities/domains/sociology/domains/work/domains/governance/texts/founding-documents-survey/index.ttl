&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/founding-documents-survey/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/domains/governance/texts/founding-documents-survey/> ;
  schema:name "Founding and Governing Documents: A Survey of Constitutional Instruments" ;
  schema:description "A survey of the types of founding and governing documents that constitute organizations, their structural requirements, governance functions, and relationships. Covers charters, constitutions, articles of incorporation, articles of agreement, bylaws, covenants, treaties, and cooperative constitutions, examining what functions each serves and how they relate to one another." ;
