&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/settlement-of-work-management/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/settlement-of-work-management/> ;
  schema:name "The Settlement of Work Management: How Infrastructure Turns Inquiry Into Process" ;
  schema:description "As work infrastructure matures, questions like 'what should I do next?' settle from open inquiry through derivation and procedure into deterministic process — the same settlement path that applies to the work being managed." ;
  schema:datePublished "2026-04-03" ;
  schema:dateModified "2026-04-03" ;
