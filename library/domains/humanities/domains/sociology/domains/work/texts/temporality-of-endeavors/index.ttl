  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/temporality-of-endeavors/> ;
  schema:name "The Temporality of Endeavors" ;
  schema:description "How an endeavor's temporal character — aim-terminated, indefinite, or aim-open — determines the shape of its operational infrastructure: which planning horizons apply, what cadences are structurally necessary, how urgency manifests, and why multi-scale operations are required." ;
