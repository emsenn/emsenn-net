&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/philosophy-of-endeavor/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/philosophy-of-endeavor/> ;
  schema:name "Philosophy of Endeavor" ;
  schema:description "The philosophical grounding of endeavor in Chisholm's analysis of intentional action, Hornsby's trying-events, and O'Shaughnessy's sustained trying." ;
  schema:datePublished "2026-04-05" ;
  schema:dateModified "2026-04-05" ;
  emsenn:Addresses &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/endeavor/> ;
  emsenn:Claim "Endeavor is the attempt raised to sustained commitment — directed, failure-open striving that is more fundamental than doing because it can be fully present when the action is absent." ;
