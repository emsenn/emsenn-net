  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/goal/> ;
  schema:name "Goal" ;
  schema:description "A directional ambition that orients work without being reducible to a single decidable target. Goals specify what success looks like in broad terms; objectives, projects, and plans translate that direction into decidable and actionable structure." ;
  schema:datePublished "2026-04-11" ;
  schema:dateModified "2026-04-11" ;
