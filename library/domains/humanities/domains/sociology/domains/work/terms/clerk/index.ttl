&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/clerk/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/clerk/> ;
  schema:name "Clerk" ;
  schema:description "A Clerk is a six-tuple (P, D, R, A, M, X) — a principal institution P, a decision-maker D whose decisions the clerk records, an official record R in the clerk's custody, an authentication act A, a ministerial mandate M governing A without discretion, and a non-delegable authentication core X. The defining structure: ministerial in discretion, constitutive in effect — the clerk's act of recording completes the institutional act rather than merely reflecting it." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/clerk/> ;
  rdfs:seeAlso "Secretary, Principal, Officer, Duty, Office, Registrar" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/clerk/> .

