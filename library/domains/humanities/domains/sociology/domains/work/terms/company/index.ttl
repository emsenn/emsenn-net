&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/company/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/company/> ;
  schema:name "Company" ;
  schema:description "A Company is a quadruple (K, S, G, ℓ) — a charter K encoding a common purpose, a staff S as ongoing personnel, a governance mechanism G for collective decision-making, and an institutional standing ℓ constituting the company as an entity. The defining structure: a company is a vessel whose charter encodes a purpose jointly held by its members — not merely imposed from above but constitutive of membership — with staff (ongoing personnel) rather than voyage-bounded crew, and an entity-status that makes collective attribution possible: 'the company decided.' Company derives from Latin companio (com + panis, bread-fellow) — a fellowship of persons sharing a common purpose." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/company/> ;
  rdfs:seeAlso "Vessel, Staff, Charter, Institution, NormativeSystem, Crew, Person, Captain" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/company/> .

