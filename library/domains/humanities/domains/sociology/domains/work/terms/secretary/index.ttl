&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/secretary/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/secretary/> ;
  schema:name "Secretary" ;
  schema:description "A Secretary is a five-tuple (Q, R, C, F, κ) — a principal body Q whose decisions the secretary records, a record set R (minutes, registers, official correspondence) over which the secretary has custody, a communications function C (official outward transmission), a filing obligation F, and an authentication function κ whose application to a document constitutes official validity. The defining structure: the secretary authenticates decisions made by Q, does not make decisions, and the authenticated record is the institution's official memory." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/secretary/> ;
  rdfs:seeAlso "Clerk, Principal, Office, Duty, Trustee" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/secretary/> .

