&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/focus/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/focus/> ;
  schema:name "Focus" ;
  schema:description "A Focus is a pair (H, t*) — an ambient RelationalState H and a designated focal history t* ∈ T — inducing a tripartite Gurwitsch field: the focal fiber H_{t*} as theme, the restriction-accessible fibers {H_t : t ≤ t*, t ≠ t*} as thematic field, and the remaining fibers as margin. The defining structure: focus is the designated current working fiber in a presheaf — the position at which the RelationalMachine currently operates, from which context radiates via restriction maps outward, and within which the nuclear pair (σ_{t*}, Δ_{t*}) partitions propositions into the nuclear focal sublocale H*_{t*} and its complement." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/focus/> ;
  rdfs:seeAlso "RelationalState, IndexedAutomaton, RelationalMachine, History, Character, Persona, MacroFocus, MesoFocus, MicroFocus" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/focus/> .

