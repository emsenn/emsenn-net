&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/tracking/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/tracking/> ;
  schema:name "Tracking" ;
  schema:description "The continuous observation of work entity states — reading the event stream, computing derived metrics, surfacing anomalies. Tracking does not act — it observes and reports. The observation layer Γ(H*) applied to work." ;
  schema:datePublished "2026-04-07" ;
  schema:dateModified "2026-04-07" ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/execution/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/review/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/tracking/> ;
  emsenn:Follows &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/execution/> ;
  emsenn:Groundedin &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/tracking-and-measurement-survey/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/texts/ontology-of-work-operations/> ;
  emsenn:Inputfrom &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/event/> , "state-change" , "artifact" ;
  rdf:type "stage" ;
  emsenn:Outputto &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/observation/> ;
  emsenn:Partofcycle "operations-loop" ;
  emsenn:Positionincycle "4" ;
  emsenn:Precedes &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/review/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/metric/> , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/event/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-state/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/record/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/observation/> ;
  emsenn:Settlementrole "Tracking is the observation layer — it reads settled state (ground terms produced by execution) and computes derived quantities (metrics). It does not produce new ground terms." ;
  emsenn:Traditions "little-law" , "goldratt-toc" , "deming-spc" , "kanban-metrics" ;
