  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/operation-item/> ;
  schema:name "OperationItem" ;
  schema:description "An OperationItem is the initial algebra of the functor F(X) = WorkUnit ⊕ List(X) — either a ground atomic WorkUnit (base case) or a Workflow wrapping a list of OperationItems (recursive case)." ;
