&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/runbook/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/runbook/> ;
  schema:name "Runbook" ;
  schema:description "A Runbook is a four-tuple (N, R, Π, G) — a trigger norm N whose activation selects this runbook, an executor role R whose incumbent is obligated to run it, a step sequence Π of acts that is execution-settled before the trigger fires, and a goal G that the sequence drives to the fixed fiber. The defining structure: a runbook is a specialized mandate whose prescribed act is a sequence, selected by a triggering norm, owned by an institution, terminating when the goal reaches H*_t." ;
  schema:datePublished "2026-03-20" ;
  schema:dateModified "2026-03-20" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/runbook/> ;
  rdfs:seeAlso "Norm, Act, Mandate, Goal, Role, Incumbent, Institution, NormativeSystem, Duty" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/runbook/> .

