&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/steward/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/steward/> ;
  schema:name "Steward" ;
  schema:description "A Steward (oikonomos) is an agent who manages another's household or estate by delegated authority — exercising genuine judgment over resources not her own, bound to the owner's interests, and obligated to render a full account of that management." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
