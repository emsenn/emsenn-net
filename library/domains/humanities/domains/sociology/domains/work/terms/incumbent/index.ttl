&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/incumbent/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/incumbent/> ;
  schema:name "Incumbent" ;
  schema:description "An Incumbent is a quadruple (O, t_now, a, ι) — an Office, a designated current history, an occupant Entity, and an incumbency proposition asserting that a holds O at t_now. Full incumbency is ι ∈ H*_{t_now}: doubly stable, with institution (σ-fixed) and induction (Δ-fixed) both complete." ;
  schema:datePublished "2026-03-19" ;
  schema:dateModified "2026-03-19" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/incumbent/> ;
  prov:wasDerivedFrom "entity" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/office/> ;
  emsenn:Minimummath "relational-history-fiber-saturating-nucleus" ;
  emsenn:Restricts "entity" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/office/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/work/terms/incumbent/> .

