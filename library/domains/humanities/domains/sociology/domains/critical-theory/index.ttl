&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> ;
  schema:name "Critical Theory" ;
  schema:description "The school originating in the Frankfurt School's fusion of Marx and Freud, extended through Foucault's analysis of power/knowledge and Povinelli's analysis of late-liberal governance — analyzing how social structures produce the knowledge, categories, and subjects that sustain them." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Centralthesis "Critical theory's central move is asking, of any social structure, whose interests it serves and how it could be otherwise — extending Marx's critique of political economy through Frankfurt School analyses of culture and consciousness, Foucault's analysis of power/knowledge, and Povinelli's analysis of late-liberal governance." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart "foucault" , "povinelli" ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> .

