&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/espositoan/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/espositoan/> ;
  schema:name "Espositean Immunitary Paradigm" ;
  schema:description "Roberto Esposito's immunitary paradigm — how communities protect themselves by incorporating controlled doses of what threatens them, and how that logic becomes auto-immune." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Centralthesis "Espositean biopolitics holds that modern political life is structured by immunitary logic — the community protects itself by internalizing controlled doses of what threatens it — and that the logic becomes auto-immune when intensified, with the community's defenses turning to consume the community itself." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/continental/terms/auto-immunity/> , "immunitary-logic" ;
