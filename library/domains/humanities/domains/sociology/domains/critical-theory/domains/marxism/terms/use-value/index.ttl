&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/terms/use-value/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/terms/use-value/> ;
  schema:name "Use-Value" ;
  schema:description "Use-value is the usefulness of a thing for satisfying a human need or want. A coat keeps someone warm; a loaf of bread feeds someone. [Karl Marx](../../general/domains/people/karl-marx.md) opens *Capital* (1867) with the distinction between use-value and [exchange-value](./exchange-value.md) because the commodity is the unity of both, and the tension between them drives the analysis forward." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/marxism/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/terms/use-value/> .

