&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/butlerian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/butlerian/> ;
  schema:name "Butlerian Biopolitics" ;
  schema:description "Judith Butler's analysis of how political and media structures determine which lives are recognized as lives — through the differential distribution of grievability, precarity, and the frames that render some lives visible and others disposable." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
  emsenn:Centralthesis "Butlerian biopolitics holds that grievability is a precondition for recognizing life as life — political and media frames sort populations into grievable and ungrievable lives before any violence is done, and that prior framing is what makes some populations available to be killed with impunity." ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/political-philosophy/terms/grievability/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/precarity/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/butlerian/terms/frames-of-war/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/butlerian/> .

