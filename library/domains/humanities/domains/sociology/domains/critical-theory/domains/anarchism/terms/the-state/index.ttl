  schema:name "The State" ;
  schema:description "The set of institutions — legislatures, courts, police, military, prisons, bureaucracies — that claim the sole right to use force over a territory and its people. Anarchism opposes it as inherently hierarchical." ;
  schema:datePublished "2026-03-06" ;
