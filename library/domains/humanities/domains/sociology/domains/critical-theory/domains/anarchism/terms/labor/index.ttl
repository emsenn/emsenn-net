  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/labor/> ;
  schema:name "Labor" ;
  schema:description "Human effort directed toward producing something — and under capitalism, a commodity that workers must sell to survive. Anarchism distinguishes freely chosen activity from compelled work performed under hierarchy." ;
