&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/autonomism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/autonomism/> ;
  schema:name "Autonomism" ;
  schema:description "The Marxist school originating in Italian workerism (operaismo) — centering workers' self-activity, the refusal of work, and the analysis of social reproduction and immaterial labor as sites of struggle." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Centralthesis "Autonomism centers workers' self-activity rather than the party or productive forces — capital reacts to workers' struggles rather than the other way around, and refusal of the labor relation (rather than negotiation within it) is the engine that forces capital to restructure." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/marxism/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/autonomism/terms/operaismo/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/autonomism/> .

