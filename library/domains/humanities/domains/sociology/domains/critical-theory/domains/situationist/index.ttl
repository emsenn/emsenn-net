&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/> ;
  schema:name "Situationist International" ;
  schema:description "The school originating with Guy Debord — the critique of spectacular society, the analysis of recuperation, and the practice of détournement." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Centralthesis "The Situationist International held that postwar capitalism's defining condition is the spectacle — the social relation in which lived experience is replaced by its representation — and that resistance must work by hijacking spectacle's own materials (détournement) to reveal the social relations they conceal." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/terms/spectacle/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/recuperation/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/terms/hypernormalization/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/> .

