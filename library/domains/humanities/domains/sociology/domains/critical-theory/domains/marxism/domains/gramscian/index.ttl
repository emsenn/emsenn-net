&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/gramscian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/gramscian/> ;
  schema:name "Gramscian Analysis" ;
  schema:description "The school of Marxist analysis developed from Antonio Gramsci's theory of cultural hegemony — how ruling-class domination operates through consent manufactured in civil society rather than through force alone." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Centralthesis "Gramscian analysis holds that ruling-class domination in developed capitalism operates not primarily through force but through hegemony — the production of consent through civil society such that the interests of the ruling class come to appear as common sense." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/marxism/> ;
