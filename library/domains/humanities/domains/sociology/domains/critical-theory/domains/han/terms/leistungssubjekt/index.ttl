&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/terms/leistungssubjekt/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/terms/leistungssubjekt/> ;
  schema:name "Leistungssubjekt" ;
  schema:description "Han's term for the late-neoliberal subject who has displaced the disciplinary 'you must' with the permissive 'you can,' and who, finding 'you can' indistinguishable from a tacit 'you must,' exploits themselves in the name of self-realization. The subject is simultaneously project and product, exploiter and exploited; the resulting depression and burnout are structural rather than individual." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "disciplinary-subject" , "sovereign-subject" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/terms/leistungssubjekt/> ;
  rdfs:seeAlso "burnout-society" , "psychopolitics" , "transparency-society" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/terms/governmentality/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/terms/leistungssubjekt/> .

