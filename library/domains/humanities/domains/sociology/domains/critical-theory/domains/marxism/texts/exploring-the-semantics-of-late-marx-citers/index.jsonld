  "@id": "https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/texts/exploring-the-semantics-of-late-marx-citers/",
  "@type": "Article",
  "dateModified": "2025-10-17",
  "datePublished": "2025-10-17",
  "description": "import csv, json, re, time, random import requests OUTFILE = \u0026#34;abstracts.csv\u0026#34; CONTACT_EMAIL = \u0026#34;emsenn@emsenn.net\u0026#34; MAX_RESULTS = 200 SLEEP = 1.2 SEED = 42 random.seed(SEED) QUERY_ANDERSON = \u0026#39;\u0026#34;Kevin B. Anderson\u0026#34; \u0026#34;The Late Marx and the Russian Road\u0026#34;\u0026#39; QUERY_CONTROL = \u0026#39;Marxism OR \u0026#34;Karl Marx\u0026#34;\u0026#39; MARX_FILTER = re.compile(r\u0026#34;(marx|marxism|historical materialism|capitalis\\w*|communis\\w*|class struggle)\u0026#34;, re.I) BAD_SUBJECTS = {\u0026#34;chemistry\u0026#34;, \u0026#34;physics\u0026#34;, \u0026#34;materials\u0026#34;, \u0026#34;engineering\u0026#34;, \u0026#34;medicine\u0026#34;, \u0026#34;biology\u0026#34;, \u0026#34;geology\u0026#34;} def query_crossref(query, rows=100, cursor=\u0026#34;*\u0026#34;): url = \u0026#34;https://api.crossref.org/works\u0026#34; params = {\u0026#34;query.bibliographic\u0026#34;: query, \u0026#34;rows\u0026#34;: rows, \u0026#34;cursor\u0026#34;: cursor, \u0026#34;mailto\u0026#34;: CONTACT_EMAIL} while True: r = requests.get(url, params=params, timeout=30) if r.status_code != 200: print(\u0026#34;Error\u0026#34;, r.status_code, r.text) break data = r.json() items = data[\u0026#34;message\u0026#34;][\u0026#34;items\u0026#34;] for it in items: yield it cursor_next = data[\u0026#34;message\u0026#34;].get(\u0026#34;next-cursor\u0026#34;) if not cursor_next or len(items) == 0: break params[\u0026#34;cursor\u0026#34;] = cursor_next time.sleep(SLEEP) def clean(text): if not text: return \u0026#34;\u0026#34; return re.sub(r\u0026#34;\\s+\u0026#34;, \u0026#34; \u0026#34;, str(text)).strip() def extract(it): doi = it.get(\u0026#34;DOI\u0026#34;, \u0026#34;\u0026#34;) title = clean(\u0026#34; \u0026#34;.join(it.get(\u0026#34;title\u0026#34;, []))) abstract = clean(it.get(\u0026#34;abstract\u0026#34;, \u0026#34;\u0026#34;)) year = None for fld in (\u0026#34;published-print\u0026#34;,\u0026#34;published-online\u0026#34;,\u0026#34;created\u0026#34;): if fld in it and \u0026#34;date-parts\u0026#34; in it[fld]: year = it[fld][\u0026#34;date-parts\u0026#34;][0][0] break authors = \u0026#34;, \u0026#34;.join([a.get(\u0026#34;family\u0026#34;,\u0026#34;\u0026#34;) for a in it.get(\u0026#34;author\u0026#34;,[]) if \u0026#34;family\u0026#34; in a]) publisher = it.get(\u0026#34;publisher\u0026#34;, \u0026#34;\u0026#34;) subjects = [s.lower() for s in it.get(\u0026#34;subject\u0026#34;, [])] lang = it.get(\u0026#34;language\u0026#34;,\u0026#34;\u0026#34;).lower() if it.get(\u0026#34;language\u0026#34;) else \u0026#34;\u0026#34; return {\u0026#34;doi\u0026#34;:doi,\u0026#34;title\u0026#34;:title,\u0026#34;abstract\u0026#34;:abstract,\u0026#34;year\u0026#34;:year, \u0026#34;authors\u0026#34;:authors,\u0026#34;publisher\u0026#34;:publisher,\u0026#34;subjects\u0026#34;:subjects,\u0026#34;lang\u0026#34;:lang} def is_marxist(rec): \u0026#34;\u0026#34;\u0026#34;Heuristic: English + humanities/social + Marx lexicon\u0026#34;\u0026#34;\u0026#34; if rec[\u0026#34;lang\u0026#34;] and not rec[\u0026#34;lang\u0026#34;].startswith(\u0026#34;en\u0026#34;): return False if any(bad in rec[\u0026#34;subjects\u0026#34;] for bad in BAD_SUBJECTS): return False text = f\u0026#34;{rec[\u0026#39;title\u0026#39;]} {rec[\u0026#39;abstract\u0026#39;]}\u0026#34;.lower() return bool(MARX_FILTER.search(text)) # --- Main collection --- def collect(query, label): records = [] for item in query_crossref(query, rows=100): rec = extract(item) if not is_marxist(rec): continue rec[\u0026#34;label\u0026#34;] = label records.append(rec) if len(records) \u0026gt;= MAX_RESULTS: break return records print(\u0026#34;Fetching Anderson-related records…\u0026#34;) anderson_records = collect(QUERY_ANDERSON, \u0026#34;cites_anderson\u0026#34;) print(\u0026#34;Fetching Marxist control records…\u0026#34;) control_records = collect(QUERY_CONTROL, \u0026#34;control\u0026#34;) rows = anderson_records + control_records random.shuffle(rows) # --- Write CSV --- with open(OUTFILE, \u0026#34;w\u0026#34;, newline=\u0026#34;\u0026#34;, encoding=\u0026#34;utf-8\u0026#34;) as f: writer = csv.DictWriter(f, fieldnames=[ \u0026#34;label\u0026#34;,\u0026#34;year\u0026#34;,\u0026#34;title\u0026#34;,\u0026#34;authors\u0026#34;,\u0026#34;publisher\u0026#34;,\u0026#34;doi\u0026#34;,\u0026#34;abstract\u0026#34; ]) writer.writeheader() for r in rows: writer.writerow({k:r.get(k,\u0026#34;\u0026#34;) for k in writer.fieldnames}) print(f\u0026#34;Wrote {len(rows)} records to {OUTFILE}\u0026#34;) print(\u0026#34;Sample titles:\u0026#34;) for r in rows[:10]: print(f\u0026#34;- [{r[\u0026#39;label\u0026#39;]}] {r[\u0026#39;year\u0026#39;]} {r[\u0026#39;title\u0026#39;][:80]}…\u0026#34;) #!/usr/bin/env python3 \u0026#34;\u0026#34;\u0026#34; explore-anderson-citations.py --------------------------------- Quick analysis of whether Anderson-citing works use more \u0026#39;moral\u0026#39; or \u0026#39;method\u0026#39; language, using a simple keyword frequency approach on abstracts.csv. Input CSV must contain columns: label, text (abstract or concatenated text). Label values: \u0026#39;cites_anderson\u0026#39; or \u0026#39;control\u0026#39;. Outputs group means and 95% confidence intervals per 1000 words. \u0026#34;\u0026#34;\u0026#34; import re, csv, statistics as stats from collections import Counter # --- Keyword patterns --- METHOD = r\u0026#34;\\b(method|methods|measurement|data(set)?|survey|fieldwork|interview|sampling|regress\\w*|model\\w*|estimate\\w*|coding|reliab\\w*|validi\\w*|operationali\\w*|variable\\w*|hypothes\\w*|test(ed|ing)?|significan\\w*|simulat\\w*|network\\w*|experiment\\w*|appendix|replicat\\w*|code|archive|corpus|algorithm)\\b\u0026#34; MORAL = r\u0026#34;\\b(redempt\\w*|inclusion|inclusive|recognit\\w*|plural\\w*|eurocentr\\w*|decolonial\\w*|coloniality|humanism|ethic(s|al)\\b(?!\\s*protocol)|empath\\w*|conscience|guilt|atone\\w*|moral\\w*|legitim\\w*|rehabilitat\\w*|reconciliat\\w*|solidarit\\w*|utopian\\w*|hopeful|hope|salvat\\w*|justice|injustic\\w*|violenc\\w*|suffer\\w*|oppress\\w*|emancipat\\w*|dignit\\w*|liberat\\w*|redress|repair|healing)\\b\u0026#34; METHOD_RE = re.compile(METHOD, re.I) MORAL_RE = re.compile(MORAL, re.I) def normalize(text): if not text: return \u0026#34;\u0026#34; return re.sub(r\u0026#34;\\s+\u0026#34;, \u0026#34; \u0026#34;, text).lower() def count_keywords(text, pattern): return len(pattern.findall(text)) def load_records(path=\u0026#34;abstracts.csv\u0026#34;): records = [] with open(path, newline=\u0026#34;\u0026#34;, encoding=\u0026#34;utf-8\u0026#34;) as f: reader = csv.DictReader(f) for row in reader: label = row.get(\u0026#34;label\u0026#34;,\u0026#34;\u0026#34;).strip() # Concatenate title + abstract for analysis text = normalize((row.get(\u0026#34;title\u0026#34;,\u0026#34;\u0026#34;) or \u0026#34;\u0026#34;) + \u0026#34; \u0026#34; + (row.get(\u0026#34;abstract\u0026#34;,\u0026#34;\u0026#34;) or \u0026#34;\u0026#34;)) if not text: continue records.append({\u0026#34;label\u0026#34;:label, \u0026#34;text\u0026#34;:text}) return records def compute_scores(records): results = [] for rec in records: words = rec[\u0026#34;text\u0026#34;].split() n_words = len(words) if words else 1 method_count = count_keywords(rec[\u0026#34;text\u0026#34;], METHOD_RE) moral_count = count_keywords(rec[\u0026#34;text\u0026#34;], MORAL_RE) # Per 1000 words mth_per_1k = method_count * 1000.0 / n_words mor_per_1k = moral_count * 1000.0 / n_words results.append({ \u0026#34;label\u0026#34;: rec[\u0026#34;label\u0026#34;], \u0026#34;method_per_1k\u0026#34;: mth_per_1k, \u0026#34;moral_per_1k\u0026#34;: mor_per_1k }) return results def group_stats(results): groups = {} for r in results: groups.setdefault(r[\u0026#34;label\u0026#34;], {\u0026#34;method\u0026#34;:[], \u0026#34;moral\u0026#34;:[]}) groups[r[\u0026#34;label\u0026#34;]][\u0026#34;method\u0026#34;].append(r[\u0026#34;method_per_1k\u0026#34;]) groups[r[\u0026#34;label\u0026#34;]][\u0026#34;moral\u0026#34;].append(r[\u0026#34;moral_per_1k\u0026#34;]) return groups def summarize(vals): if not vals: return (0.0,0.0,0.0) mean = stats.mean(vals) if len(vals) \u0026gt; 1: stdev = stats.pstdev(vals) # 95% CI ~ mean ± 1.96 * (stdev / sqrt(n)) se = stdev / (len(vals) ** 0.5) ci_low = mean - 1.96 * se ci_high = mean + 1.96 * se else: ci_low = ci_high = mean return (mean, ci_low, ci_high) def main(): records = load_records() results = compute_scores(records) groups = group_stats(results) print(\u0026#34;Group\\tType\\tMean\\tCI_low\\tCI_high\\tN\u0026#34;) for label, vals in groups.items(): for kind in (\u0026#34;method\u0026#34;,\u0026#34;moral\u0026#34;): arr = vals[kind] mean, lo, hi = summarize(arr) print(f\u0026#34;{label}\\t{kind}\\t{mean:.2f}\\t{lo:.2f}\\t{hi:.2f}\\t{len(arr)}\u0026#34;) if __name__ == \u0026#34;__main__\u0026#34;: main() ",
