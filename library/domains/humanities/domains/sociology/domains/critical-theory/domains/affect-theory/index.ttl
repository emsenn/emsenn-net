&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/> ;
  schema:name "Affect Theory" ;
  schema:description "The school that analyzes how pre-cognitive bodily intensities — tension, ease, attraction, repulsion — organize social and political life in ways that ideology critique and rational-actor models cannot capture." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Centralthesis "Affect theory holds that social order is maintained not just through belief and coercion but through the organization of pre-cognitive bodily intensities — rhythm, atmospheric pressure, attachment — that rational deliberation and ideological persuasion cannot account for." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart "berlant" ;
