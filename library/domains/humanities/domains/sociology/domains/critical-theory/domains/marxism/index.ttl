&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/> ;
  schema:name "Marxism" ;
  schema:description "The school of social analysis grounded in Marx's critique of political economy — historical materialism, class struggle, the analysis of capitalism as a system of exploitation, and the traditions that extended and contested this analysis." ;
  schema:datePublished "2026-03-07" ;
  schema:dateModified "2026-03-07" ;
  emsenn:Centralthesis "Marxism holds that the mode of production — how a society organizes the labor that sustains it — determines the structure of that society's politics, law, culture, and consciousness, and that capitalism is a specific mode in which the apparatus of state, law, and ideology exists to maintain the extraction of surplus value from those who sell their labor." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/gramscian/> , &lt;https://emsenn.net/tags/decolonial/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/autonomism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/political-economy/> ;
