&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/> ;
  schema:name "Hannian Analysis" ;
  schema:description "Byung-Chul Han's analytical framework — the achievement-subject, the burnout society, the transparency society, psychopolitics, and the disappearance of the other — for understanding how late-neoliberal subjects come to exploit themselves under the affective grammar of freedom." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Centralthesis "Late-neoliberal governance does not discipline its subjects from outside; it produces them as achievement-subjects (Leistungssubjekte) who exhaust themselves in the name of self-realization. The subject is simultaneously project and product, exploiter and exploited, and the resulting depression is a structural feature of the system rather than an individual pathology." ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/terms/leistungssubjekt/> , "burnout-society" , "transparency-society" , "psychopolitics" ;
  prov:wasDerivedFrom "foucault" ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/han/> .

