  schema:name "Adaptation Does Not Require a Future" ;
  schema:description "Anarcho-mutualism's five structural commitments each presuppose conditions that collapse destroys. Anarcho-nihilism's relational ontology presupposes only relations — and relations persist where procedures, symmetry, and consensus do not." ;
  schema:datePublished "2026-03-30" ;
