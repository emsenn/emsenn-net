&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarcho-nihilism/terms/the-death-drive/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarcho-nihilism/terms/the-death-drive/> ;
  schema:name "The Death Drive" ;
  schema:description "The Freudian concept, radicalized by Lacan, of a force that operates beyond the pleasure principle — unbinding, disintegrating, and returning to zero. For anarcho-nihilism, the death drive names the structural position of what the symbolic order cannot integrate: the force that disrupts every system's self-reproduction." ;
  schema:datePublished "2026-03-06" ;
