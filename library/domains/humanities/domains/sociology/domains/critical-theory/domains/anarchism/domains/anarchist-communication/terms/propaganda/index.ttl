  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarchist-communication/terms/propaganda/> ;
  schema:name "Propaganda" ;
  schema:description "The systematic production and distribution of communication designed to shape belief, attitude, or behavior in service of a political project. Propaganda is not defined by being false but by being instrumental — communication organized around effects rather than truth." ;
