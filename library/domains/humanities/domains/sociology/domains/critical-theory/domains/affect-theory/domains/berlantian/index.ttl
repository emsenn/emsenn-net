&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/> ;
  schema:name "Berlantian Analysis" ;
  schema:description "Lauren Berlant's analysis of how affect sustains attachment to conditions that are actively harmful — cruel optimism, the impasse, crisis ordinariness, and the slow death of populations managed through attrition rather than catastrophe." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Centralthesis "Berlantian analysis examines how affect — the pre-cognitive registers of attachment, hope, exhaustion, and endurance — sustains people's participation in arrangements that are actively harmful to them, with cruel optimism naming the relation in which the object of attachment is itself the obstacle to flourishing." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/terms/cruel-optimism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/terms/affective-infrastructure/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/terms/slow-death/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/domains/berlantian/> .

