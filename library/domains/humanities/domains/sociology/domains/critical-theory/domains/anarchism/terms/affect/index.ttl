  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/affect/> ;
  schema:name "Affect" ;
  schema:description "The felt, bodily dimension of political experience — intensities that precede and exceed conscious emotion. Anarchist analysis uses affect to explain how domination operates at the level of feeling (fear, exhaustion, numbness) and how resistance produces its own intensities (solidarity, rage, armed joy) that escape rational calculation." ;
