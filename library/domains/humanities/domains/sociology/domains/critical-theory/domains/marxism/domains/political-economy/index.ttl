&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/political-economy/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/political-economy/> ;
  schema:name "Political Economy" ;
  schema:description "The discipline analyzing economic structures as political arrangements — who controls production, how surplus is distributed, and how economic power translates into political power." ;
  schema:datePublished "2026-03-07" ;
  schema:dateModified "2026-03-07" ;
  emsenn:Centralthesis "Political economy treats economic structures as political arrangements rather than natural laws — refusing the neoclassical separation of economics from politics, since the separation itself is a political act that naturalizes the market." ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/science/domains/information/terms/discipline/> ;
