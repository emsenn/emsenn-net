&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/domains/settler-colonialism/terms/knowledge-sovereignty/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/domains/settler-colonialism/terms/knowledge-sovereignty/> ;
  schema:name "Knowledge Sovereignty" ;
  schema:description "Knowledge sovereignty is the right of a community to control how its knowledge is represented, stored, transmitted, and used. It applies to Indigenous knowledge systems, community archives, traditional ecological knowledge, and any body of knowledge whose meaning depends on the context of its production." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
