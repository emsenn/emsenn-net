&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/benjaminian/terms/weak-messianic-power/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/benjaminian/terms/weak-messianic-power/> ;
  schema:name "Weak messianic power" ;
  schema:description "Benjamin's term, from the second of the 'Theses on the Philosophy of History' (1940), for the power each generation possesses to recognize a claim from past generations on the present and to act on that claim. The power is weak (not sovereign, not redemptive in itself) but it is nevertheless a power — the past has expectations of us that we can refuse, fulfill, or betray." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "progress-historiography" , "sovereign-messianism" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/benjaminian/terms/weak-messianic-power/> ;
  rdfs:seeAlso "jetztzeit" , "dialectical-image" , "angel-of-history" , "redemption" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/benjaminian/terms/weak-messianic-power/> .

