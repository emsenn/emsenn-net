&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/postliberalism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/postliberalism/> ;
  schema:name "Postliberalism" ;
  schema:description "The school of thought arguing that liberalism has exhausted itself — from the right (Deneen, Dreher, Vermeule) through a critique of liberal individualism, secularism, and procedural neutrality as corrosive of community, tradition, and meaning." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Centralthesis "Postliberalism argues that liberalism has exhausted itself — its core commitments to individual autonomy, procedural neutrality, and the market as organizing principle have dissolved the communal and moral foundations on which liberal institutions themselves depend." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/political-philosophy/domains/liberalism/> , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/political-philosophy/domains/liberalism/terms/procedural-liberalism/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/postliberalism/> .

