&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/decolonial/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/decolonial/> ;
  schema:name "Decolonial Marxism" ;
  schema:description "The school of Marxist analysis that insists colonialism and racial domination are constitutive of capitalism — not deviations from it — drawing on Fanon, Cabral, Mariátegui, and the anti-colonial revolutionary tradition." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  emsenn:Centralthesis "Decolonial Marxism insists that colonialism and racial domination are constitutive of capitalism rather than deviations from it — primitive accumulation was concretely the dispossession of Indigenous peoples and the enslavement of Africans, and any analysis of capitalism that brackets colonialism is analyzing an abstraction." ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/marxism/domains/decolonial/> .

