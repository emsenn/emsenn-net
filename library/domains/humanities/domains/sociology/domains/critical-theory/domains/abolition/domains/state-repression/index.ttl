&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/> ;
  schema:name "State Repression" ;
  schema:description "The analysis of how states suppress dissent, resistance, and organizing — through surveillance, infiltration, prosecution, and the legal infrastructure of political control." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Centralthesis "The analysis of state repression treats it not as a failure of liberal governance but as a feature of it — the same legal frameworks that protect rights produce the mechanisms for their suspension, and the state of exception is the structure through which liberal democracies suppress dissent without formally abandoning their commitment to rights." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
