  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-commons/> ;
  schema:name "The Commons" ;
  schema:description "Resources managed collectively by the communities that use them — not owned by individuals, corporations, or the state, but governed through shared agreements, mutual obligation, and direct participation. The destruction of the commons through enclosure is the historical origin of capitalism." ;
  schema:datePublished "2026-03-06" ;
