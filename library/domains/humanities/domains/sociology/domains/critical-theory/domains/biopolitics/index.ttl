&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/> ;
  schema:name "Biopolitics" ;
  schema:description "The lineage of thought analyzing how modern power takes biological life as its object — governing populations through the management of who lives, who dies, and what counts as living." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Centralthesis "Biopolitics names the form of modern governance that takes biological life itself as its object, and the tradition extending Foucault's analysis asks five complementary questions: what is life stripped of political standing (Agamben), how does protection turn auto-immune (Esposito), whose life is grievable (Butler), how does sovereignty work through death (Mbembe), and what governance precedes the Life/Nonlife distinction (Povinelli)." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  schema:hasPart "agamben" , "butler" , "esposito" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/terms/necropolitics/> ;
  prov:wasDerivedFrom &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> ;
  emsenn:Introduces "lineage" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/> .

