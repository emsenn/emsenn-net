&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/queer/domains/kyriarchism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/queer/domains/kyriarchism/> ;
  schema:name "Kyriarchism" ;
  schema:description "The analysis of interlocking systems of domination — patriarchy, white supremacy, capitalism, heteronormativity, ableism — as a single structure of rule rather than as separate oppressions." ;
  schema:datePublished "2025-02-19" ;
  schema:dateModified "2025-02-19" ;
  emsenn:Centralthesis "Kyriarchism (Schüssler Fiorenza's term) names the rule of lords — the interlocking structure in which patriarchy, white supremacy, capitalism, heteronormativity, and ableism operate not as separate systems that coexist but as a single structure of domination, producing intersectional conditions that single-axis analysis cannot describe." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
