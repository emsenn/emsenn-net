&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/> ;
  schema:name "Povinellian Analysis" ;
  schema:description "Elizabeth Povinelli's analytical framework — late liberalism, economies of abandonment, endurance, quasi-events, geontologies, geontopower — for understanding how liberal governance operates through withdrawal, ontological classification, and the management of the Life/Nonlife boundary." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
  emsenn:Centralthesis "Povinellian analysis treats late-liberal governance as operating through administrative withdrawal — populations and places are classified, abandoned, and retroactively justified by the failures their abandonment produces — with the underlying move being ontological politics over the Life/Nonlife boundary itself." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/late-liberalism/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/economies-of-abandonment/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/endurance/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/quasi-event/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/geontologies/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/povinellian/terms/geontopower/> ;
