&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/disaster-response/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/disaster-response/> ;
  schema:name "Disaster Response" ;
  schema:description "The sociological study of how communities respond to disasters — with emphasis on emergent, mutual-aid-based, and anti-colonial models of response that operate outside or against state frameworks." ;
  schema:datePublished "2026-03-08" ;
  schema:dateModified "2026-03-08" ;
  emsenn:Centralthesis "The sociology of disaster response analyzes catastrophe as a political question rather than a technical one — who organizes response, for whom, and on what terms — emphasizing emergent, mutual-aid-based, and anti-colonial models that operate outside or against state frameworks." ;
