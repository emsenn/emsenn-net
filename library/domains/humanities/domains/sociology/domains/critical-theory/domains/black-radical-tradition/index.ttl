&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/black-radical-tradition/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/black-radical-tradition/> ;
  schema:name "Black Radical Tradition" ;
  schema:description "The lineage of Black political thought analyzing racial capitalism, dispossession, and resistance — from slave revolt through Du Bois, C.L.R. James, Robinson, Davis, and Gilmore." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Centralthesis "The Black radical tradition holds that capitalism and racism are not separate systems but a single structure — racial capitalism — and that Black liberation is the vantage point from which the structure of modern domination becomes visible, not a special case of a more general emancipatory project." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  emsenn:Introduces "lineage" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/black-radical-tradition/> .

