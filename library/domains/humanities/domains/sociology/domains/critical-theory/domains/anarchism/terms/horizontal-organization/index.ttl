  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/horizontal-organization/> ;
  schema:name "Horizontal Organization" ;
  schema:description "Horizontal organization is the principle that a group's internal structure should not reproduce the hierarchies it opposes. Decision-making power distributes across all participants rather than concentrating in leaders, executives, or permanent committees." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
