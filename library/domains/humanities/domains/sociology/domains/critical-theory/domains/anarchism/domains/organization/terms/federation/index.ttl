&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/organization/terms/federation/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/organization/terms/federation/> ;
  schema:name "Federation" ;
  schema:description "Federation is the horizontal coordination of autonomous groups through delegates who carry revocable mandates, not permanent representatives who accumulate decision-making power. Each participating group retains its autonomy; the federation coordinates action across groups without subordinating any to a central authority." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
