  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-unconscious/> ;
  schema:name "The Unconscious" ;
  schema:description "The dimension of mental life not available to conscious awareness — not a hidden room but a structure that shapes what subjects want, do, and repeat without knowing why. Anarchist analysis draws on the unconscious to explain how domination persists at the level of subjectivity, not only institutions." ;
  schema:datePublished "2026-03-07" ;
