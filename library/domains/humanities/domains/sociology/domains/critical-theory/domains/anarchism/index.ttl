  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/> ;
  schema:name "Anarchism" ;
  schema:description "The school of political thought and practice organized around the rejection of the state and all coercive hierarchy — proposing voluntary association, mutual aid, and direct action as the basis of social organization." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Centralthesis "Anarchism treats the state and all coercive hierarchy as illegitimate, proposing voluntary association, mutual aid, direct action, and prefigurative politics — building the world you want within the shell of the world that exists — as the basis of social organization." ;
