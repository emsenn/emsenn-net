&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/feminism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/feminism/> ;
  schema:name "Feminism" ;
  schema:description "The school of thought and practice analyzing how gender organizes social life — how patriarchy operates, how it intersects with race, class, and sexuality, and how it is contested." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Centralthesis "Feminism analyzes how gender structures social life — who has power, who does what work, whose experience counts as knowledge, whose body is governed by whom — and refuses to treat any of these arrangements as natural rather than produced by social structures." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
