&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-symbolic-order/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-symbolic-order/> ;
  schema:name "The Symbolic Order" ;
  schema:description "The system of language, law, categories, and shared meaning through which a society organizes itself — and through which domination is naturalized. Drawn from Lacanian psychoanalysis, the symbolic order names the structure that makes hierarchy appear as reason, coercion as procedure, and domination as the way things simply are." ;
  schema:datePublished "2026-03-07" ;
