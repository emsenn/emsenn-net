&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/confession/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/confession/> ;
  schema:name "Confession" ;
  schema:description "The technology of self-disclosure that operates as a mechanism of power-knowledge in modernity: the requirement or solicitation of the subject to speak truthfully about themselves — their desires, transgressions, identities — to a recognized authority, with the speech itself producing the subject as a particular kind of truth-bearer rather than merely revealing pre-existing facts." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "silence" , "refusal-of-self-disclosure" , "privacy" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/confession/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/terms/governmentality/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/power-knowledge/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/> , "subjectivation" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/confession/> .

