&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/> ;
  schema:name "Abolition" ;
  schema:description "The school of thought and practice that argues the carceral state — prisons, police, surveillance — cannot be reformed and must be dismantled, with social needs met through non-punitive structures." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Analogousto &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/> ;
  emsenn:Centralthesis "Abolition argues that the carceral state cannot be reformed into justice — prisons, police, and courts do what they were built to do, and the work is to dismantle them while building the social infrastructure that makes caging people unnecessary." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/science/domains/information/terms/school/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/> .

