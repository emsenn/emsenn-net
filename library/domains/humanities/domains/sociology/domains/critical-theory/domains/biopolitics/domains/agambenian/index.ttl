&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/agambenian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/domains/agambenian/> ;
  schema:name "Agambenian Biopolitics" ;
  schema:description "Giorgio Agamben's theory of sovereignty, bare life, and the state of exception — the hidden structure of Western politics as the production of life stripped of political standing." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  emsenn:Centralthesis "Agambenian biopolitics holds that Western sovereignty operates through the production of bare life — human existence included in the political order only by being excluded from it — and that the concentration camp, not the city, is the paradigmatic space of modern politics." ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/biopolitics/> ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/political-philosophy/terms/bare-life/> , "sovereign-exception" ;
