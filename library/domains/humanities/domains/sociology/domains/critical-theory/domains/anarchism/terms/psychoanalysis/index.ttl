  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/psychoanalysis/> ;
  schema:name "Psychoanalysis" ;
  schema:description "The theoretical tradition, from Freud through Lacan, that analyzes the unconscious structures shaping desire, drive, and subjectivity. Anarchism draws on psychoanalysis not as therapy but as political analysis: it explains how domination operates at the level of wanting, how systems manage resistance through the regulation of pleasure, and why some forms of resistance escape this management." ;
