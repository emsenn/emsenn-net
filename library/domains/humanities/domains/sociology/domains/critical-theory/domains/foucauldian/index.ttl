&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/> ;
  schema:name "Foucauldian Analysis" ;
  schema:description "Michel Foucault's analytical framework — power/knowledge, discourse, archaeology, genealogy, biopower, governmentality — for understanding how institutions produce the knowledge, categories, and subjects they govern." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Centralthesis "Foucauldian analysis asks not who has power but how power works — tracing how institutions produce the knowledge that classifies and governs people, and how the subjects so produced come to understand themselves through the very frameworks that manage them." ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/power-knowledge/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/discourse/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/archaeology/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/genealogy/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/terms/biopolitics/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/abolition/domains/state-repression/terms/governmentality/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/foucauldian/terms/subject/> ;
