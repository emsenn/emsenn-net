  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarcho-nihilism/terms/desire/> ;
  schema:name "Desire" ;
  schema:description "In Lacanian psychoanalysis, the mode of wanting organized around lack — desire targets a future object, is sustained by its own non-fulfillment, and is vulnerable to collapse when the object proves unattainable. Anarcho-nihilism distinguishes desire from drive to explain why hope-based resistance fails." ;
  schema:datePublished "2026-03-06" ;
