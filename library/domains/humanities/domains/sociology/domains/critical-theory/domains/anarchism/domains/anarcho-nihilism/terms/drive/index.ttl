  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarcho-nihilism/terms/drive/> ;
  schema:name "Drive" ;
  schema:description "In Lacanian psychoanalysis, the mode of wanting that does not target an object but operates through repetition — drive circles endlessly without aiming at satisfaction, and its operation is its own purpose. Anarcho-nihilism identifies drive as the ground of resistance that persists when hope collapses." ;
  schema:datePublished "2026-03-06" ;
