  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/mutual-aid/> ;
  schema:name "Mutual Aid" ;
  schema:description "People helping each other because they share a need — not charity from above, not market exchange, but horizontal cooperation among equals. Anarchism holds that mutual aid, not competition, is the basic organizing principle of social life." ;
  schema:datePublished "2026-03-06" ;
