&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/emotional-labor/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/emotional-labor/> ;
  schema:name "Emotional labor" ;
  schema:description "The labor of producing or suppressing feelings to meet the affective expectations of an institution, role, or audience — distinct from physical or cognitive labor in that what is being shaped is the worker's own feeling-state. Coined by Arlie Russell Hochschild in *The Managed Heart* (1983) to analyze the affective work of service-sector employees." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "physical-labor" , "cognitive-labor" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/emotional-labor/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/feeling-rules/> , "affective-labor" , "emotion-work" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/affect-theory/terms/emotional-labor/> .

