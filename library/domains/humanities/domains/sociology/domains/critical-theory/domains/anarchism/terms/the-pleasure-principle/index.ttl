&lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-pleasure-principle/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/terms/the-pleasure-principle/> ;
  schema:name "The Pleasure Principle" ;
  schema:description "Freud's principle that the psychic apparatus seeks to reduce tension and maintain equilibrium — the homeostatic management of satisfaction. Anarchist analysis uses it to describe how systems of domination manage populations through the regulated distribution of pleasure, and how resistance that operates 'beyond the pleasure principle' escapes this management." ;
  schema:datePublished "2026-03-07" ;
