&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/ethnocide/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/ethnocide/> ;
  schema:name "Ethnocide" ;
  schema:description "The deliberate destruction of a people's culture — language, religion, custom, social organization — while leaving the physical population alive. Distinguished from genocide (which targets physical existence) but operating through the same logic of elimination." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/> ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/genocide/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/assimilation/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/ethnocide/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/ethnocide/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/ethnocide/> .

