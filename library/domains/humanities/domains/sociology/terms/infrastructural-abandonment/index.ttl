  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/infrastructural-abandonment/> ;
  schema:name "Infrastructural Abandonment" ;
  schema:description "The withdrawal of institutional maintenance from communities, spaces, or systems that remain inhabited — not destruction but the managed cessation of upkeep, producing slow degradation rather than acute crisis." ;
