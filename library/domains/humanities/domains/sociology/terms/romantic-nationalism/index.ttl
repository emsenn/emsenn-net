&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/romantic-nationalism/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/romantic-nationalism/> ;
  schema:name "Romantic Nationalism" ;
  schema:description "The 18th–19th century movement fusing Romantic aesthetics with national identity — claiming that each people has a unique spirit (Volksgeist) expressed through language, folklore, and custom, and that this spirit must be made visible, preserved, and defended." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Contrastswith "civic-nationalism" , "enlightenment-universalism" ;
  emsenn:Enables &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/volksgeist/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/cybernetic-postliberalism/terms/genring/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/invention-of-tradition/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/palingenetic-ultranationalism/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/romantic-nationalism/> .

