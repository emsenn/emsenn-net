  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/risk/> ;
  schema:name "Risk" ;
  schema:description "The framework through which uncertain futures are made calculable, manageable, and governable. Risk is not a neutral description of danger but a political technology that determines what counts as a threat, who is responsible for managing it, and what forms of action are considered legitimate." ;
  schema:datePublished "2026-03-07" ;
