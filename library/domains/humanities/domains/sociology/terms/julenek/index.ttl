  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/julenek/> ;
  schema:name "Julenek" ;
  schema:description "The julenek (Christmas sheaf) is a Norwegian tradition of hanging oats or wheat for birds at Christmas. It tracks through three historical phases: pre-Christian harvest offering (associated with Freya and fertility), Christian reinterpretation as charity toward creation, and modern folk tradition." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
