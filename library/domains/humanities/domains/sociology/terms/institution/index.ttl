&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/institution/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/institution/> ;
  schema:name "institution" ;
  schema:description "An institution is a stable, organized pattern of [practices](../domains/work/terms/practice.md) that structures how people act in a domain. Hospitals, schools, courts, prisons, the military, churches, and markets are institutions. So are less visible things: marriage, medical diagnosis, academic peer review, the job interview." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
