  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/anti-christian-resistance-bruvik/> ;
  schema:name "Anti-Christian resistance in Bruvik" ;
  schema:description "Bruvik, Norway was a center of Norse paganism before the forced Christianization of the 10th–11th centuries. Archaeological evidence — burial mounds, cult sites, amulets worn covertly into the Christian era — suggests persistent resistance to the new religion, both overt and everyday." ;
  schema:datePublished "2026-03-03" ;
