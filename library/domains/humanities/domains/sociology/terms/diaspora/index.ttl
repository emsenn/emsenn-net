&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/diaspora/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/diaspora/> ;
  schema:name "Diaspora" ;
  schema:description "A people dispersed from their homeland who maintain collective identity, memory, and connection across distance — not merely a population in exile but a mode of being that sustains political and cultural life without state sovereignty." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
