&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/statelessness/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/statelessness/> ;
  schema:name "Statelessness" ;
  schema:description "The condition of a people who constitute a nation but possess no sovereign state — politically legible only as minorities, refugees, or insurgents within states that claim their territory. The condition that defines Kurdish political existence." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/nation-state/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/legalism/terms/sovereignty/> , "citizenship" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/statelessness/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/statelessness/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/statelessness/> .

