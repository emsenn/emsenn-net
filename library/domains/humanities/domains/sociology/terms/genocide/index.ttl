&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/genocide/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/genocide/> ;
  schema:name "Genocide" ;
  schema:description "The deliberate destruction of a people as such — not merely mass killing but the systematic elimination of a group's capacity to exist as a group. Raphael Lemkin's coinage, expanded by subsequent scholarship to include cultural, linguistic, and epistemic dimensions." ;
  schema:datePublished "2026-04-02" ;
