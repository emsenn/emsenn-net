  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/crisis-capture/> ;
  schema:name "Crisis Capture" ;
  schema:description "The process by which states, corporations, or NGOs absorb community-led crisis responses into managerial, extractive, or counterinsurgent frameworks — turning autonomous adaptation into administered recovery." ;
