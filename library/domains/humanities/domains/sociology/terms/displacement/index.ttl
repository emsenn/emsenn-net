&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/displacement/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/displacement/> ;
  schema:name "Displacement" ;
  schema:description "The forced removal of a people from the place that sustains their way of life — not merely geographic relocation but the severing of the relationships between people, land, and practice through which culture reproduces itself." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  emsenn:Contrastswith "migration" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/diaspora/> , "nomadism" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/displacement/> , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/displacement/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/displacement/> .

