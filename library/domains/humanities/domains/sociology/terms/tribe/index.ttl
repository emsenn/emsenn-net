  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/tribe/> ;
  schema:name "Tribe" ;
  schema:description "A kinship-based political unit organized through lineage, alliance, and reciprocal obligation — analytically useful for specific social structures but politically dangerous when applied as a genre category that reduces complex societies to 'tribal peoples.'" ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
