&lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/labor/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/sociology/terms/labor/> ;
  schema:name "Labor" ;
  schema:description "Labor is purposeful human activity that transforms the world. The Marxist tradition distinguishes labor from labor-power; feminist political economy adds reproductive labor; Indigenous traditions refuse the separation between labor and the relations of life." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "leisure" , &lt;https://emsenn.net/library/domains/engineering/domains/games/terms/play/> , "labor-as-commodity" , "work-as-job" ;
  schema:about &lt;https://emsenn.net/tags/labor/> ;
