&lt;https://emsenn.net/library/domains/humanities/domains/divination/domains/tarot/terms/spread/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/divination/domains/tarot/terms/spread/> ;
  schema:name "spread" ;
  schema:description "A **spread** is a layout that assigns interpretive roles to card positions in a tarot reading. Each position in the spread carries a meaning — past, present, future; situation, obstacle, advice; self, other, outcome — and the card drawn into that position is read through that meaning." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/divination/domains/tarot/terms/spread/> .

