  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/marketing/domains/digital-marketing/terms/impression/> ;
  schema:name "Impression" ;
  schema:description "An impression is a single instance of an advertisement being loaded and displayed to a user. It is the fundamental unit of measurement in digital advertising — the atomic event that the entire [programmatic advertising](./programmatic-advertising.md) system is built to produce and count." ;
