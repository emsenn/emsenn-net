  emsenn:Governs &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/marketing/terms/marketing-plan/> , &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/strategy/terms/revenue-model/> , &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/marketing/terms/pricing-strategy/> ;
