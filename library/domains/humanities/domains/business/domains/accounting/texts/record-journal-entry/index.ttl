  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/texts/record-journal-entry/> ;
  schema:name "Record a Journal Entry" ;
  schema:description "A [journal entry](../terms/journal.md) records a single transaction in the books using [double-entry bookkeeping](../terms/double-entry-bookkeeping.md). Every entry has a date, a description, and at least one [debit and one credit](../terms/debit-and-credit.md) that are equal in total." ;
