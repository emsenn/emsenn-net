&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/texts/close-the-books/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/texts/close-the-books/> ;
  schema:name "Close the Books at Period End" ;
  schema:description "Closing the books transfers the balances of temporary accounts (revenues, expenses, dividends/draws) into [retained earnings](../terms/retained-earnings.md), resetting them to zero for the next period. This is the final step in the [accounting cycle](../terms/accounting-cycle.md) before the post-closing trial balance." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
