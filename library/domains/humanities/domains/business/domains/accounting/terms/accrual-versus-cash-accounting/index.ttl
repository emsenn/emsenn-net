  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/accrual-versus-cash-accounting/> ;
  schema:name "Accrual Versus Cash Accounting" ;
  schema:description "The most fundamental choice in accounting is *when* to record revenue and expenses. The two approaches — [accrual accounting](../terms/accrual-accounting.md) and cash accounting — give different answers and produce different financial pictures of the same business." ;
