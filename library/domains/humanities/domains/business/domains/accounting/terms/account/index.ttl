&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/account/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/account/> ;
  schema:name "account" ;
  schema:description "An account is a named record that tracks increases and decreases in a specific asset, liability, equity, revenue, or expense. It's the basic classification unit of [double-entry bookkeeping](./double-entry-bookkeeping.md) — every transaction is recorded by [debiting](./debit-and-credit.md) one or more accounts and [crediting](./debit-and-credit.md) one or more others." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
