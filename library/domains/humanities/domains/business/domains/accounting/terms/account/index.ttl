  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/double-entry-bookkeeping/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/account/> , &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/account/> ;
