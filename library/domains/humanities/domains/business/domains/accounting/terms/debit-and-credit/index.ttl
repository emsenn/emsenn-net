&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/debit-and-credit/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/debit-and-credit/> ;
  schema:name "debit and credit" ;
  schema:description "A debit is an entry on the left side of an [account](./account.md); a credit is an entry on the right side. In [double-entry bookkeeping](./double-entry-bookkeeping.md), every transaction consists of equal debits and credits — if $500 is debited somewhere, $500 must be credited elsewhere." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
