&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/closing-entry/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/closing-entry/> ;
  schema:name "closing entry" ;
  schema:description "A closing entry is a [journal entry](./journal.md) made at the end of an accounting period that transfers the balances of temporary [accounts](./account.md) — revenue, expense, and dividend accounts — to [retained earnings](./retained-earnings.md), a permanent equity account." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/terms/accounting-cycle/> ;
