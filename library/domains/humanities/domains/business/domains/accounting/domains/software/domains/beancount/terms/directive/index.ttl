&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/beancount/terms/directive/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/beancount/terms/directive/> ;
  schema:name "Directive" ;
  schema:description "A directive is any dated entry in a Beancount file. Unlike [Ledger](../ledger-cli.md), where directives are optional configuration, Beancount treats everything as a directive — transactions, account openings, balance assertions, price entries, and metadata all follow the same pattern: a date followed by a directive type." ;
