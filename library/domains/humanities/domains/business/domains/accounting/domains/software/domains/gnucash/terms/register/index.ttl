  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/gnucash/terms/register/> ;
  schema:name "Register" ;
  schema:description "The register is GnuCash's primary interface for viewing and entering transactions within a single account. It resembles a checkbook register — each row is a transaction showing date, description, transfer account, and amount. The register displays the running balance for the account." ;
  schema:datePublished "2026-03-06" ;
