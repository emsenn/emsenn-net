&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/beancount/terms/balance-assertion/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/beancount/terms/balance-assertion/> ;
  schema:name "Balance Assertion" ;
  schema:description "A balance assertion is a directive that declares what an account's balance should be on a given date. Beancount checks this assertion against the computed balance from all preceding transactions. If they don't match, Beancount reports an error." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:keywords &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/beancount/terms/balance-assertion/> .

