&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/gnucash/terms/split-transaction/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/gnucash/terms/split-transaction/> ;
  schema:name "Split Transaction" ;
  schema:description "A split transaction in GnuCash is a transaction that posts to more than two accounts. All GnuCash transactions are internally represented as splits — even a simple two-account transaction has two splits. But the term \"split transaction\" typically refers to cases where a single transaction distributes its amount across multiple accounts." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
