&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/ledger-cli/terms/virtual-posting/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/ledger-cli/terms/virtual-posting/> ;
  schema:name "Virtual Posting" ;
  schema:description "A virtual posting is a posting enclosed in parentheses `()` or square brackets `[]` that doesn't need to balance with the other postings in the transaction. Virtual postings exist for budgeting and tracking purposes — they let users associate amounts with accounts without affecting the real double-entry balance." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
