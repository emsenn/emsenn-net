  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/gnucash/texts/set-up-chart-of-accounts/> ;
  schema:name "Set Up a Chart of Accounts in GnuCash" ;
  schema:description "GnuCash ships with predefined [account](../../../../../terms/account.md) hierarchies (personal, business, etc.) that users can select when creating a new file. These templates provide a reasonable starting [chart of accounts](../../../../../terms/chart-of-accounts.md) based on common accounting needs." ;
