&lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/ledger-cli/terms/posting/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/ledger-cli/terms/posting/> ;
  schema:name "Posting" ;
  schema:description "A posting is one line within a Ledger transaction that assigns an amount to an account. Every transaction contains at least two postings, and their amounts must sum to zero (enforcing [double-entry bookkeeping](../../terms/double-entry-bookkeeping.md)). Ledger allows the last posting in a transaction to omit its amount — the software infers it from the balance." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:keywords &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/ledger-cli/terms/posting/> .

