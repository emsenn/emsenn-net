  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/business/domains/accounting/domains/software/domains/gnucash/texts/reconcile-bank-account/> ;
  schema:name "Reconcile a Bank Account in GnuCash" ;
  schema:description "Reconciliation in GnuCash matches the transactions in the [register](../terms/register.md) against a bank statement to confirm that the book balance agrees with the bank's records. This process catches errors, duplicates, and missing transactions — it's the primary way to verify that the books are accurate." ;
