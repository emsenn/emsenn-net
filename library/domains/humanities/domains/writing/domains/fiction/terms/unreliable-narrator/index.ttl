&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/unreliable-narrator/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/unreliable-narrator/> ;
  schema:name "Unreliable Narrator" ;
  schema:description "An ***unreliable narrator*** is a [narrator](./narrator.md) whose account of events the reader has reason to doubt. [Wayne Booth](../../../../general/domains/people/wayne-booth.md) introduced the concept in *The Rhetoric of Fiction* (1961): a narrator is unreliable when their norms — their values, perceptions, or knowledge — diverge from the norms the text as a whole implies [@booth1961]." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/unreliable-narrator/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/unreliable-narrator/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/unreliable-narrator/> .

