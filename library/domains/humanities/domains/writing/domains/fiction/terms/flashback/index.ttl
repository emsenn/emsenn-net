&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/flashback/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/flashback/> ;
  schema:name "Flashback" ;
  schema:description "A ***flashback*** is a [scene](./scene.md) set in the past, interrupting the present-time narrative to dramatize an earlier event. Unlike [backstory](./backstory.md) delivered through exposition or dialogue, a flashback shows the past in real time — the reader experiences it as a scene rather than being told about it." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/flashback/> .

