&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/> ;
  schema:name "Arc" ;
  schema:description "An ***arc*** is the trajectory of change in a narrative — the shape traced by a [character](./character.md)'s development or a [plot](./plot.md)'s progression from beginning to end. If plot is what happens, arc is the direction it's heading and the change it produces." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/fiction/terms/arc/> .

