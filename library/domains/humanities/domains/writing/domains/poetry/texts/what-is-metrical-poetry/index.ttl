  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/texts/what-is-metrical-poetry/> ;
  schema:name "What Is Metrical Poetry" ;
  schema:description "An introduction to metrical poetry as a contract between writer and reader's ear. Distinguishes meter from rhythm, surveys the four metrical systems, and explains why English settled on accentual-syllabic verse and what metrical writing offers that free verse cannot." ;
  schema:datePublished "2026-04-30" ;
  schema:dateModified "2026-04-30" ;
  schema:isBasedOn "./the-line-and-the-break.md" ;
