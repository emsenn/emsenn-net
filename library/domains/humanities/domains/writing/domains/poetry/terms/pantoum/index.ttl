&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/pantoum/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/pantoum/> ;
  schema:name "pantoum" ;
  schema:description "A pantoum is a fixed form built on interlocking repetition: a series of quatrains in which the second and fourth lines of each [stanza](./stanza.md) become the first and third lines of the next. In the final stanza, the first and third lines of the opening stanza return as the second and fourth lines, closing the loop." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/pantoum/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/pantoum/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/pantoum/> .

