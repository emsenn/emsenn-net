&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/assonance/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/assonance/> ;
  schema:name "assonance" ;
  schema:description "Assonance is the repetition of vowel sounds within nearby words, independent of consonants. Unlike [rhyme](./rhyme.md), which matches both vowel and following consonant sounds, assonance matches vowels alone: *lake/fate*, *deep/leen*, *hold/bone*." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/assonance/> .

