&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/sonnet/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/sonnet/> ;
  schema:name "sonnet" ;
  schema:description "A sonnet is a fourteen-line poem in [meter](./meter.md) (typically iambic pentameter) with a prescribed [rhyme](./rhyme.md) scheme and a structural [volta](./volta.md). It is one of the most durable fixed forms in the Western poetic tradition, originating in thirteenth-century Sicily and refined by Petrarch, Shakespeare, Milton, and many others." ;
  schema:datePublished "2026-03-05" ;
