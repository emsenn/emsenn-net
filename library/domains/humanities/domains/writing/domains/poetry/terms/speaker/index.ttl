&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/speaker/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/speaker/> ;
  schema:name "Speaker" ;
  schema:description "The ***speaker*** is the voice that addresses the reader in a [poem](../../../terms/poem.md) — the \"I\" (explicit or implied) who perceives, reflects, and speaks. The speaker is to poetry what the [narrator](../../fiction/terms/narrator.md) is to fiction: the figure through whom the work is experienced. And like the narrator, the speaker is not the poet." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/speaker/> .

