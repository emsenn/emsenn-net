&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/elegy/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/elegy/> ;
  schema:name "Elegy" ;
  schema:description "An ***elegy*** is a [poem](../../../terms/poem.md) of mourning — a meditation on loss, death, or the passage of time. The elegy is one of the oldest poetic modes, traceable to Greek and Latin traditions, and one of the most enduring: the impulse to address the dead, to give shape to grief, and to find (or fail to find) consolation is as old as poetry itself." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/elegy/> .

