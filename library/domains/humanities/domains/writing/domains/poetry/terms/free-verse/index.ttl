&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/free-verse/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/free-verse/> ;
  schema:name "free verse" ;
  schema:description "Free verse is poetry written without a fixed [meter](./meter.md) or [rhyme](./rhyme.md) scheme. The term translates the French *vers libre*, which named the movement that emerged in late-nineteenth-century French poetry and was taken up in English by Pound, Eliot, Williams, and others in the early twentieth century." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/> ;
