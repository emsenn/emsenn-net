&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/meter/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/meter/> ;
  schema:name "meter" ;
  schema:description "Meter is the structured pattern of stressed and unstressed syllables in a line of verse. It is the rhythmic skeleton of formal poetry — the recurring beat that the ear learns to expect and that the poet can satisfy, delay, or violate for effect." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
