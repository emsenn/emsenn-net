&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/rhyme/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/rhyme/> ;
  schema:name "rhyme" ;
  schema:description "Rhyme is the repetition of similar sounds in two or more words, most commonly at the ends of lines of verse. It is one of the oldest and most recognizable features of poetry, serving simultaneously as a structural device, a mnemonic aid, and a source of sonic pleasure." ;
