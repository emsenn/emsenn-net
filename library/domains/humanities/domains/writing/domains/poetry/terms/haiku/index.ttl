&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/haiku/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/haiku/> ;
  schema:name "haiku" ;
  schema:description "A haiku is a short Japanese poetic form traditionally composed in three phrases of 5, 7, and 5 *on* (sound units roughly analogous to syllables). In English, the form is conventionally rendered as three lines, though the syllable count is debated — Japanese *on* are shorter than English syllables, and many English-language haiku poets prefer brevity over strict 5-7-5 adherence." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
