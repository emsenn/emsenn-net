&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/couplet/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/couplet/> ;
  schema:name "couplet" ;
  schema:description "A couplet is a pair of successive lines of verse, usually linked by [rhyme](./rhyme.md) and often forming a complete syntactic and thematic unit. The couplet is one of the smallest structural units in poetry — two lines — yet it can function as a self-contained poem, a [stanza](./stanza.md) form, or a closing gesture." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
