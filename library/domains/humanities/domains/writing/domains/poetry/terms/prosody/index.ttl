&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/prosody/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/prosody/> ;
  schema:name "prosody" ;
  schema:description "Prosody is the study and practice of the sound patterns in verse: [meter](./meter.md), rhythm, [rhyme](./rhyme.md), stress, intonation, and the way these interact with meaning. It is the technical discipline of understanding how a poem sounds and why it sounds that way." ;
