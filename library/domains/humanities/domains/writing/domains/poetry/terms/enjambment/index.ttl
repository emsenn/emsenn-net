&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/enjambment/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/poetry/terms/enjambment/> ;
  schema:name "enjambment" ;
  schema:description "Enjambment is the continuation of a syntactic unit — a phrase, clause, or sentence — past the end of a [line break](./line-break.md) and into the next line. The word comes from the French *enjamber*, to step over or straddle." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
