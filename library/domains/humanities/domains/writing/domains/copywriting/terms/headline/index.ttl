&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/copywriting/terms/headline/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/copywriting/terms/headline/> ;
  schema:name "Headline" ;
  schema:description "A ***headline*** is the first line of copy the reader sees — the sentence that determines whether they read anything else. In advertising, the headline sits above the body copy. On the web, it's the H1, the email subject line, the social media post, the search result title. Whatever the format, the headline does the same job: earn the reader's next second of attention." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/copywriting/terms/headline/> .

