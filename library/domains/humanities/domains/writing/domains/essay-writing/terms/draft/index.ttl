&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/draft/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/draft/> ;
  schema:name "Draft" ;
  schema:description "A ***draft*** is a version of a piece of writing that is not yet finished — a stage in the composing process between initial generation and final text. Drafting is the act of producing that version." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/draft/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/draft/> ;
