&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/concession/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/concession/> ;
  schema:name "Concession" ;
  schema:description "A ***concession*** is the writer's acknowledgment that an opposing point has merit. It is the complement of [counterargument](./counterargument.md): where a counterargument is the opposing position itself, a concession is the writer's admission that the opposing position has force." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/concession/> .

