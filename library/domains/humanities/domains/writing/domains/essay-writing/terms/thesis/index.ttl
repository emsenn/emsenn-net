&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/thesis/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/thesis/> ;
  schema:name "Thesis" ;
  schema:description "A ***thesis*** is the central claim or governing idea of a piece of writing — the proposition that the rest of the text develops, defends, or explores. A **thesis statement** is the explicit formulation of that claim, typically appearing early in the text." ;
  schema:datePublished "2026-03-06" ;
