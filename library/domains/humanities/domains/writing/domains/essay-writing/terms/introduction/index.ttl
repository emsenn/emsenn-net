&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/introduction/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/introduction/> ;
  schema:name "Introduction" ;
  schema:description "An ***introduction*** is the opening section of an essay that orients the reader to the subject, states or implies the [thesis](../../../terms/thesis.md), and creates a reason to keep reading. It is the counterpart of the [conclusion](./conclusion.md): the introduction sets up the essay's question; the conclusion shows what the essay has found." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/introduction/> .

