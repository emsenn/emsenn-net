  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/lyric-essay/> ;
  schema:name "Lyric Essay" ;
  schema:description "A ***lyric essay*** is a hybrid form that borrows techniques from [poetry](../../poetry/_index.md) — fragmentation, juxtaposition, white space, [imagery](../../../terms/imagery.md) over [argument](./argument.md) — to do the [essay](../../../terms/essay.md)'s work of thinking through a subject." ;
  schema:datePublished "2026-03-06" ;
