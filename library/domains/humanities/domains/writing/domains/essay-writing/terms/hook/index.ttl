&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/hook/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/hook/> ;
  schema:name "Hook" ;
  schema:description "A ***hook*** is an opening that gives the reader a reason to keep reading. The term comes from journalism (where the opening is called the **lede**) but applies across all writing: the first sentence, paragraph, or page must earn the reader's attention, because no one is obligated to finish what they started." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/> ;
