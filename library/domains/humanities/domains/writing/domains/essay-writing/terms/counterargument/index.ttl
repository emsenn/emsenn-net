&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/counterargument/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/counterargument/> ;
  schema:name "Counterargument" ;
  schema:description "A ***counterargument*** is an objection to the writer's [thesis](../../../terms/thesis.md) — a reason someone might disagree, an alternative explanation, or [evidence](./evidence.md) that cuts against the claim. A **concession** is the writer's acknowledgment that the counterargument has some validity." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/counterargument/> , &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/concession/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/essay-writing/terms/counterargument/> .

