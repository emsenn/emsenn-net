&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/rhetoric-and-composition/terms/analogy/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/rhetoric-and-composition/terms/analogy/> ;
  schema:name "Analogy" ;
  schema:description "An ***analogy*** is an extended comparison between two things that are unlike in most respects but similar in the respect that matters for the writer's purpose. Where a metaphor identifies (\"grief is an ocean\"), an analogy explains (\"grief is like an ocean in that it comes in waves — sometimes calm, sometimes overwhelming, and you can't control which\")." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf "writing/topics/rhetoric-and-composition/terms" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/rhetoric-and-composition/terms/analogy/> .

