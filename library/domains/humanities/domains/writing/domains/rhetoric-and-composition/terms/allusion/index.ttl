&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/rhetoric-and-composition/terms/allusion/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/rhetoric-and-composition/terms/allusion/> ;
  schema:name "Allusion" ;
  schema:description "An ***allusion*** is an indirect reference to another text, event, person, or cultural artifact. Unlike a citation, which identifies its source explicitly, an allusion depends on the reader's recognition — the writer gestures toward a shared reference without naming it directly." ;
  schema:datePublished "2026-03-06" ;
