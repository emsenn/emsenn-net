&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/terms/tutorial/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/terms/tutorial/> ;
  schema:name "Tutorial" ;
  schema:description "A ***tutorial*** is a document that teaches the reader how to do something by walking them through a complete, worked example. It differs from [procedural documentation](./procedural-documentation.md) in its purpose: procedural documentation helps the reader complete a task they already understand; a tutorial teaches the reader a skill they don't yet have." ;
  schema:datePublished "2026-03-06" ;
