&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/terms/user-guide/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/terms/user-guide/> ;
  schema:name "User Guide" ;
  schema:description "A ***user guide*** is a document that teaches someone how to use a product, system, or service. It differs from a [tutorial](./tutorial.md) in scope: a tutorial walks the reader through one task to build a skill; a user guide covers the product comprehensively, organized so readers can find what they need when they need it." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/technical-writing/terms/user-guide/> .

