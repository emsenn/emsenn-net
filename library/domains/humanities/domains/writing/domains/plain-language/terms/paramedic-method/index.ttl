&lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/plain-language/terms/paramedic-method/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/writing/domains/plain-language/terms/paramedic-method/> ;
  schema:name "Paramedic Method" ;
  schema:description "The ***Paramedic Method*** is a step-by-step procedure for revising wordy, nominalized prose, developed by [Richard Lanham](../../general/domains/people/richard-lanham.md) in *Revising Prose* [@lanham2006]. It treats [revision](./revision.md) as a learnable, repeatable skill rather than an intuitive art." ;
