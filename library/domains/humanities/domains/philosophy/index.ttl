&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/> ;
  schema:name "Philosophy" ;
  schema:description "The study of fundamental questions about existence, knowledge, values, reason, mind, and language. Organized here by tradition of origin, not by Western academic subdiscipline." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  schema:hasPart "african" , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/buddhist/> , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/caribbean/> , "chinese" , &lt;https://emsenn.net/tags/indigenous/> , "islamic" , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/> , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/ontological-turn/> ;
  emsenn:Locates &lt;https://emsenn.net/library/domains/humanities/domains/math/domains/sets/terms/domain/> ;
  emsenn:Method "The method of philosophy is conceptual analysis, argumentation, and close reading of philosophical texts, organized by tradition of origin so that each tradition's methods and assumptions can be understood on their own terms rather than through the lens of another." ;
  emsenn:Teleology "The goal of philosophy is to examine fundamental questions about existence, knowledge, values, reason, mind, and language — and to understand how different traditions have framed and answered those questions." ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/> .

