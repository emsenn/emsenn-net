  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/texts/environment-and-totality-survey/> ;
  schema:name "Environment and Totality: The Local and the Whole" ;
  schema:description "A survey of how environment and totality relate — how the local surroundings of a thing scale (or fail to scale) into a whole that contains everything. Covers situation semantics, Hegel's concrete universal, nesting and context, and the boundary that separates inside from outside." ;
