  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/texts/substance-and-process/> ;
  schema:name "Substance and Process: Two Traditions in Ontology" ;
  schema:description "Two ancient philosophical traditions answer the question 'what is real?' in opposing ways. Substance philosophy says reality is made of persistent things. Process philosophy says reality is made of events and becomings. Neither alone captures how reality works. Both are needed." ;
