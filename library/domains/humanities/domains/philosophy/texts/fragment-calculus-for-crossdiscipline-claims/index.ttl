&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/texts/fragment-calculus-for-crossdiscipline-claims/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/texts/fragment-calculus-for-crossdiscipline-claims/> ;
  schema:name "A Fragment Calculus for Cross-Discipline Claims" ;
  schema:description "A formal framework for managing claims across disciplinary contexts — fragments contain reasoning under controlled assumptions, with explicit provenance, scoped closure, and delta analysis for cross-fragment coherence." ;
  schema:datePublished "2026-04-05" ;
  schema:dateModified "2026-04-05" ;
  emsenn:Claim "Cross-disciplinary incoherence comes not from contradictions in claims but from uncontrolled closure — importing rules across disciplinary fragments without pricing in the assumption changes." ;
  emsenn:Texttype "paper" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/texts/fragment-calculus-for-crossdiscipline-claims/> .

