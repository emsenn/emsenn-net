&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/caribbean/domains/wynterian/terms/man-overrepresentation/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/caribbean/domains/wynterian/terms/man-overrepresentation/> ;
  schema:name "Overrepresentation of Man" ;
  schema:description "Wynter's term for the structural condition in which the modern Western secular subject — Man, in two successive overrepresentations (Man1 of the rational political subject, Man2 of the bio-economic subject) — has been mistaken for the human itself, with the consequence that other genres of the human are positioned as subhuman, prehuman, or insufficiently human. The overrepresentation is not a correctable bias but the structural form of modern knowledge, governing what counts as rational, scientific, and fully human." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "pluriversal-human" , "post-anthropocentric-human" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/caribbean/domains/wynterian/terms/man-overrepresentation/> ;
  rdfs:seeAlso "genres-of-the-human" , "sociogenic-principle" , "coloniality-of-being" , "descriptive-statement" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/caribbean/domains/wynterian/terms/man-overrepresentation/> .

