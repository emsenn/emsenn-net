  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/logic/domains/paraconsistent/terms/explosion/> ;
  schema:name "Explosion" ;
  schema:description "The classical principle that from a contradiction, any proposition whatsoever can be derived — making inconsistency catastrophic. Paraconsistent logic is defined by rejecting this." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
