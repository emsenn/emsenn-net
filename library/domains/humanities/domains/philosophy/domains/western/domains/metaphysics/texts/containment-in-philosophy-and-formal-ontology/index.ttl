&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/metaphysics/texts/containment-in-philosophy-and-formal-ontology/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/metaphysics/texts/containment-in-philosophy-and-formal-ontology/> ;
  schema:name "Containment in Philosophy and Formal Ontology" ;
  schema:description "Containment is not parthood — being inside something is a spatial relation, not a compositional one. Aristotle, Casati-Varzi, DOLCE, and BFO converge on this distinction." ;
  schema:datePublished "2026-04-05" ;
  schema:dateModified "2026-04-05" ;
  emsenn:Addresses &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/container/> ;
  emsenn:Claim "Containment is a spatial location relation distinct from mereological parthood. The container and its contents are ontologically separate." ;
  emsenn:Texttype &lt;https://emsenn.net/tags/survey/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/metaphysics/texts/containment-in-philosophy-and-formal-ontology/> .

