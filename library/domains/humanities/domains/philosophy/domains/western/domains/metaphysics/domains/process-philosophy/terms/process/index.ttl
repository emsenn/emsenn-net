  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/domains/western/domains/metaphysics/domains/process-philosophy/terms/process/> ;
  schema:name "Process" ;
  schema:description "The fundamental character of reality in Whitehead's metaphysics: becoming rather than being, change rather than persistence — entities are achievements of processes, not substrates that undergo them." ;
