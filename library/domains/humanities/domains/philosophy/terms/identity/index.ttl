&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/identity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/identity/> ;
  schema:name "Identity" ;
  schema:description "What makes a thing THIS thing and not another — what persists through change. Identity is not primitive; it is grounded in properties, relations, causal history, and the continuity of a process of becoming." ;
  schema:datePublished "2026-04-03" ;
  schema:dateModified "2026-04-03" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/> ;
