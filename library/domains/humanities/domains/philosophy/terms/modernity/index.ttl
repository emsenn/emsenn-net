&lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/modernity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/modernity/> ;
  schema:name "Modernity" ;
  schema:description "The historical condition defined by industrialization, urbanization, secularization, rationalization, and the nation-state — and, crucially, by the claim that these processes constitute progress from tradition. The condition that generates Romantic nationalism as its reaction." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
