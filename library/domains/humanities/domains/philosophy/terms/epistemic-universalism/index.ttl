  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/epistemic-universalism/> ;
  schema:name "Epistemic Universalism" ;
  schema:description "The assumption that legitimate knowledge must be articulable in terms accessible to all rational agents — functioning as a gatekeeping mechanism that delegitimizes situated, relational, and place-based ways of knowing." ;
