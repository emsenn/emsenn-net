  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/authenticity/> ;
  schema:name "Authenticity" ;
  schema:description "The claim that a person, practice, or community expresses its true nature — used in Romantic nationalism to distinguish 'real' folk life from corrupted modernity, and in genring to police the boundary between who counts as a genuine member of a people and who does not." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
