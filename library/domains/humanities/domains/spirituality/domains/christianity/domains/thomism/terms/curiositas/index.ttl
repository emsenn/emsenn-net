&lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> ;
  schema:name "Curiositas" ;
  schema:description "The Thomist vice of disordered cognitive appetite: the desire to know that has been severed from its proper ends and that consumes its subject without orienting them to truth. Curiositas is restless, distracted, and self-perpetuating; it desires the knowing-as-such, regardless of whether the known is worth knowing or fits the knower's vocation. Structurally opposed to studiositas (the virtuous discipline of cognitive appetite)." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/> , "attention" , &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/situationist/terms/spectacle/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> .

