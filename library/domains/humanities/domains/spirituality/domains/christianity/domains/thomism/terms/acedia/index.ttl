&lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/> ;
  schema:name "Acedia" ;
  schema:description "The Thomist vice — one of the seven deadly sins in the Western tradition — of spiritual torpor: the inability to rouse oneself to the good one knows one should pursue. Acedia is not laziness in the ordinary sense (the disinclination to work) but a specifically spiritual condition: the soul's withdrawal from its own ends, often manifest as restlessness, distraction, and aversion to what would actually fulfill it." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "magnanimity" , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/> , "fortitude" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/> ;
  rdfs:seeAlso "tristitia" , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/> , "dejection" , "melancholia" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/> .

