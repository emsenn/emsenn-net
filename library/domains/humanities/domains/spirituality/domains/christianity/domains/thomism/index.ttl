&lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/>
  rdf:type schema:WebPage ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/> ;
  schema:name "Thomism" ;
  schema:description "The theological-philosophical tradition descended from Thomas Aquinas (c. 1225-1274) — synthesizing Aristotelian philosophy with Christian theology, articulating the virtues and vices of the soul, and providing the conceptual apparatus that the Christian pastoral institution used to govern souls. Of particular relevance to cybernetic postliberalism: the affective genres (acedia, spes, studiositas, curiositas) by which the medieval pastoral apparatus calibrated the inner life." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  schema:hasPart &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/acedia/> , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/> , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> , &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> , "virtue" , "vice" , "beatitude" , "pastoral-care" ;
