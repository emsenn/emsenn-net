&lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/> ;
  schema:name "Spes" ;
  schema:description "The Thomist theological virtue of hope: the disposition by which the soul tends toward a future good that is difficult but possible to attain, structured as expectation rather than certainty. Spes is bounded by despair (the conviction that the good cannot be attained) on one side and by presumption (the assumption that the good can be attained without effort or grace) on the other." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "desperatio" , "praesumptio" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/spes/> ;
