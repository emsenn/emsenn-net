&lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> ;
  schema:name "Studiositas" ;
  schema:description "The Thomist virtue of studiousness: the disciplined and proportioned love of knowledge that orders the desire to know to the goods that knowledge serves. Studiositas is the moderating virtue of the cognitive appetite, structurally opposed on one side by curiositas (the disordered desire for knowledge) and on the other by negligence (the failure to seek knowledge one should pursue)." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> , "negligentia" ;
  schema:about &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/curiositas/> , "prudence" , "temperantia" , &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/knowledge/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/spirituality/domains/christianity/domains/thomism/terms/studiositas/> .

