&lt;https://emsenn.net/library/domains/humanities/domains/media/domains/worldbuilding/terms/lore/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/media/domains/worldbuilding/terms/lore/> ;
  schema:name "lore" ;
  schema:description "Lore is the accumulated background knowledge of a fictional world: its histories, myths, cosmologies, genealogies, natural laws, and cultural details that are not necessarily foregrounded in any single narrative but provide depth and coherence to the world as a whole. Lore is what a world knows about itself, whether or not any particular story tells it." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf "media/topics/worldbuilding/terms" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/media/domains/worldbuilding/terms/lore/> .

