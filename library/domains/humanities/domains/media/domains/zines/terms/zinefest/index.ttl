&lt;https://emsenn.net/library/domains/humanities/domains/media/domains/zines/terms/zinefest/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/media/domains/zines/terms/zinefest/> ;
  schema:name "zinefest" ;
  schema:description "A zinefest is an organized event where [zine](./zine.md) makers gather to display, sell, trade, and distribute their work. Zinefests typically take the form of tabling events in community spaces, where each maker occupies a table and visitors move between them, browsing and purchasing." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
