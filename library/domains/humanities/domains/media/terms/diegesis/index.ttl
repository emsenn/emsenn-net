&lt;https://emsenn.net/library/domains/humanities/domains/media/terms/diegesis/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/media/terms/diegesis/> ;
  schema:name "diegesis" ;
  schema:description "Diegesis is the world as it exists within a narrative—the reality that the characters inhabit and the events they experience. The term derives from Greek rhetoric (Plato's distinction between diegesis, narration, and mimesis, imitation) and enters modern usage through narratology, particularly the work of Gérard Genette." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/media/terms/diegesis/> .

