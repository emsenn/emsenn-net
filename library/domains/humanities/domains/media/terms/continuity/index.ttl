&lt;https://emsenn.net/library/domains/humanities/domains/media/terms/continuity/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/humanities/domains/media/terms/continuity/> ;
  schema:name "continuity" ;
  schema:description "Continuity is the internal consistency of a fictional world across its multiple realizations—different works, episodes, installments, tellings, or play sessions set in the same world. A world exhibits continuity when established facts, character histories, spatial relationships, and causal sequences remain coherent from one realization to the next." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/humanities/domains/sociology/domains/critical-theory/domains/anarchism/domains/anarchist-communication/terms/media/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/humanities/domains/media/terms/continuity/> .

