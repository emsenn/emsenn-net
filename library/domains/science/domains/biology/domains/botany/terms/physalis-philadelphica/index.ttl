  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/physalis-philadelphica/> ;
  schema:name "Physalis philadelphica" ;
  schema:description "Solanaceae herb from Mexico/Central America. Produces small (2–4 cm) green berries (tomatillos) within a papery calyx husk. Characterized by gametophytic self-incompatibility (GSI) requiring cross-pollination across plants. Self-incompatible flowers are hermaphrodite but genetically prevent self-fertility; cross-compatibility occurs across genotypes at an S-locus. The only self-incompatible Physalis species commonly cultivated." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
