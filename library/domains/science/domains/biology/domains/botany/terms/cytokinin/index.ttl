  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/cytokinin/> ;
  schema:name "Cytokinin" ;
  schema:description "Cytokinin: a class of plant hormones that promote cell division (cytokinesis) and delay senescence (leaf aging). Synthesized primarily in root tips, transported upward in the xylem, and perceived through a two-component phosphorelay system. The name derives from their role in cytokinesis, though their regulatory functions extend far beyond cell division." ;
  schema:datePublished "2026-04-02" ;
