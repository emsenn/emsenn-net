&lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/solanum-tuberosum/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/solanum-tuberosum/> ;
  schema:name "Solanum tuberosum" ;
  schema:description "Solanaceae herbaceous perennial (cultivated as annual) native to Andean uplands (2,000–4,000 m elevation, Peru/Bolivia). Produces underground stem tubers (swollen stolons) as primary carbohydrate storage. Alloployploid genome (4x, 2n=48). Purple and blue pigmented cultivars accumulate high-anthocyanin tuber flesh (delphinidin-based). Insect-pollinated, self-fertile; true seed propagation rare, vegetative propagation via seed-tuber the standard." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/anthocyanin/> , &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> , &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/potato/> ;
