  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/brassica-oleracea/> ;
  schema:name "Brassica oleracea" ;
  schema:description "Herbaceous biennial from Brassicaceae, wild ancestor from coastal European cliffs. Through cultivar selection, single polymorphic species diversified into morphologically distinct groups (cabbage, broccoli, kale, Brussels sprouts) with divergent apical and axillary meristem development. All produce glucosinolates and volatile sulfur compounds; flavor enhanced by frost-induced starch-to-sugar conversion." ;
  schema:datePublished "2026-04-02" ;
