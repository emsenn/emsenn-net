&lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/tropaeolum-majus/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/tropaeolum-majus/> ;
  schema:name "Tropaeolum majus" ;
  schema:description "Annual herb from Tropaeolaceae, domesticated in the Andes. Entirely edible leaves and flowers with glucosinolate-derived peppery flavor; unripe immature seeds develop as \"poor man's capers.\" Premier trap crop for aphids (Aphididae), with volatile emissions attracting and confusing Aphis fabae, Aphis gossypii; feeding preference diverts pest pressure from adjacent crops. Herbaceous annual vine 1.5-3 m depending on cultivar and support." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/glucosinolate/> , &lt;https://emsenn.net/library/domains/engineering/domains/domesticity/domains/production/gardening/terms/radish/> , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/tropaeolum-majus/> ;
