  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/hierochloe-odorata/> ;
  schema:name "Hierochloe odorata" ;
  schema:description "Perennial grass from Poaceae, native to boreal and temperate wetlands of the Upper Great Lakes and northern North America. Called wiingashk in Ojibwe—sacred hair of O'gushnan (Mother Earth). One of Four Sacred Medicines in Anishinaabe tradition (alongside tobacco, cedar, sage). Produces coumarin-derived sweet vanilla fragrance. Rhizomatous perennial forming dense mats; propagates via rhizome division. Used ceremonially for smudging, blessing, and protection for millennia." ;
  schema:datePublished "2026-04-02" ;
