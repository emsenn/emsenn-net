  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/helianthus-annuus/> ;
  schema:name "Helianthus annuus" ;
  schema:description "Annual herb from Asteraceae, domesticated by Indigenous North American cultures ~3500 BCE. Heliotropic seedlings track the sun via differential growth on the stem; mature capitula exhibit solar tracking via pulvinus-driven petiolar movement. Accumulates helianthic acid and polyunsaturated oils in achene; yellow and purple xanthophyll pigments in ray florets. Ecological role as primary pollinator attractant and seed-oil staple." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
