  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/achillea-filipendulina/> ;
  schema:name "Achillea filipendulina" ;
  schema:description "Perennial herb from Asteraceae, native to Central Asia (Caucasus, western Asia). Hardy zones 3-9. Herbaceous perennial 0.8-1.5 m tall with finely pinnately-divided feathery foliage (hence \"filipendulina\" = threadlike leaves). Produces dense, flat-topped inflorescences (corymbs) of golden-yellow tiny disk florets. Named for Achilles—historically used as wound treatment for millennia (Trojan War mythology). Dye plant: quercetin and luteolin produce yellow-gold color. Flat-topped flower clusters function as landing pads for beneficial insects (parasitoid wasps, tachinid flies). Drought-tolerant, long-lived, cut-flower cultivar." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
