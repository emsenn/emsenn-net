  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/aquilegia-caerulea/> ;
  schema:name "Aquilegia caerulea" ;
  schema:description "Perennial herb from Ranunculaceae, native to high-altitude Rocky Mountain meadows (Colorado, Montana, New Mexico, Utah). Hardy zones 3-9. Flowers bear distinctive backwardly-projecting spurs arising from modified sepals; sepals blue or pale, petals white, spurs prominent and nectar-bearing. Blooms year two from seed. Critical early-season nectar source for native bumblebees (Bombus) and long-tongued bees (Anthophora, Eucera); also visited by hummingbirds. Self-seeds readily in cultivation." ;
  schema:datePublished "2026-04-02" ;
