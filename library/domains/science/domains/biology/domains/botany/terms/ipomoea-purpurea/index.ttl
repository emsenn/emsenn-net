  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/ipomoea-purpurea/> ;
  schema:name "Ipomoea purpurea" ;
  schema:description "Annual vine from Convolvulaceae, native to tropical Mexico. Herbaceous, twining vine producing ephemeral flowers that close by mid-morning. Flowers are funnel-shaped, typically purple-blue (purple-veined white, bicolored, or solid burgundy cultivars exist). Flowers mature acropetally along the inflorescence; each flower persists one morning. Pollinated by bumblebees and morning-flying bees. Seeds are hard-coated, toxin-containing (ergot alkaloid-like compounds), germinate slowly." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
