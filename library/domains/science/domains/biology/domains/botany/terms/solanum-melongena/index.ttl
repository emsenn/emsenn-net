  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/solanum-melongena/> ;
  schema:name "Solanum melongena" ;
  schema:description "Solanaceae herb from tropical and subtropical Asia. Domesticated from Solanum insanum (wild progenitor, South/Southeast Asia). Produces large berries with dark purple, white, striped, or green skin; white spongy mesocarp. Multiple domestication events in Asia created Occidental (Mediterranean) and Oriental (Southeast Asian) morphotypes. Protogynous buzz-pollinated flowers." ;
  schema:datePublished "2026-04-02" ;
