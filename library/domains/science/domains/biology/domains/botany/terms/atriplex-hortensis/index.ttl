  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/atriplex-hortensis/> ;
  schema:name "Atriplex hortensis" ;
  schema:description "Rapid-growing annual from Amaranthaceae, native to Central and western Asia. Produces large, triangular or rounded leaves with powdery (farinose) surface; purple cultivars exhibit deep anthocyanin coloration. Heat- and drought-tolerant; grows 4–6 feet tall. Matures in 40–50 days; early bolting but short-season annual makes multiple plantings possible." ;
  schema:datePublished "2026-04-02" ;
