  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/amaranthus-cruentus/> ;
  schema:name "Amaranthus cruentus" ;
  schema:description "Annual herb from Amaranthaceae, domesticated in Mexico 7000+ years ago. Produces dense, erect inflorescence of tightly-packed flowers in pendant tassels. Seeds are starchy, gluten-free pseudocereals with high-quality protein (16-17% crude protein); amino acid profile superior to wheat. Red flower bracts accumulate betalain pigments (amaranthin, isoamaranthin) used by Hopi and Puebloan peoples for ceremonial bread dye (hopi red dye, also in piki bread). Commercial grain and dye crop with recent agronomic revival." ;
  schema:datePublished "2026-04-02" ;
