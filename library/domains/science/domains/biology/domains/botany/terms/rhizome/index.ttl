  schema:name "Rhizome" ;
  schema:description "A modified subterranean stem that grows horizontally, producing adventitious roots and aerial shoots from its nodes — the organ responsible for clonal spread in grasses, ferns, gingers, irises, and invasive knotweeds" ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
