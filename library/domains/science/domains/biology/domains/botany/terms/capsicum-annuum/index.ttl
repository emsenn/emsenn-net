  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/capsicum-annuum/> ;
  schema:name "Capsicum annuum" ;
  schema:description "Solanaceae herb domesticated in Mexico 6,000+ years ago. Produces bell, chili, and sweet pepper morphotypes via selection on capsaicinoid biosynthesis, fruit morphology, and wall thickness. Staminate anthers release pollen via gravity and insect vibration; self-compatible but reliant on insect pollination for high fruit set." ;
