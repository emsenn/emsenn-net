&lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/tagetes-patula/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/botany/terms/tagetes-patula/> ;
  schema:name "Tagetes patula" ;
  schema:description "Annual herb from Asteraceae, domesticated in Mexico. Produces volatile terthienyls and monoterpenes that suppress root-knot nematode (*Meloidogyne* spp.) via root exudation and persistence in soil. Limonene and other terpenes suppress whitefly populations (Bemisia tabaci) through olfactory interference. Ecological role as intercrop nematicidal agent and natural insecticide in vegetable gardens." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
