&lt;https://emsenn.net/library/domains/science/domains/biology/domains/genetics/terms/gene/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/biology/domains/genetics/terms/gene/> ;
  schema:name "Gene" ;
  schema:description "A gene is a segment of [DNA](./dna.md) that encodes the information needed to produce a functional product — usually a protein, sometimes a functional RNA molecule. Genes are the units of heredity: they are passed from parent to offspring through reproduction, and the variation among genes within a population is the material on which [natural selection](../concepts/natural-selection.md) acts." ;
  schema:datePublished "2026-03-06" ;
  schema:dateModified "2026-03-06" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/biology/domains/genetics/terms/gene/> , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/genetics/terms/gene/> , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/genetics/terms/gene/> ;
  schema:isPartOf "biology/disciplines/genetics/terms" ;
