  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/texts/why-spacetime-is-one-thing/> ;
  schema:name "Why Spacetime Is One Thing" ;
  schema:description "You already have an intuition for space -- it is where things are. And you have an intuition for time -- it is when things happen. The discovery that space and time are not independent but are aspects of a single entity is one of the most important results in physics." ;
