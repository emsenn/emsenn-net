&lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/> ;
  schema:name "Redshift" ;
  schema:description "Redshift is the stretching of [light](./light.md) to longer wavelengths. In cosmology, the dominant cause is the expansion of space itself: as [light](./light.md) travels through an expanding universe, the space it traverses stretches, and the light's wavelength stretches with it." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
  emsenn:Contrastswith "blueshift" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/> ;
  emsenn:Enables &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/hubble-parameter/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/observation/terms/cosmic-distance-ladder/> ;
  schema:isBasedOn &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/light/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/electromagnetic-spectrum/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/cosmic-expansion/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/redshift/> .

