  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/texts/from-recombination-to-the-cmb/> ;
  schema:name "From Recombination to the CMB" ;
  schema:description "For the first 380,000 years, the universe was opaque. Photons could not travel more than a short distance before scattering off free electrons. Then, in a geologically brief period, the universe became transparent. The light released in that transition is still visible today." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
