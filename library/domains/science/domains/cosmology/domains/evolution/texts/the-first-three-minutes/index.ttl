  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/texts/the-first-three-minutes/> ;
  schema:name "The First Three Minutes" ;
  schema:description "Run the expansion backward. The universe gets hotter and denser. At some point, it was hot enough for nuclear fusion -- not inside stars, but everywhere, all at once. This text traces the first few minutes of the universe, when the light elements were forged." ;
  schema:datePublished "2026-03-31" ;
