  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/texts/the-expanding-universe/> ;
  schema:name "The Expanding Universe" ;
  schema:description "In 1929, Edwin Hubble observed that distant galaxies are moving away from us, and the farther they are, the faster they recede. This was the first evidence that the universe is expanding." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
