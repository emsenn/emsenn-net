&lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/big-bang/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/big-bang/> ;
  schema:name "Big Bang" ;
  schema:description "The Big Bang is the event approximately 13.8 billion years ago from which the observable universe expanded from an extremely hot, dense state. It is not an explosion in space. It is the beginning of the expansion of [spacetime](../../../terms/spacetime.md) itself." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
  emsenn:Enables &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/nucleosynthesis/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/cosmic-expansion/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/evolution/terms/cosmic-inflation/> ;
