  schema:name "Type Ia Supernova" ;
  schema:description "A Type Ia supernova is a thermonuclear explosion of a white dwarf [star](../../structure/terms/star.md) that reaches a nearly uniform peak luminosity, making it a reliable [standard candle](./standard-candle.md) for measuring cosmological distances." ;
  schema:datePublished "2026-03-31" ;
