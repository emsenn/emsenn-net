  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/observation/texts/the-cmb-as-evidence/> ;
  schema:name "The CMB as Evidence" ;
  schema:description "In 1965, Arno Penzias and Robert Wilson were testing a microwave antenna at Bell Labs and found a persistent noise they could not eliminate. It came from every direction. It did not vary with the time of day or the season. They had discovered the cosmic microwave background." ;
  schema:datePublished "2026-03-31" ;
