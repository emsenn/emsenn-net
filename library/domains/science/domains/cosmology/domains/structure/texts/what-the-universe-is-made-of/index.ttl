  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/structure/texts/what-the-universe-is-made-of/> ;
  schema:name "What the Universe Is Made Of" ;
  schema:description "Everything you have ever seen, touched, or tasted is made of protons, neutrons, and electrons. This ordinary matter -- [baryonic matter](../terms/baryonic-matter.md) -- accounts for every star, every planet, every grain of dust, every living thing. It is also less than five percent of the universe." ;
