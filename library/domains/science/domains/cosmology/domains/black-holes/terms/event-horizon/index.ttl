&lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/event-horizon/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/event-horizon/> ;
  schema:name "Event Horizon" ;
  schema:description "The event horizon is the boundary of a [black hole](./black-hole.md) -- the surface beyond which events cannot affect an outside observer. It is defined by the requirement that outgoing [light](../../../terms/light.md) rays at the horizon remain trapped: they can neither escape nor fall inward, but hover at the boundary forever." ;
  schema:datePublished "2026-03-31" ;
  schema:dateModified "2026-03-31" ;
  emsenn:Enables &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/hawking-radiation/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/bekenstein-hawking-entropy/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/holographic-principle/> ;
  schema:isBasedOn &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/black-hole/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/terms/light/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/event-horizon/> .

