  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/terms/holographic-principle/> ;
  schema:name "Holographic Principle" ;
  schema:description "The holographic principle is the conjecture that the information content of a region of space can be fully encoded on its boundary, at a density of at most one bit per Planck area ($l_P^2 \u0007pprox 2.6 \times 10^{-70}$ m$^2$)." ;
