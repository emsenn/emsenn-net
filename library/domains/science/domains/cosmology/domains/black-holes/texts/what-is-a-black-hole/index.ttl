  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/black-holes/texts/what-is-a-black-hole/> ;
  schema:name "What Is a Black Hole?" ;
  schema:description "Take a star and compress it. Make it smaller and smaller, denser and denser. At some point, the gravitational pull at the surface becomes so strong that [light](../../../terms/light.md) itself cannot escape. You have made a [black hole](../terms/black-hole.md)." ;
  schema:datePublished "2026-03-31" ;
