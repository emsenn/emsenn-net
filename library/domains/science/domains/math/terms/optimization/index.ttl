  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/terms/optimization/> ;
  schema:name "Optimization" ;
  schema:description "Optimization is finding the best option within constraints. You have a measure of quality, a set of possibilities, and rules about which possibilities are allowed. Optimization picks the possibility that scores highest on the measure without breaking the rules." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
