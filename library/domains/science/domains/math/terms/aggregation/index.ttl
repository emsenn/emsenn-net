  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/terms/aggregation/> ;
  schema:name "Aggregation" ;
  schema:description "Aggregation is collecting many individual things into one summary. A ledger aggregates accounts — it gathers all the individual account records into a single organized whole. A sum aggregates numbers. A census aggregates individuals into a population count." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
