&lt;https://emsenn.net/library/domains/science/domains/math/terms/normalization/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/terms/normalization/> ;
  schema:name "Normalization" ;
  schema:description "Normalization is dividing a quantity by a base to make it comparable. Raw numbers are hard to compare — a site earning $500 from 100,000 pageviews and a site earning $50 from 1,000 pageviews look different until you normalize by pageviews: $5 RPM vs $50 RPM." ;
