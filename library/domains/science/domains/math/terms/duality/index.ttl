&lt;https://emsenn.net/library/domains/science/domains/math/terms/duality/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/terms/duality/> ;
  schema:name "Duality" ;
  schema:description "A duality is a correspondence between two structures where everything in one has a mirror in the other, but with the directions reversed. If you flip all the arrows in one structure, you get the other." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
