  emsenn:Enables &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/morphism/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/partial-order/> , "state-machine" , "topological-sort" ;
