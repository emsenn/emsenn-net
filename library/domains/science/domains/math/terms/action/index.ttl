&lt;https://emsenn.net/library/domains/science/domains/math/terms/action/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/terms/action/> ;
  schema:name "Action" ;
  schema:description "An action is one thing operating on another. A group acting on a set moves elements around. A function acting on an input produces an output. A debit acting on an account changes its balance." ;
  schema:datePublished "2026-03-29" ;
  schema:dateModified "2026-03-29" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/terms/action/> , &lt;https://emsenn.net/library/domains/science/domains/math/terms/action/> , &lt;https://emsenn.net/library/domains/science/domains/math/terms/action/> ;
