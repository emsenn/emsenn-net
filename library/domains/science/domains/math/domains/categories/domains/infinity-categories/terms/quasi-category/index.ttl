&lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/terms/quasi-category/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/terms/quasi-category/> ;
  schema:name "Quasi-Category" ;
  schema:description "A quasi-category is a [simplicial set](./simplicial-set.md) in which every inner [horn](./horn.md) has a filler: for every map Λⁿₖ → X with 0 \u003c k \u003c n, there exists an extension Δⁿ → X. This condition ensures that composites of [morphisms](../../ordinary-categories/terms/morphism.md) exist but are not required to be unique — they are unique only up to a contractible space of choices." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/terms/quasi-category/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/texts/quasi-categories/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/terms/quasi-category/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/infinity-categories/terms/quasi-category/> .

