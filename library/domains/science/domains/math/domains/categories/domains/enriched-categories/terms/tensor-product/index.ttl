&lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/enriched-categories/terms/tensor-product/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/enriched-categories/terms/tensor-product/> ;
  schema:name "Tensor Product" ;
  schema:description "The tensor product in a [monoidal category](./monoidal-category.md) is a bifunctor ⊗: C × C → C that combines two objects into one. It is the categorical analogue of multiplication: just as a [monoid](../../../prealgebra/terms/monoid.md) has a binary operation on elements, a monoidal category has a binary operation on objects." ;
