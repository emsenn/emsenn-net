&lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/adjoint-pair/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/adjoint-pair/> ;
  schema:description "A pair of functors F ⊣ G between categories, connected by a natural bijection Hom(F(a), b) ≅ Hom(a, G(b))." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
  emsenn:Bilatticeform "⊙ ⊣ ⇒" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/adjoint-pair/> ;
  emsenn:Instances "free-forgetful" , &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/quantifier/> , "residuation" , "tensor-hom" , "extent-intent" ;
  emsenn:Lambekform "a · b ≤ c iff b ≤ a\\c iff a ≤ c/b" ;
  emsenn:Law "Hom(F(a), b) ≅ Hom(a, G(b))" ;
  emsenn:Lawvereform "∃ ⊣ ∀" ;
  emsenn:Leftadjoint "free" , "generative" , "extending" , "existential" ;
  emsenn:Linearlogicform "⊗ ⊣ ⊸" ;
  emsenn:Ordertheoreticform &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/galois-connection/> ;
  emsenn:Residuatedlatticeform "a · b ≤ c iff b ≤ a → c" ;
  emsenn:Rightadjoint "forgetful" , "constraining" , "restricting" , "universal" ;
  emsenn:Slogan "adjoints arise everywhere (Mac Lane)" ;
  emsenn:Specialization &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/functor/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/adjoint-pair/> .

