&lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/kan-extension/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/kan-extension/> ;
  schema:name "Kan Extension" ;
  schema:description "A Kan extension is the universal way to extend a [functor](./functor.md) along another [functor](./functor.md). Given [functors](./functor.md) F: C → D and K: C → E, the left Kan extension Lan_K(F): E → D is the \"best approximation\" of F that factors through K." ;
  schema:datePublished "2026-03-02" ;
