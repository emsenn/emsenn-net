  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/composition/> ;
  schema:name "Composition" ;
  schema:description "Composition is the operation that combines two consecutive [morphisms](./morphism.md) into one. If f goes from A to B and g goes from B to C, their composite g ∘ f goes from A to C. You do f first, then g." ;
