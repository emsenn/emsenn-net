&lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/proposition/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/proposition/> ;
  schema:name "Proposition" ;
  schema:description "A proposition is a statement that is capable of being true or false. \"It is raining\" is a proposition. \"2 + 2 = 4\" is a proposition. \"Close the door\" is not — it is a command, not something that has a truth value. The concept is one of the oldest in logic: Aristotle defined it (as *apophansis*) in *De Interpretatione* as a sentence that can be affirmed or denied." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
