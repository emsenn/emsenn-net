&lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/model/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/model/> ;
  schema:name "Model" ;
  schema:description "A model is a mathematical structure that makes a set of logical sentences true. It is the bridge between syntax (the formal sentences of a theory) and semantics (what those sentences are *about*). The axioms of group theory are sentences in a formal language. The integers under addition are a model of those axioms — a concrete mathematical object in which every axiom holds true." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/model/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/model/> , &lt;https://emsenn.net/library/domains/science/domains/cosmology/domains/structure/> ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/definition/> ;
  emsenn:Mathematicalobject "first-order-theory" ;
