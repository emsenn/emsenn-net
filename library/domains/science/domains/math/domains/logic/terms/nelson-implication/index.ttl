&lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/nelson-implication/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/nelson-implication/> ;
  schema:description "A strong implication on bilattices incorporating both direct and contrapositive reasoning: x ⇒_N y = (x ⊃ y) ∧ (∼y ⊃ ∼x)." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
  emsenn:Actson &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/bilattice/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/twist-product/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/nelson-implication/> ;
  emsenn:Generalizedby "busaniche-galatos-marcos-2022" , "rivieccio-busaniche-2024" ;
  emsenn:Identity "(x ⇒ (x ⇒ y)) ∧_k (~y ⇒ (~y ⇒ ~x)) = x ⇒ y" ;
  emsenn:Incorporates "direct-implication" , &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/contrapositive/> ;
  emsenn:Introducedby "chajda-langer-2021" ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/connective/> ;
  emsenn:Repairs &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/contrapositive/> ;
  emsenn:Secondadjointpairon &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/twist-product/> ;
  emsenn:Simplecontrapositive "fails-on-bilattice" ;
  emsenn:Specialization "residual-implication" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/logic/terms/nelson-implication/> .

