&lt;https://emsenn.net/library/domains/science/domains/math/domains/topology/terms/restriction/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/topology/terms/restriction/> ;
  schema:name "Restriction" ;
  schema:description "Restriction is the operation of moving data from a larger context to a smaller one — given a section s defined on U and an inclusion V ⊆ U, the restriction s|_V is the section obtained by \"forgetting\" the data outside V." ;
  schema:datePublished "2025-12-26" ;
