&lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/binomial-coefficient/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/binomial-coefficient/> ;
  schema:name "Binomial Coefficient" ;
  schema:description "The binomial coefficient $\binom{n}{k}$ (read \"$n$ choose $k$\") counts the number of ways to choose $k$ objects from $n$ without regard to order — the number of [combinations](./combination.md). It is defined as $\binom{n}{k} = \frac{n!}{k!(n-k)!}$ for $0 leq k leq n$. For example, $\binom{5}{2} = \frac{5!}{2! cdot 3!} = \frac{120}{2 cdot 6} = 10$: there are 10 ways to choose 2 objects from 5." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/binomial-coefficient/> .

