&lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/natural-numbers/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/natural-numbers/> ;
  schema:name "Natural Numbers" ;
  schema:description "The natural numbers ℕ = {0, 1, 2, 3, ...} are the numbers generated from [zero](./zero.md) by repeated application of the [successor](./successor.md) operation. They are characterized by the [Peano axioms](./peano-axioms.md): zero is a natural number, every natural number has a successor, zero is not a successor, the successor function is injective, and [induction](./induction.md) holds." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/natural-numbers/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/natural-numbers/> ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/definition/> ;
  schema:isPartOf "Peano arithmetic" ;
  schema:isBasedOn "./zero.md" , "./successor.md" , "./peano-axioms.md" , "./induction.md" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/number-theory/terms/natural-numbers/> .

