  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/functions/is-boolean-true/> ;
  schema:description "Cascades boolean-element evidence into a parallel is-boolean-true-result fiber, preserving the structured channels that carry each contribution. Reading is-boolean-true-result at a subject gives the witnessing of whether and why the subject is boolean-true." ;
