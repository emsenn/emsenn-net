&lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/coset/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/coset/> ;
  schema:name "Coset" ;
  schema:description "A coset is a \"shifted copy\" of a [subgroup](./subgroup.md) within a larger [group](./group.md). Given a subgroup $H$ of a group $G$ and an element $g in G$, the left coset of $H$ by $g$ is $gH = {g cdot h : h in H}$ — you take every element of $H$ and multiply it on the left by $g$. The right coset is $Hg = {h cdot g : h in H}$ — you multiply on the right instead." ;
  schema:datePublished "2026-03-05" ;
  schema:dateModified "2026-03-05" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/coset/> .

