  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/closure/> ;
  schema:description "The result of repeatedly applying a set of rules until nothing new is produced. The least fixpoint of a monotone operator — making all derivable consequences explicit." ;
