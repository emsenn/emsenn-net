  emsenn:Computedvia "knaster-tarski" ;
  emsenn:Convergence "at most 2 × |assertions| steps" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/closure/> ;
  emsenn:Effectivealgebraafter "{t, f, ⊤}" ;
  emsenn:Onbilattice "eliminates ⊥ within scope" ;
  emsenn:Properties &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/idempotence/> , "extensive" , &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/monotone/> ;
