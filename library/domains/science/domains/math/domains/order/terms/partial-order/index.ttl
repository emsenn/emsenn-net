  emsenn:Enables &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/lattice/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/meet/> , &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/join/> ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/humanities/domains/philosophy/terms/relation/> ;
