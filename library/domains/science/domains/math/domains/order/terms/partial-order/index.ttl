&lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/partial-order/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/partial-order/> ;
  schema:name "Partial Order" ;
  schema:description "A partial order on a set is a relation ≤ that satisfies three rules. It is [reflexive](./reflexive.md): everything is ≤ itself. It is [transitive](./transitive.md): if a ≤ b and b ≤ c, then a ≤ c. It is [antisymmetric](./antisymmetric.md): if a ≤ b and b ≤ a, then a and b are the same thing. A set with a partial order on it is called a partially ordered set, or poset." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
  emsenn:Contrastswith &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/total-order/> ;
