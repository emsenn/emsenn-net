&lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/antisymmetric/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/math/domains/order/terms/antisymmetric/> ;
  schema:name "Antisymmetric" ;
  schema:description "A relation R on a set S is antisymmetric if mutual relatedness implies equality: whenever aRb and bRa, then a = b." ;
  schema:datePublished "2025-12-26" ;
  schema:dateModified "2025-12-26" ;
