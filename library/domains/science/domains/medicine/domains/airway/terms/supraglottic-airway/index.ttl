  schema:name "Supraglottic Airway" ;
  schema:description "A rescue airway device placed above the vocal cords to support oxygenation and ventilation when bag-mask ventilation or tracheal intubation is inadequate or delayed." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Actson &lt;https://emsenn.net/library/domains/science/domains/medicine/domains/airway/> ;
  schema:isPartOf "airway-management-escalation" ;
  emsenn:Contrastswith "endotracheal-intubation" , "cricothyrotomy" ;
