  schema:name "First-Pass Metabolism" ;
  schema:description "The phenomenon by which an orally administered drug is extensively metabolized by the liver and intestinal wall before reaching systemic circulation, dramatically reducing the fraction of active drug available" ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
