&lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/ultrastability/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/ultrastability/> ;
  schema:name "Ultrastability" ;
  schema:description "Ashby's term for the property of a system that maintains its essential variables within survival ranges across multiple regimes of disturbance — including disturbances that exceed the system's first-order response repertoire — by reorganizing its own structure when first-order regulation fails." ;
  schema:datePublished "2026-04-27" ;
  schema:dateModified "2026-04-27" ;
  emsenn:Contrastswith "first-order-stability" , "brittle-stability" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/ultrastability/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/requisite-variety/> , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/physiology/terms/homeostasis/> , "viable-system" , &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/structural-coupling/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/ultrastability/> .

