&lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/requisite-variety/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/requisite-variety/> ;
  schema:name "Requisite variety" ;
  schema:description "Ashby's law: a system can regulate its environment only if its internal variety is at least equal to the variety of disturbances arriving from that environment. Equivalently, only variety can absorb variety. Stability requires that the regulating system match the complexity of what it regulates." ;
  schema:datePublished "2026-03-03" ;
  schema:dateModified "2026-03-03" ;
  emsenn:Contrastswith "single-loop-control" , "fixed-rule-system" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/requisite-variety/> ;
  rdfs:seeAlso &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/ultrastability/> , "viable-system" , &lt;https://emsenn.net/library/domains/science/domains/biology/domains/physiology/terms/homeostasis/> , "attenuator" , "amplifier" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/information/domains/cybernetics/terms/requisite-variety/> .

