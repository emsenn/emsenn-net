&lt;https://emsenn.net/library/domains/science/domains/information/terms/term/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/terms/term/> ;
  schema:name "Term" ;
  schema:description "A Term is an element of the free algebra T(Σ, X) over a signature Σ and variable set X. It is the canonical syntactic object: built compositionally from variables and operation symbols, characterized by the universal property that any variable assignment into any Σ-algebra extends uniquely to an interpretation of all terms." ;
  schema:datePublished "2026-03-18" ;
  schema:dateModified "2026-03-18" ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/information/terms/term/> ;
  rdfs:seeAlso "Formula, Proposition" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/information/terms/term/> .

