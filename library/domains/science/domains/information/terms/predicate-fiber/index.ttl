&lt;https://emsenn.net/library/domains/science/domains/information/terms/predicate-fiber/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/terms/predicate-fiber/> ;
  schema:description "The collection of all subject-object pairs sharing a predicate, together with their epistemic values. The basic unit of the fiber functor." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
  emsenn:Adjunctiononfiber "⊙ ⊣ ⇒" ;
  emsenn:Algebra &lt;https://emsenn.net/library/domains/science/domains/math/domains/algebra/terms/bilattice/> ;
  emsenn:Collects &lt;https://emsenn.net/library/domains/science/domains/information/terms/subject-predicate-object/> ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/information/> ;
  schema:about &lt;https://emsenn.net/library/domains/science/domains/information/terms/predicate-fiber/> ;
  emsenn:Distributive "true" ;
  emsenn:Functorassignment "p ↦ A_p" ;
  emsenn:Functoris "contravariant" ;
  emsenn:Functortarget "distributive-bilattice" ;
  emsenn:Infcaterms "column of a formal context" ;
  emsenn:Infeaturestructureterms "all entities' values for a single attribute" ;
  emsenn:Indexedby "predicate" ;
  emsenn:Introduces &lt;https://emsenn.net/library/domains/science/domains/information/terms/predicate-fiber/> ;
  emsenn:Pattern &lt;https://emsenn.net/library/domains/science/domains/math/domains/categories/domains/ordinary-categories/terms/hyperdoctrine/> ;
  emsenn:Pointwiseoperations "truth-meet" , "truth-join" , "knowledge-meet" , "knowledge-join" ;
  emsenn:Valuesin &lt;https://emsenn.net/library/domains/science/domains/information/terms/epistemic-state/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/information/terms/predicate-fiber/> .

