  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/texts/what-resource-sensitivity-means-for-knowledge/> ;
  schema:name "What Resource Sensitivity Means for Knowledge" ;
  schema:description "Linear logic treats premises as resources consumed by use. Applied to knowledge systems, this means assertions have epistemic weight that gets used up when you reason with them." ;
