  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/texts/predication-as-residuation/> ;
  schema:name "Predication as Residuation" ;
  schema:description "Three fields independently discovered that predication — the act of asserting a relationship between subject and object — is a residuation. Lambek found it in grammar, Lawvere in logic, Busaniche-Cignoli in algebra." ;
  schema:datePublished "2026-03-30" ;
  schema:dateModified "2026-03-30" ;
