  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/texts/documentation-theory-survey/> ;
  schema:name "Documentation Theory: A Survey of Documents, Signs, and Records" ;
  schema:description "Survey of documentation theory from Otlet and Briet through archival science and Buckland. Examines what documents are, how they differ from knowledge, the principles of archival preservation, and the threefold nature of information and documentation." ;
