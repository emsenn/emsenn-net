  schema:name "Why Four Values Instead of Two?" ;
  schema:description "Classical logic has true and false. Belnap's bilattice adds 'unknown' and 'contradictory.' This text explains why the four-valued system is the right one for knowledge that comes from multiple sources." ;
  schema:datePublished "2026-03-31" ;
