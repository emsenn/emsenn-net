&lt;https://emsenn.net/library/domains/science/domains/information/texts/the-bilattice-valued-allegory-of-relational-composition/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/information/texts/the-bilattice-valued-allegory-of-relational-composition/> ;
  schema:name "The Bilattice-Valued Allegory of Relational Composition" ;
  schema:description "The allegory of bilattice-valued relations on $mathbf{2}otimesmathbf{2}$ decomposes as a product of two classical Freyd-Scedrov allegories. Classical relational composition embeds as a proper sub-allegory; the bilattice allegory is a strictly stronger, lossless refinement tracking an orthogonal refutation channel." ;
  schema:datePublished "2026-04-14" ;
  schema:dateModified "2026-04-14" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/information/> ;
