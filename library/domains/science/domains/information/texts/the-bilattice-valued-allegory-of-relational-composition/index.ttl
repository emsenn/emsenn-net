  schema:isBasedOn &lt;https://emsenn.net/library/domains/science/domains/information/texts/the-adjoint-structure-of-predication-on-bilattice-valued-fibers/> , &lt;https://emsenn.net/library/domains/science/domains/information/texts/the-adjoint-structure-of-predication-on-bilattice-valued-fibers/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/information/texts/the-bilattice-valued-allegory-of-relational-composition/> .

