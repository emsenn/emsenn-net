&lt;https://emsenn.net/library/domains/science/domains/linguistics/terms/linguicide/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/linguistics/terms/linguicide/> ;
  schema:name "Linguicide" ;
  schema:description "The deliberate killing of a language by state policy — not natural language death but the systematic suppression of a language through bans, educational exclusion, and institutional erasure. Coined by Amir Hassanpour." ;
  schema:datePublished "2026-04-02" ;
  schema:dateModified "2026-04-02" ;
  schema:isPartOf &lt;https://emsenn.net/library/domains/science/domains/linguistics/> ;
  emsenn:Contrastswith "language-death" , "language-shift" ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/linguistics/terms/linguicide/> .

