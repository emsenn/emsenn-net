&lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semantics/terms/intension/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semantics/terms/intension/> ;
  schema:name "intension" ;
  schema:description "An **intension** is the rule, concept, or mode of presentation that determines what a term refers to. Where [extension](extension.md) is the actual referent a term picks out, intension is the criterion that does the picking." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
