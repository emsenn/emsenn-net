&lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/icon/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/icon/> ;
  schema:name "icon" ;
  schema:description "An icon is a [sign](./sign.md) that represents its object by resemblance. The [representamen](./representamen.md) shares some quality or structural feature with the thing it stands for — a portrait resembles the person depicted, a map resembles the territory, a diagram resembles the structure it represents." ;
