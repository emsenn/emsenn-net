&lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/representamen/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/representamen/> ;
  schema:name "representamen" ;
  schema:description "The representamen is the form a [sign](./sign.md) takes — the mark, sound, gesture, image, or token that enters into a [sign](./sign.md) relation. It is the thing that does the representing, as distinct from the object it represents and the [interpretant](./interpretant.md) it produces." ;
