&lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/signified/>
  rdf:type schema:Article ;
  schema:url &lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/signified/> ;
  schema:name "signified" ;
  schema:description "The signified (*signifié*) is one half of [Saussure](../../../../../../humanities/domains/general/domains/people/ferdinand-de-saussure.md)'s dyadic model of the [sign](./sign.md). It is the concept evoked by the [signifier](./signifier.md) — not a referent in the world but a mental concept within a language system." ;
  schema:datePublished "2025-12-31" ;
  schema:dateModified "2025-12-31" ;
  schema:keywords &lt;https://emsenn.net/tags/saussure/> ;
  schema:identifier &lt;https://emsenn.net/library/domains/science/domains/linguistics/domains/semiotics/terms/signified/> .

